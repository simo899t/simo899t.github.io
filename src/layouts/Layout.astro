---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Simon Holm',
  description = 'AI student at SDU. Builder. Chairperson of IMADA Fagråd.',
} = Astro.props;

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'Simon Holm' ? 'Simon Holm' : `${title} — Simon Holm`}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">simon holm</a>
      <ul class="nav-links">
        <li><a href="/"         class={isActive('/')         ? 'active' : ''}>about</a></li>
        <li><a href="/projects" class={isActive('/projects') ? 'active' : ''}>projects</a></li>
        <li><a href="/cv"       class={isActive('/cv')       ? 'active' : ''}>cv</a></li>
        <li><a href="/notes"    class={isActive('/notes')    ? 'active' : ''}>notes</a></li>
        <li><a href="/contact"  class={isActive('/contact')  ? 'active' : ''}>contact</a></li>
      </ul>
    </div>
  </nav>

  <canvas id="loss-canvas" aria-hidden="true"></canvas>

  <main>
    <slot />
  </main>

  <footer>
    <p>© 2026 Simon Holm · <a href="mailto:simon@cogito.dk">simon@cogito.dk</a> · <a href="https://github.com/simo899t" target="_blank">GitHub</a></p>
  </footer>
</body>
</html>

<script>
const canvas = document.getElementById('loss-canvas') as HTMLCanvasElement;
const ctx    = canvas.getContext('2d')!;
const dpr    = window.devicePixelRatio || 1;

const W = 100, H = 90;
canvas.width  = W * dpr;
canvas.height = H * dpr;
canvas.style.width  = W + 'px';
canvas.style.height = H + 'px';
ctx.scale(dpr, dpr);

const PAD = { t: 8, r: 6, b: 18, l: 18 };
const PW  = W - PAD.l - PAD.r;
const PH  = H - PAD.t - PAD.b;
const N   = 80; // epochs

function makeLoss(start: number, end: number, noise: number): number[] {
  const pts: number[] = [];
  for (let i = 0; i < N; i++) {
    const t    = i / (N - 1);
    const base = start * Math.exp(-4 * t) + end;
    pts.push(base + (Math.random() - 0.5) * noise * (1 - t * 0.7));
  }
  return pts;
}

let trainLoss: number[] = [];
let valLoss:   number[] = [];
let progress   = 0;
let pauseTicks = 0;

function newRun() {
  const end = 0.08 + Math.random() * 0.12;
  trainLoss = makeLoss(1.2 + Math.random() * 0.4, end,            0.06);
  valLoss   = makeLoss(1.3 + Math.random() * 0.3, end + 0.05,    0.09);
  progress  = 0;
}

function draw() {
  ctx.clearRect(0, 0, W, H);

  // axes
  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  ctx.lineWidth   = 0.5;
  ctx.beginPath(); ctx.moveTo(PAD.l, PAD.t); ctx.lineTo(PAD.l, PAD.t + PH); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(PAD.l, PAD.t + PH); ctx.lineTo(PAD.l + PW, PAD.t + PH); ctx.stroke();

  // axis labels
  ctx.fillStyle   = 'rgba(255,255,255,0.2)';
  ctx.font        = '6px Consolas, monospace';
  ctx.textAlign   = 'center';
  ctx.fillText('epochs', PAD.l + PW / 2, H - 3);
  ctx.save();
  ctx.translate(6, PAD.t + PH / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillText('loss', 0, 0);
  ctx.restore();

  const maxL = Math.max(...trainLoss, ...valLoss, 0.01);
  const n    = Math.max(2, Math.floor(progress));

  function plotLine(pts: number[], color: string) {
    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth   = 1;
    for (let i = 0; i < n && i < pts.length; i++) {
      const x = PAD.l + (i / (N - 1)) * PW;
      const y = PAD.t + PH - (pts[i] / maxL) * PH;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();
  }

  plotLine(trainLoss, 'rgba(77,182,196,0.55)');
  plotLine(valLoss,   'rgba(180,130,255,0.35)');

  // legend
  ctx.font      = '5.5px Consolas, monospace';
  ctx.textAlign = 'left';
  ctx.fillStyle = 'rgba(77,182,196,0.5)';  ctx.fillText('train', PAD.l + 2,      PAD.t + 7);
  ctx.fillStyle = 'rgba(180,130,255,0.4)'; ctx.fillText('val',   PAD.l + 28, PAD.t + 7);
}

function tick() {
  if (progress < N) {
    progress += 0.9;
    draw();
  } else {
    pauseTicks++;
    if (pauseTicks > 60) { newRun(); pauseTicks = 0; }
  }
  requestAnimationFrame(tick);
}

newRun();
tick();
</script>

<style is:global>
#loss-canvas {
  display: none;
  position: fixed;
  right: calc(50% - 350px - 115px);
  top: 50%;
  transform: translateY(-50%);
  opacity: 0.45;
  pointer-events: none;
}

@media (min-width: 980px) {
  #loss-canvas { display: block; }
}
</style>
