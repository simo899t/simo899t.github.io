---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Simon Holm',
  description = 'AI student at SDU. Builder. Chairperson of IMADA Fagråd.',
} = Astro.props;

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'Simon Holm' ? 'Simon Holm' : `${title} — Simon Holm`}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">simon holm</a>
      <ul class="nav-links">
        <li><a href="/"         class={isActive('/')         ? 'active' : ''}>about</a></li>
        <li><a href="/projects" class={isActive('/projects') ? 'active' : ''}>projects</a></li>
        <li><a href="/cv"       class={isActive('/cv')       ? 'active' : ''}>cv</a></li>
        <li><a href="/notes"    class={isActive('/notes')    ? 'active' : ''}>notes</a></li>
        <li><a href="/contact"  class={isActive('/contact')  ? 'active' : ''}>contact</a></li>
      </ul>
    </div>
  </nav>

  <canvas id="plexus" aria-hidden="true"></canvas>

  <main>
    <slot />
  </main>

  <footer>
    <p>© 2026 Simon Holm · <a href="mailto:simon@cogito.dk">simon@cogito.dk</a> · <a href="https://github.com/simo899t" target="_blank">GitHub</a></p>
  </footer>
</body>
</html>

<script>
const canvas = document.getElementById('plexus') as HTMLCanvasElement;
const ctx    = canvas.getContext('2d')!;
const dpr    = window.devicePixelRatio || 1;

const W = 220;
let   H = window.innerHeight;

function resize() {
  H = window.innerHeight;
  canvas.width        = W * dpr;
  canvas.height       = H * dpr;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  buildNet();
}

// ── network architecture ──────────────────────────────
const LAYERS = [3, 5, 5, 4, 2];   // neurons per layer
const NR     = 5;                  // neuron radius
const COL_GAP = W / (LAYERS.length + 1);

interface Neuron { x: number; y: number; act: number; }
type Edge = { a: Neuron; b: Neuron; w: number; pulse: number; active: boolean; };

let neurons: Neuron[][] = [];
let edges:   Edge[]     = [];

function buildNet() {
  neurons = LAYERS.map((count, li) => {
    const x      = COL_GAP * (li + 1);
    const totalH = (count - 1) * 44;
    const startY = H / 2 - totalH / 2;
    return Array.from({ length: count }, (_, ni) => ({
      x,
      y: startY + ni * 44,
      act: 0,
    }));
  });

  edges = [];
  for (let li = 0; li < neurons.length - 1; li++) {
    for (const a of neurons[li]) {
      for (const b of neurons[li + 1]) {
        edges.push({
          a, b,
          w:      0.3 + Math.random() * 0.5,
          pulse:  -1,
          active: false,
        });
      }
    }
  }
}

// ── forward pass animation ────────────────────────────
const PULSE_SPEED = 0.018;
let   passTimer   = 0;

function firePass() {
  // reset
  for (const layer of neurons) for (const n of layer) n.act = 0;
  for (const e of edges) { e.pulse = -1; e.active = false; }

  // activate input layer
  for (const n of neurons[0]) n.act = 0.4 + Math.random() * 0.6;

  // schedule edge pulses layer by layer
  let delay = 0;
  for (let li = 0; li < neurons.length - 1; li++) {
    const layerEdges = edges.filter(e => e.a === neurons[li].find(n => n === e.a) || neurons[li].includes(e.a));
    const d = delay;
    setTimeout(() => {
      for (const e of layerEdges) {
        e.active = true;
        e.pulse  = 0;
      }
      // activate next layer neurons when pulses arrive
      setTimeout(() => {
        for (const n of neurons[li + 1]) {
          n.act = 0.35 + Math.random() * 0.55;
        }
      }, 1000 / PULSE_SPEED * 0.001 * 1000);
    }, d);
    delay += 900;
  }
}

firePass();
setInterval(firePass, LAYERS.length * 900 + 1400);

// ── draw ─────────────────────────────────────────────
function draw() {
  ctx.clearRect(0, 0, W, H);

  // edges
  for (const e of edges) {
    if (e.active && e.pulse >= 0 && e.pulse <= 1) {
      e.pulse += PULSE_SPEED;

      // draw the travelling dot
      const px = e.a.x + (e.b.x - e.a.x) * e.pulse;
      const py = e.a.y + (e.b.y - e.a.y) * e.pulse;

      // trail
      const grad = ctx.createLinearGradient(e.a.x, e.a.y, px, py);
      grad.addColorStop(0, 'rgba(77,182,196,0)');
      grad.addColorStop(1, `rgba(77,182,196,${e.w * 0.35})`);
      ctx.beginPath();
      ctx.moveTo(e.a.x, e.a.y);
      ctx.lineTo(px, py);
      ctx.strokeStyle = grad;
      ctx.lineWidth   = 0.8;
      ctx.stroke();

      // pulse dot
      ctx.beginPath();
      ctx.arc(px, py, 1.8, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(77,182,196,${e.w * 0.9})`;
      ctx.fill();
    } else {
      // resting edge — very dim
      ctx.beginPath();
      ctx.moveTo(e.a.x, e.a.y);
      ctx.lineTo(e.b.x, e.b.y);
      ctx.strokeStyle = `rgba(77,182,196,${e.w * 0.06})`;
      ctx.lineWidth   = 0.5;
      ctx.stroke();
    }
  }

  // neurons
  for (const layer of neurons) {
    for (const n of layer) {
      const alpha = 0.12 + n.act * 0.5;

      // glow
      if (n.act > 0.1) {
        const g = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, NR * 3);
        g.addColorStop(0, `rgba(77,182,196,${n.act * 0.18})`);
        g.addColorStop(1, 'rgba(77,182,196,0)');
        ctx.beginPath();
        ctx.arc(n.x, n.y, NR * 3, 0, Math.PI * 2);
        ctx.fillStyle = g;
        ctx.fill();
      }

      // ring
      ctx.beginPath();
      ctx.arc(n.x, n.y, NR, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(77,182,196,${0.18 + n.act * 0.55})`;
      ctx.lineWidth   = 1;
      ctx.stroke();

      // fill
      ctx.beginPath();
      ctx.arc(n.x, n.y, NR - 1, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(77,182,196,${alpha})`;
      ctx.fill();

      // decay activation slowly
      n.act *= 0.993;
    }
  }
}

function tick() { draw(); requestAnimationFrame(tick); }
resize();
window.addEventListener('resize', resize);
tick();
</script>

<style is:global>
#plexus {
  display: none;
  position: fixed;
  right: calc(50% - 350px - 230px);
  top: 0;
  opacity: 0.85;
  pointer-events: none;
  z-index: 0;
}

@media (min-width: 1020px) {
  #plexus { display: block; }
}

main { position: relative; z-index: 1; }
nav  { position: relative; z-index: 2; }
</style>
