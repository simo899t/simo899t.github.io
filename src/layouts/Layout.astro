---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Simon Holm',
  description = 'AI student at SDU. Builder. Chairperson of IMADA Fagråd.',
} = Astro.props;

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'Simon Holm' ? 'Simon Holm' : `${title} — Simon Holm`}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">simon holm</a>
      <ul class="nav-links">
        <li><a href="/"         class={isActive('/')         ? 'active' : ''}>about</a></li>
        <li><a href="/projects" class={isActive('/projects') ? 'active' : ''}>projects</a></li>
        <li><a href="/cv"       class={isActive('/cv')       ? 'active' : ''}>cv</a></li>
        <li><a href="/notes"    class={isActive('/notes')    ? 'active' : ''}>notes</a></li>
        <li><a href="/contact"  class={isActive('/contact')  ? 'active' : ''}>contact</a></li>
      </ul>
    </div>
  </nav>

  <canvas id="plexus" aria-hidden="true"></canvas>

  <main>
    <slot />
  </main>

  <footer>
    <p>© 2026 Simon Holm · <a href="mailto:simon@cogito.dk">simon@cogito.dk</a> · <a href="https://github.com/simo899t" target="_blank">GitHub</a></p>
  </footer>
</body>
</html>

<script>
const canvas = document.getElementById('plexus') as HTMLCanvasElement;
const ctx    = canvas.getContext('2d')!;
const dpr    = window.devicePixelRatio || 1;

const W = 200;
let H = window.innerHeight;

function resize() {
  H = window.innerHeight;
  canvas.width  = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
}
resize();
window.addEventListener('resize', resize);

// Node type
interface Node {
  x: number; y: number;
  vx: number; vy: number;
  r: number;
}

const NODE_COUNT = 38;
const LINK_DIST  = 90;
const SPEED      = 0.22;

const nodes: Node[] = Array.from({ length: NODE_COUNT }, () => ({
  x:  Math.random() * W,
  y:  Math.random() * window.innerHeight,
  vx: (Math.random() - 0.5) * SPEED,
  vy: (Math.random() - 0.5) * SPEED,
  r:  1.5 + Math.random() * 1.5,
}));

function draw() {
  const h = canvas.height / dpr;
  ctx.clearRect(0, 0, W, h);

  // edges
  for (let i = 0; i < nodes.length; i++) {
    for (let j = i + 1; j < nodes.length; j++) {
      const dx = nodes[i].x - nodes[j].x;
      const dy = nodes[i].y - nodes[j].y;
      const d  = Math.sqrt(dx * dx + dy * dy);
      if (d < LINK_DIST) {
        const alpha = (1 - d / LINK_DIST) * 0.28;
        ctx.strokeStyle = `rgba(77,182,196,${alpha})`;
        ctx.lineWidth   = 0.6;
        ctx.beginPath();
        ctx.moveTo(nodes[i].x, nodes[i].y);
        ctx.lineTo(nodes[j].x, nodes[j].y);
        ctx.stroke();
      }
    }
  }

  // nodes
  for (const n of nodes) {
    ctx.beginPath();
    ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(77,182,196,0.55)';
    ctx.fill();
  }
}

function tick() {
  const h = canvas.height / dpr;
  for (const n of nodes) {
    n.x += n.vx;
    n.y += n.vy;
    if (n.x < 0 || n.x > W)  n.vx *= -1;
    if (n.y < 0 || n.y > h)  n.vy *= -1;
  }
  draw();
  requestAnimationFrame(tick);
}

tick();
</script>

<style is:global>
#plexus {
  display: none;
  position: fixed;
  right: calc(50% - 350px - 210px);
  top: 0;
  opacity: 0.5;
  pointer-events: none;
  z-index: 0;
}

@media (min-width: 1020px) {
  #plexus { display: block; }
}

main { position: relative; z-index: 1; }
nav  { position: relative; z-index: 2; }
</style>
