---
import Layout from '../layouts/Layout.astro';

const education = [
  {
    period: '2024 –',
    title: 'BSc Artificial Intelligence',
    place: 'University of Southern Denmark (IMADA), Odense',
    detail: 'Algorithms & data structures, machine learning, linear algebra, functional programming (Haskell), knowledge representation, optimisation, ethics.',
  },
  {
    period: '2020 – 2023',
    title: 'Gymnasium (STX)',
    place: 'Technical programme',
    detail: 'Mathematics, physics, innovation & product development.',
  },
];

const experience = [
  {
    period: 'Mar 2025 –',
    title: 'Chairperson, IMADA Fagråd',
    place: 'University of Southern Denmark',
    detail: 'Student council for AI & Mathematics. Represent students in faculty and university meetings.',
  },
  {
    period: '2023 – 2024',
    title: 'Webscraper & Web Developer',
    place: 'Freelance',
    detail: '',
  },
];

const skills = ['Python', 'Java', 'Haskell', 'SQL', 'PyTorch', 'SciPy', 'Git'];
---

<Layout title="CV" description="Simon Holm — curriculum vitae.">
  <div class="container page">

    <div class="cv-header">
      <h1><strong>Simon</strong> Holm</h1>
      <a href="/cv.pdf" download class="download">Download PDF ↓</a>
    </div>

    <hr />

    <section>
      <h2>Education</h2>
      <div class="timeline">
        {education.map(e => (
          <div class="item">
            <span class="period">{e.period}</span>
            <div>
              <strong>{e.title}</strong>
              <span class="place">{e.place}</span>
              {e.detail && <p>{e.detail}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <section>
      <h2>Experience & Leadership</h2>
      <div class="timeline">
        {experience.map(e => (
          <div class="item">
            <span class="period">{e.period}</span>
            <div>
              <strong>{e.title}</strong>
              <span class="place">{e.place}</span>
              {e.detail && <p>{e.detail}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <section>
      <h2>Skills</h2>
      <p class="skills">{skills.join(' · ')}</p>
    </section>

  </div>
</Layout>

<style>
.cv-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 1rem;
  padding-top: 1rem;
  flex-wrap: wrap;
}

h1 {
  font-size: 2.2rem;
  font-weight: 300;
  letter-spacing: -0.01em;
}

h1 strong { font-weight: 700; }

.download {
  font-size: 0.82rem;
  color: var(--text-muted);
  white-space: nowrap;
}

.download:hover { color: var(--text); text-decoration: none; }

h2 {
  font-size: 0.8rem;
  font-weight: 500;
  text-transform: lowercase;
  letter-spacing: 0.02em;
  color: var(--text-muted);
  margin-bottom: 1.25rem;
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
}

.item {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 1rem;
}

.period {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-dim);
  padding-top: 3px;
  white-space: nowrap;
}

.item strong {
  display: block;
  font-size: 0.9rem;
  color: var(--text);
  margin-bottom: 0.15rem;
}

.place {
  display: block;
  font-size: 0.8rem;
  color: var(--accent);
  margin-bottom: 0.3rem;
}

.item p {
  font-size: 0.82rem;
  color: var(--text-dim);
  margin: 0;
}

.skills {
  font-size: 0.875rem;
  color: var(--text-muted);
  margin: 0;
}

@media (max-width: 500px) {
  .item { grid-template-columns: 1fr; gap: 0.25rem; }
}
</style>
