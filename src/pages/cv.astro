---
import Layout from '../layouts/Layout.astro';

const education = [
  {
    title: 'BSc Artificial Intelligence',
    place: 'University of Southern Denmark (IMADA), Odense',
    period: '2024 – present',
    details: [
      'Sem 1: Discrete Mathematics · Intro to Programming · Intro to Computer Science',
      'Sem 2: Intro to AI · Algorithms & Data Structures · Calculus · OOP (Java) · Database Systems',
      'Sem 3: Machine Learning · Linear Algebra · Functional Programming (Haskell) · Ethics & Privacy · Calculus',
      'Sem 4: Advanced Machine Learning · Optimisation · Knowledge Representation · AI & Society',
      'Sem 5: Knowledge Representation & Reasoning · …',
    ],
  },
  {
    title: 'Gymnasium (STX)',
    place: 'Technical programme — Mathematics, Physics & Innovation',
    period: '2020 – 2023',
    details: [],
  },
];

const experience = [
  {
    title: 'Chairperson, IMADA Fagråd',
    place: 'University of Southern Denmark',
    period: 'Mar 2025 – present',
    desc: 'Leading student representation for AI & Mathematics at IMADA. Facilitating communication between students and faculty, advocating for curriculum and welfare improvements.',
  },
  {
    title: 'Webscraper & Web Developer',
    place: 'Freelance / Personal',
    period: '2023 – 2024',
    desc: 'Built web scraping pipelines and small web tools.',
  },
  {
    title: 'Student Assistant',
    place: '',
    period: '',
    desc: '',
  },
];

const skills = {
  'Programming': ['Python', 'Java', 'Haskell', 'SQL'],
  'Tools & Frameworks': ['PyTorch', 'SciPy', 'NumPy', 'Git', 'Astro', 'Flask'],
  'Areas': ['Machine Learning', 'Deep Learning', 'Optimisation', 'Algorithms & Data Structures', 'Knowledge Representation'],
  'Languages': ['Danish (native)', 'English (fluent)'],
};
---

<Layout title="CV" description="Simon Holm's curriculum vitae — education, experience, and skills.">
  <div class="container page">

    <div class="cv-header">
      <div>
        <p class="section-label">Curriculum Vitae</p>
        <h1>Simon Holm</h1>
        <p class="subtitle">AI Student · SDU · Odense, Denmark</p>
      </div>
      <a href="/cv.pdf" download class="btn-download">
        ↓ Download PDF
      </a>
    </div>

    <!-- PDF preview -->
    <div class="pdf-wrapper">
      <embed src="/cv.pdf" type="application/pdf" width="100%" height="640px" />
      <p class="pdf-fallback">
        <a href="/cv.pdf" target="_blank">Open CV in new tab</a> if the preview doesn't load.
      </p>
    </div>

    <hr />

    <!-- Timeline: Education -->
    <section>
      <p class="section-label">Education</p>
      <div class="timeline">
        {education.map(e => (
          <div class="timeline-item">
            <div class="tl-meta">
              <span class="tl-period">{e.period}</span>
            </div>
            <div class="tl-body">
              <strong class="tl-title">{e.title}</strong>
              <span class="tl-place">{e.place}</span>
              {e.details.length > 0 && (
                <ul class="tl-details">
                  {e.details.map(d => <li>{d}</li>)}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <!-- Timeline: Experience -->
    <section>
      <p class="section-label">Experience & Leadership</p>
      <div class="timeline">
        {experience.filter(e => e.desc).map(e => (
          <div class="timeline-item">
            <div class="tl-meta">
              <span class="tl-period">{e.period}</span>
            </div>
            <div class="tl-body">
              <strong class="tl-title">{e.title}</strong>
              {e.place && <span class="tl-place">{e.place}</span>}
              {e.desc && <p class="tl-desc">{e.desc}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <!-- Skills -->
    <section>
      <p class="section-label">Skills</p>
      <div class="skills-grid">
        {Object.entries(skills).map(([cat, items]) => (
          <div class="skill-group">
            <h3>{cat}</h3>
            <div class="chips">
              {items.map(s => <span class="tag accent">{s}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</Layout>

<style>
h1 {
  font-size: 2rem;
  letter-spacing: -0.02em;
}

.cv-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 2rem;
  flex-wrap: wrap;
}

.subtitle {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--accent);
  margin-top: 0.25rem;
}

.btn-download {
  display: inline-block;
  padding: 0.55rem 1.25rem;
  border-radius: 6px;
  font-size: 0.875rem;
  font-weight: 500;
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-muted);
  white-space: nowrap;
  transition: border-color 0.2s, color 0.2s;
  opacity: 1 !important;
}

.btn-download:hover {
  border-color: var(--border-hover);
  color: var(--text);
}

.pdf-wrapper {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--bg-card);
}

.pdf-fallback {
  text-align: center;
  font-size: 0.8rem;
  padding: 0.75rem;
  color: var(--text-dim);
  border-top: 1px solid var(--border);
}

.pdf-fallback a {
  color: var(--accent);
}

/* Timeline */
.timeline {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-top: 1rem;
  padding-left: 0.5rem;
  border-left: 2px solid var(--border);
}

.timeline-item {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 1.25rem;
  padding-left: 1.25rem;
  position: relative;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: -5px;
  top: 6px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid var(--bg);
}

.tl-meta {
  padding-top: 2px;
}

.tl-period {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-dim);
  white-space: nowrap;
}

.tl-title {
  display: block;
  font-size: 0.95rem;
  color: var(--text);
  margin-bottom: 0.15rem;
}

.tl-place {
  display: block;
  font-size: 0.8rem;
  color: var(--accent);
  margin-bottom: 0.4rem;
}

.tl-desc {
  font-size: 0.82rem;
  color: var(--text-dim);
  margin: 0;
}

.tl-details {
  margin: 0.5rem 0 0 0;
  padding-left: 1rem;
  list-style: none;
}

.tl-details li {
  font-size: 0.8rem;
  color: var(--text-dim);
  margin-bottom: 0.2rem;
  position: relative;
}

.tl-details li::before {
  content: '·';
  position: absolute;
  left: -0.9rem;
  color: var(--accent);
}

/* Skills */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
  margin-top: 1rem;
}

.skill-group h3 {
  font-size: 0.78rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 0.5rem;
  font-weight: 500;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

@media (max-width: 600px) {
  .timeline-item { grid-template-columns: 1fr; gap: 0.25rem; }
  .skills-grid { grid-template-columns: 1fr; }
}
</style>
