---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Simon Holm" description="AI student at SDU. Chairperson of IMADA Fagråd.">
  <div class="container page">

    <section class="hero">
      <img src="/profile.png" alt="Simon Holm" class="photo" />
      <div class="hero-text">
        <h1>Simon Holm</h1>
        <p class="tagline">AI · SDU · Odense</p>
      </div>
    </section>

    <div class="bio">
      <p>
        5th-semester AI student at SDU. I'm interested in interpretability and what
        Danish and European AI sovereignty actually means in practice.
      </p>
      <p>
        I chair the <a href="https://imada.sdu.dk" target="_blank">IMADA Fagråd</a> — the student council
        for math &amp; CS at my faculty. Outside that: sim racing, music, gaming.
      </p>
      <p>
        I write study notes in <a href="https://typst.app" target="_blank">Typst</a>.
        If you want to learn Typst syntax there's a game I made for it:
        <a href="https://simo899t.github.io/typstnique" target="_blank">Typstnique</a>.
      </p>
    </div>

    <nav class="inline-nav">
      <a href="/projects">Projects</a>
      <a href="/cv">CV</a>
      <a href="/notes">Notes</a>
      <a href="/contact">Contact</a>
    </nav>

  </div>
</Layout>

<style>
.hero {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: 3.5rem 0 2rem;
}

.photo {
  width: 72px;
  height: 72px;
  border-radius: 6px;
  object-fit: cover;
  flex-shrink: 0;
}

h1 {
  font-size: 1.5rem;
  font-weight: 600;
  letter-spacing: -0.02em;
  margin-bottom: 0.15rem;
}

.tagline {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--text-dim);
  margin: 0;
}

.bio {
  max-width: 520px;
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
  margin-bottom: 2.5rem;
}

.bio p {
  font-size: 0.925rem;
  color: var(--text-muted);
  margin: 0;
}

.inline-nav {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
}

.inline-nav a {
  font-size: 0.875rem;
  color: var(--text-muted);
  border-bottom: 1px solid var(--border);
  padding-bottom: 1px;
  transition: color 0.15s, border-color 0.15s;
  opacity: 1 !important;
}

.inline-nav a:hover {
  color: var(--text);
  border-color: var(--text-muted);
}
</style>
