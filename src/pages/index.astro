---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Simon Holm" description="AI student at SDU. Chairperson of IMADA Fagråd.">
  <div class="container page">

    <div class="layout">
      <div class="content">
        <h1><strong>Simon</strong> Holm</h1>

        <p>
          4th-semester AI student at SDU. I'm very passionate about machine learning, with a key interest in mechanistic interpretability and
          Danish and European AI/technology sovereignty.
        </p>
        <p>
          I chair the <a href="https://imadafagraad.dk" target="_blank">IMADA Fagråd</a> — the student council
          for math &amp; CS at my faculty. Outside that: Math, science-fiction, music, gaming.
        </p>
        <p>
          I write study notes in <a href="https://typst.app" target="_blank">Typst</a>.
          If you want to learn the syntax there's a game I made:
          <a href="https://simo899t.github.io/typstnique" target="_blank">Typstnique</a>.
        </p>
      </div>

      <div class="sidebar">
        <img src="/profile.png" alt="Simon Holm" class="photo" />
        <p class="address">Institute of Mathematics and Computer Science, SDU<br />Odense, Denmark</p>
      </div>
    </div>

    <div class="links">
      <a href="/projects">Projects</a>
      <a href="/cv">CV</a>
      <a href="/notes">Notes</a>
      <a href="/contact">Contact</a>
    </div>

  </div>
</Layout>

<style>
.layout {
  display: grid;
  grid-template-columns: 1fr 180px;
  gap: 3rem;
  align-items: start;
  padding-top: 1.5rem;
}

h1 {
  font-size: 2.2rem;
  font-weight: 300;
  letter-spacing: -0.01em;
  margin-bottom: 1.25rem;
  line-height: 1.2;
}

h1 strong { font-weight: 700; }

p {
  font-size: 0.9rem;
  margin-bottom: 0.9rem;
  color: var(--text-muted);
}

.sidebar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.9rem;
  padding-top: 0.5rem;
}

.photo {
  width: 150px;
  height: 150px;
  border-radius: 50%;
  object-fit: cover;
}

.address {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  text-align: center;
  line-height: 1.7;
  margin: 0;
}

.links {
  display: flex;
  gap: 1.25rem;
  margin-top: 1.75rem;
}

.links a {
  font-size: 0.875rem;
  color: var(--text-muted);
}

.links a:hover {
  color: var(--text);
  text-decoration: none;
}

@media (max-width: 560px) {
  .layout { grid-template-columns: 1fr; }
  .sidebar { flex-direction: row; align-items: center; gap: 1.25rem; }
  .photo { width: 72px; height: 72px; }
  .address { text-align: left; }
}
</style>
