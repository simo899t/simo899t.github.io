---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Simon Holm" description="AI student at SDU. Chairperson of IMADA Fagråd.">
  <div class="container page">

    <div class="layout">
      <div class="content">
        <h1><strong>Simon</strong> Holm</h1>

        <p>
          5th-semester AI student at SDU. I'm interested in interpretability and what
          Danish and European AI sovereignty actually means in practice.
        </p>
        <p>
          I chair the <a href="https://imada.sdu.dk" target="_blank">IMADA Fagråd</a> — the student council
          for math &amp; CS at my faculty. Outside that: sim racing, music, gaming.
        </p>
        <p>
          I write study notes in <a href="https://typst.app" target="_blank">Typst</a>.
          If you want to learn the syntax there's a game I made:
          <a href="https://simo899t.github.io/typstnique" target="_blank">Typstnique</a>.
        </p>
      </div>

      <div class="sidebar">
        <img src="/profile.png" alt="Simon Holm" class="photo" />
        <p class="address">IMADA, SDU<br />Odense, Denmark</p>
      </div>
    </div>

    <canvas id="algo"></canvas>

    <div class="links">
      <a href="/projects">Projects</a>
      <a href="/cv">CV</a>
      <a href="/notes">Notes</a>
      <a href="/contact">Contact</a>
    </div>

  </div>
</Layout>

<script>
const CELL = 11;
const BG       = '#141414';
const WALL     = '#2c2c2c';
const VISITED  = '#1a2a2d';
const CURRENT  = '#4db6c4';
const PATH     = '#163040';

let cols: number, rows: number, grid: Cell[][], stack: Cell[], current: Cell, done: boolean;
let animId: number, resetTimer: ReturnType<typeof setTimeout>;

interface Cell {
  r: number; c: number;
  visited: boolean;
  walls: [boolean, boolean, boolean, boolean]; // top right bottom left
}

const canvas = document.getElementById('algo') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

function resize() {
  cancelAnimationFrame(animId);
  clearTimeout(resetTimer);
  const w = canvas.parentElement!.clientWidth;
  cols = Math.floor(w / CELL);
  rows = 9;
  canvas.width  = cols * CELL * dpr;
  canvas.height = rows * CELL * dpr;
  canvas.style.width  = `${cols * CELL}px`;
  canvas.style.height = `${rows * CELL}px`;
  ctx.scale(dpr, dpr);
  start();
}

function start() {
  grid = [];
  for (let r = 0; r < rows; r++) {
    grid[r] = [];
    for (let c = 0; c < cols; c++) {
      grid[r][c] = { r, c, visited: false, walls: [true, true, true, true] };
    }
  }
  current = grid[0][0];
  current.visited = true;
  stack = [];
  done = false;
  loop();
}

function loop() {
  step();
  step();
  step();
  draw();
  if (!done) {
    animId = requestAnimationFrame(loop);
  } else {
    resetTimer = setTimeout(() => { ctx.scale(1/dpr, 1/dpr); ctx.scale(dpr, dpr); start(); }, 1800);
  }
}

function step() {
  if (done) return;
  const nb = neighbors(current);
  if (nb.length) {
    const next = nb[Math.floor(Math.random() * nb.length)];
    stack.push(current);
    removeWall(current, next);
    next.visited = true;
    current = next;
  } else if (stack.length) {
    current = stack.pop()!;
  } else {
    done = true;
  }
}

function neighbors(cell: Cell): Cell[] {
  const { r, c } = cell;
  const out: Cell[] = [];
  if (r > 0        && !grid[r-1][c].visited) out.push(grid[r-1][c]);
  if (c < cols - 1 && !grid[r][c+1].visited) out.push(grid[r][c+1]);
  if (r < rows - 1 && !grid[r+1][c].visited) out.push(grid[r+1][c]);
  if (c > 0        && !grid[r][c-1].visited) out.push(grid[r][c-1]);
  return out;
}

function removeWall(a: Cell, b: Cell) {
  const dr = b.r - a.r, dc = b.c - a.c;
  if (dr === -1) { a.walls[0] = false; b.walls[2] = false; }
  if (dc ===  1) { a.walls[1] = false; b.walls[3] = false; }
  if (dr ===  1) { a.walls[2] = false; b.walls[0] = false; }
  if (dc === -1) { a.walls[3] = false; b.walls[1] = false; }
}

const stackSet = new Set<Cell>();

function draw() {
  stackSet.clear();
  stack.forEach(c => stackSet.add(c));

  ctx.fillStyle = BG;
  ctx.fillRect(0, 0, cols * CELL, rows * CELL);

  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      const cell = grid[r][c];
      const x = c * CELL, y = r * CELL;

      if (cell === current) {
        ctx.fillStyle = CURRENT;
        ctx.fillRect(x + 1, y + 1, CELL - 2, CELL - 2);
      } else if (stackSet.has(cell)) {
        ctx.fillStyle = PATH;
        ctx.fillRect(x + 1, y + 1, CELL - 2, CELL - 2);
      } else if (cell.visited) {
        ctx.fillStyle = VISITED;
        ctx.fillRect(x + 1, y + 1, CELL - 2, CELL - 2);
      }

      ctx.strokeStyle = WALL;
      ctx.lineWidth = 1;
      if (cell.walls[0]) { ctx.beginPath(); ctx.moveTo(x, y);          ctx.lineTo(x + CELL, y);          ctx.stroke(); }
      if (cell.walls[1]) { ctx.beginPath(); ctx.moveTo(x + CELL, y);   ctx.lineTo(x + CELL, y + CELL);   ctx.stroke(); }
      if (cell.walls[2]) { ctx.beginPath(); ctx.moveTo(x + CELL, y + CELL); ctx.lineTo(x, y + CELL);     ctx.stroke(); }
      if (cell.walls[3]) { ctx.beginPath(); ctx.moveTo(x, y + CELL);   ctx.lineTo(x, y);                 ctx.stroke(); }
    }
  }
}

resize();
window.addEventListener('resize', resize);
</script>

<style>
.layout {
  display: grid;
  grid-template-columns: 1fr 180px;
  gap: 3rem;
  align-items: start;
  padding-top: 1.5rem;
}

h1 {
  font-size: 2.2rem;
  font-weight: 300;
  letter-spacing: -0.01em;
  margin-bottom: 1.25rem;
  line-height: 1.2;
}

h1 strong { font-weight: 700; }

p {
  font-size: 0.9rem;
  margin-bottom: 0.9rem;
  color: var(--text-muted);
}

.sidebar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.9rem;
  padding-top: 0.5rem;
}

.photo {
  width: 150px;
  height: 150px;
  border-radius: 50%;
  object-fit: cover;
}

.address {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  text-align: center;
  line-height: 1.7;
  margin: 0;
}

#algo {
  display: block;
  margin: 1.75rem 0 1.5rem;
  border-radius: 3px;
}

.links {
  display: flex;
  gap: 1.25rem;
}

.links a {
  font-size: 0.875rem;
  color: var(--text-muted);
}

.links a:hover {
  color: var(--text);
  text-decoration: none;
}

@media (max-width: 560px) {
  .layout { grid-template-columns: 1fr; }
  .sidebar { flex-direction: row; align-items: center; gap: 1.25rem; }
  .photo { width: 72px; height: 72px; }
  .address { text-align: left; }
}
</style>
