---
import Layout from '../layouts/Layout.astro';

const groups = [
  {
    lang: 'Python',
    projects: [
      { title: 'Sorting Network Generator', note: '1st sem exam', url: 'https://github.com/simo899t/sortnet', desc: 'Generating optimal sorting networks for lists.' },
      { title: 'C3Paw — Cat & Dog Classifier', note: '4th sem exam', url: 'https://github.com/simo899t/cat_dog_classification', desc: 'CNN-based image classifier using PyTorch.' },
      { title: 'Path & CNN Optimization', note: '4th sem exam', url: 'https://github.com/simo899t/optimization_assignment_1', desc: 'Shortest-path algorithms and CNN optimisation.' },
      { title: 'Mood2-D2 — Emotion Classifier', note: '4th sem exam', url: 'https://github.com/simo899t/emotion_classifier', desc: 'Classifying human emotions from facial expressions.' },
      { title: 'Simplex Environment Search', note: '4th sem exam', url: 'https://github.com/simo899t/optimization_assignment_2', desc: 'Simplex method and roar-net-api solver.' },
      { title: 'SundAdmin API', note: 'personal', url: 'https://github.com/simo899t/SundAdmin', desc: 'My first REST API.' },
    ],
  },
  {
    lang: 'Java',
    projects: [
      { title: 'Pacman', note: '2nd sem exam', url: 'https://github.com/simo899t/pacman', desc: 'Pacman-like game with JavaFX.' },
    ],
  },
  {
    lang: 'Haskell',
    projects: [
      { title: 'snakey', note: '3rd sem exam', url: 'https://github.com/simo899t/snakey', desc: 'A DSL for defining and running snake-like games.' },
    ],
  },
  {
    lang: 'Web',
    projects: [
      { title: 'Typstnique', note: 'personal', url: 'https://simo899t.github.io/typstnique', desc: 'A game for learning Typst syntax.' },
      { title: 'Practice Quiz App', note: 'personal', url: 'https://github.com/simo899t', desc: 'Quiz app for SDU exam practice — multiple choice and free response with MathJax.' },
    ],
  },
  {
    lang: 'Notes',
    projects: [
      { title: 'SDU Notes', note: 'sem 2–5', url: 'https://github.com/simo899t/SDU', desc: 'Typst lecture notes on algorithms, ML, linear algebra, KR, and more.' },
    ],
  },
];
---

<Layout title="Projects" description="Simon Holm's projects.">
  <div class="container page">
    <h1>Projects</h1>

    <div class="groups">
      {groups.map(g => (
        <section>
          <h2>{g.lang}</h2>
          <ul>
            {g.projects.map(p => (
              <li>
                <a href={p.url} target="_blank">{p.title}</a>
                <span class="note">{p.note}</span>
                <p>{p.desc}</p>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</Layout>

<style>
h1 {
  font-size: 1.5rem;
  margin-bottom: 2.5rem;
}

.groups {
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

h2 {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-dim);
  margin-bottom: 0.75rem;
}

ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

li {
  display: grid;
  grid-template-columns: auto 1fr;
  grid-template-rows: auto auto;
  column-gap: 0.6rem;
  align-items: baseline;
}

li a {
  font-size: 0.9rem;
  color: var(--text);
  font-weight: 500;
  opacity: 1 !important;
}

li a:hover { color: var(--accent); }

.note {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-dim);
}

li p {
  grid-column: 1 / -1;
  font-size: 0.82rem;
  color: var(--text-dim);
  margin: 0.1rem 0 0;
}
</style>
