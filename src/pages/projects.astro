---
import Layout from '../layouts/Layout.astro';

const groups = [
  {
    lang: 'Python', dot: '#3b82f6',
    projects: [
      { title: 'Sorting Network Generator', note: '1st sem', url: 'https://github.com/simo899t/sortnet', desc: 'Generating optimal sorting networks for lists.' },
      { title: 'C3Paw — Cat & Dog Classifier', note: '4th sem', url: 'https://github.com/simo899t/cat_dog_classification', desc: 'CNN-based classifier of images of cats and dogs using PyTorch.' },
      { title: 'Path & CNN Optimization', note: '4th sem', url: 'https://github.com/simo899t/optimization_assignment_1', desc: 'Optimal path algorithms and CNN optimization.' },
      { title: 'Mood2-D2 — Emotion Classifier', note: '4th sem', url: 'https://github.com/simo899t/emotion_classifier', desc: 'Classifying emotions from text.' },
      { title: 'Simplex Environment Search & ILP', note: '4th sem', url: 'https://github.com/simo899t/optimization_assignment_2', desc: 'Simplex method and roar-net-api solver.' },
    ],
  },
  {
    lang: 'Java', dot: '#f59e0b',
    projects: [
      { title: 'Pacman', note: '2nd sem', url: 'https://github.com/simo899t/pacman', desc: 'Pacman-like game with JavaFX — entities, collision detection, AI ghosts.' },
    ],
  },
  {
    lang: 'Haskell', dot: '#a855f7',
    projects: [
      { title: 'snakey', note: '3rd sem', url: 'https://github.com/simo899t/snakey', desc: 'A DSL for defining and running 1v1 snake-like games.' },
    ],
  },
  {
    lang: 'Web', dot: '#22c55e',
    projects: [
      { title: 'Typstnique', note: 'personal', url: 'https://simo899t.github.io/typstnique', desc: 'A game for learning Typst syntax.' },
      { title: 'Practice Quiz App', note: 'personal', url: 'https://github.com/simo899t', desc: 'Quiz app for SDU exam practice — multiple choice + free response.' },
    ],
  },
  {
    lang: 'Notes & Coursework', dot: '#4db6c4',
    projects: [
      { title: 'SDU Notes', note: 'sem 2–5', url: 'https://github.com/simo899t/SDU', desc: 'Typst lecture notes covering algorithms, ML, linear algebra, KR, and more.' },
    ],
  },
];
---

<Layout title="Projects" description="Simon Holm's projects.">
  <div class="container page">
    <h1>Projects</h1>
    <p class="sub">Coursework and personal projects from SDU and beyond.</p>

    <div class="groups">
      {groups.map(g => (
        <section>
          <h2>
            <span class="dot" style={`background:${g.dot}`}></span>
            {g.lang}
          </h2>
          <ul>
            {g.projects.map(p => (
              <li>
                <div class="row">
                  <a href={p.url} target="_blank">{p.title}</a>
                  <span class="note">{p.note}</span>
                </div>
                <p>{p.desc}</p>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</Layout>

<style>
h1 {
  font-size: 1.6rem;
  font-weight: 600;
  margin-bottom: 0.35rem;
}

.sub {
  font-size: 0.85rem;
  color: var(--text-dim);
  margin-bottom: 2.5rem;
}

.groups {
  display: flex;
  flex-direction: column;
  gap: 2.25rem;
}

h2 {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  margin-bottom: 0.75rem;
}

.dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  flex-shrink: 0;
}

ul {
  list-style: none;
  border-left: 1px solid var(--border);
  padding-left: 1rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

li { }

.row {
  display: flex;
  align-items: baseline;
  gap: 0.6rem;
  margin-bottom: 0.15rem;
}

.row a {
  font-size: 0.875rem;
  color: var(--text);
  font-weight: 500;
}

.row a:hover { color: var(--accent); text-decoration: none; }

.note {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
}

li p {
  font-size: 0.8rem;
  color: var(--text-dim);
  margin: 0;
}
</style>
