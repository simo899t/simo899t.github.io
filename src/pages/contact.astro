---
import Layout from '../layouts/Layout.astro';

const links = [
  {
    label: 'Email',
    value: 'simon@cogito.dk',
    href: 'mailto:simon@cogito.dk',
    icon: '✉',
  },
  {
    label: 'GitHub',
    value: 'github.com/simo899t',
    href: 'https://github.com/simo899t',
    icon: '⌥',
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/simon-holm',
    href: 'https://www.linkedin.com/in/simon-holm',
    icon: '↗',
  },
];
---

<Layout title="Contact" description="Get in touch with Simon Holm.">
  <div class="container page">

    <p class="section-label">Get in touch</p>
    <h1>Contact</h1>
    <p class="subtitle">
      Feel free to reach out — whether it's about a project, collaboration, or just to say hi.
    </p>

    <div class="links">
      {links.map(l => (
        <a href={l.href} target={l.href.startsWith('mailto') ? '_self' : '_blank'} class="link-card">
          <span class="link-icon">{l.icon}</span>
          <div>
            <span class="link-label">{l.label}</span>
            <span class="link-value">{l.value}</span>
          </div>
        </a>
      ))}
    </div>

    <div class="note-box">
      <p class="mono">// preferred: email</p>
      <p>I'm best reached by email. I usually reply within a day or two.</p>
    </div>

  </div>
</Layout>

<style>
h1 {
  font-size: 2rem;
  letter-spacing: -0.02em;
  margin-bottom: 0.5rem;
}

.subtitle {
  font-size: 0.9rem;
  max-width: 440px;
  margin-bottom: 2.5rem;
}

.links {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  max-width: 440px;
  margin-bottom: 2.5rem;
}

.link-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1rem 1.25rem;
  color: var(--text);
  transition: border-color 0.2s, transform 0.2s;
  opacity: 1 !important;
}

.link-card:hover {
  border-color: var(--border-hover);
  transform: translateX(3px);
}

.link-icon {
  font-size: 1rem;
  width: 28px;
  text-align: center;
  flex-shrink: 0;
  color: var(--accent);
}

.link-label {
  display: block;
  font-size: 0.7rem;
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  margin-bottom: 0.1rem;
}

.link-value {
  font-size: 0.9rem;
  color: var(--text);
}

.note-box {
  max-width: 440px;
  padding: 1rem 1.25rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-left: 3px solid var(--accent-2);
  border-radius: var(--radius);
}

.note-box .mono {
  margin-bottom: 0.35rem;
  color: var(--accent-2);
}

.note-box p {
  font-size: 0.85rem;
  margin: 0;
}
</style>
