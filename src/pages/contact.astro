---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Simon Holm.">
  <div class="container page">
    <h1>Contact</h1>

    <p>Best reached by email - I usually reply within a day or two.</p>

    <ul>
      <li><a href="mailto:simon@cogito.dk">simon@cogito.dk</a></li>
      <li><a href="https://github.com/simo899t" target="_blank">github.com/simo899t</a></li>
      <li><a href="https://www.linkedin.com/in/simon-holm-aa4b60304/" target="_blank">LinkedIn</a></li>
    </ul>
  </div>
</Layout>

<style>
h1 {
  font-size: 1.5rem;
  margin-bottom: 1.25rem;
}

p {
  font-size: 0.9rem;
  margin-bottom: 1.5rem;
}

ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

li a {
  font-size: 0.9rem;
  color: var(--text-muted);
  opacity: 1 !important;
}

li a:hover { color: var(--text); opacity: 1; }
</style>
