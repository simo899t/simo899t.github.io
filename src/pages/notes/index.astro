---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNotes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

---

<Layout title="Notes" description="Study notes by Simon Holm.">
  <div class="container page">
    <h1>Notes</h1>
    <p class="sub">
      Short write-ups on things I'm figuring out.
      Written in <a href="https://typst.app" target="_blank">Typst</a> —
      try the syntax with <a href="https://simo899t.github.io/typstnique" target="_blank">Typstnique</a>.
    </p>

    <div class="typst-blurb">
      <p>
        I write all my lecture notes in <a href="https://typst.app/open-source/" target="_blank">Typst</a> —
        a modern typesetting system that compiles as you type, with real math, clean PDFs, and
        no LaTeX boilerplate. I have a shared <code>temp.typ</code> that every course imports:
        custom <code>#theorem</code> / <code>#definition</code> boxes, matrix shorthands like <code>succ</code> and <code>mat</code>,
        calculus operators like <code>#dv(f,x)</code> and <code>#ppv(f,x)</code>, and a bunch of
        symbol aliases so KR proofs don't look like line noise.
        The demo below cycles through a few real snippets.
      </p>
    </div>

    <div class="typst-demo">
      <div class="demo-src">
        <div class="pane-bar">
          <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
          <span class="pane-title">notes.typ</span>
        </div>
        <div class="editor">
          <div class="line-nums" id="line-nums"></div>
          <pre id="typst-src"></pre>
        </div>
      </div>
      <div class="demo-out">
        <div class="pane-bar">
          <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
          <span class="pane-title">notes.pdf</span>
        </div>
        <div class="paper-wrap">
          <div class="paper" id="paper"></div>
        </div>
      </div>
    </div>

    {allNotes.length > 0 ? (
      <div class="note-list">
        {allNotes.map(n => (
          <a href={`/notes/${n.slug}`} class="note-row">
            <span class="note-title">{n.data.title}</span>
            <span class="note-meta">
              {n.data.tags.join(' · ')} &nbsp;·&nbsp;
              {n.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">more coming soon</p>
    )}
  </div>
</Layout>

<script>
const srcEl   = document.getElementById('typst-src');
const lineEl  = document.getElementById('line-nums');
const paperEl = document.getElementById('paper');
if (!srcEl || !lineEl || !paperEl) throw new Error('demo elements missing');;

// Each demo: src lines + chunks { atLine, html } that appear as that line finishes typing
const DEMOS = [
  {
    src: [
      `#import "../../temp.typ": *`,      // 0
      `#show: note.with(`,                // 1
      `  title:  "Linear Algebra",`,      // 2
      `  course: "DM561",`,               // 3
      `)`,                                // 4
      ``,                                 // 5
      `= Positive Definiteness`,          // 6
      ``,                                 // 7
      `A symmetric $A in RR^(n times n)$ is`,  // 8
      `_positive definite_ ($A succ 0$) iff`,  // 9
      `$x^T A x > 0$ for all $x != bold(0)$.`, // 10
      ``,                                 // 11
      `#definition[`,                     // 12
      `  $A succ 0 bi$ all eigenvalues`,  // 13
      `  $lambda_i > 0 bi$ Cholesky`,    // 14
      `  decomposition $A = L L^T$ exists.`, // 15
      `]`,                                // 16
      ``,                                 // 17
      `*Example.* For`,                   // 18
      `$A = mat(4, 2; 2, 3)$`,           // 19
      `we get $det(A) = 8 > 0$ and`,     // 20
      `$A_11 = 4 > 0$, so $A succ 0$.`,  // 21
    ],
    chunks: [
      { atLine: 6,  html: `<h1>Positive Definiteness</h1>` },
      { atLine: 10, html: `<p>A symmetric <em>A</em> ∈ ℝ<sup><em>n</em>×<em>n</em></sup> is <em>positive definite</em> (<em>A</em> ≻ 0) iff <em>x</em><sup>T</sup><em>Ax</em> &gt; 0 for all <em>x</em> ≠ <strong>0</strong>.</p>` },
      { atLine: 16, html: `<div class="def-box"><strong>Definition.</strong> <em>A</em> ≻ 0 ⟺ all eigenvalues λ<sub><em>i</em></sub> &gt; 0 ⟺ Cholesky decomposition <em>A</em> = <em>LL</em><sup>T</sup> exists.</div>` },
      { atLine: 21, html: `<p><strong>Example.</strong> For <em>A</em> = <span style="font-family:serif">[<sup>4 2</sup>/<sub>2 3</sub>]</span> we get det(<em>A</em>) = 8 &gt; 0 and <em>A</em><sub>11</sub> = 4 &gt; 0, so <em>A</em> ≻ 0.</p>` },
    ],
  },
  {
    src: [
      `#import "../../temp.typ": *`,      // 0
      `#show: note.with(`,                // 1
      `  title:  "Optimisation",`,        // 2
      `  course: "DM872",`,               // 3
      `)`,                                // 4
      ``,                                 // 5
      `= Gradient Descent`,               // 6
      ``,                                 // 7
      `The gradient descent update for`,  // 8
      `parameters $theta$ with loss $loss$:`, // 9
      ``,                                 // 10
      `$ theta_(t+1) = theta_t`,          // 11
      `  - eta nabla_theta loss(theta_t) $`, // 12
      ``,                                 // 13
      `where $eta > 0$ is the learning rate.`, // 14
      ``,                                 // 15
      `== Mini-batch SGD`,                // 16
      ``,                                 // 17
      `Approximate $nabla_theta loss$ over`, // 18
      `a batch $cal(B) subset cal(D)$:`,  // 19
      ``,                                 // 20
      `$ nabla_theta loss`,               // 21
      `  approx 1 / abs(cal(B))`,           // 22
      `  sum_(i in cal(B)) nabla_theta loss_i $`, // 23
    ],
    chunks: [
      { atLine: 6,  html: `<h1>Gradient Descent</h1>` },
      { atLine: 9,  html: `<p>The gradient descent update for parameters θ with loss ℒ:</p>` },
      { atLine: 12, html: `<div class="math">θ<sub>t+1</sub> = θ<sub>t</sub> − η ∇<sub>θ</sub> ℒ(θ<sub>t</sub>)</div>` },
      { atLine: 14, html: `<p>where η &gt; 0 is the learning rate.</p>` },
      { atLine: 16, html: `<h2>Mini-batch SGD</h2>` },
      { atLine: 19, html: `<p>Approximate ∇<sub>θ</sub> ℒ over a batch ℬ ⊆ 𝒟:</p>` },
      { atLine: 23, html: `<div class="math">∇<sub>θ</sub> ℒ ≈ (1/|ℬ|) Σ<sub>i∈ℬ</sub> ∇<sub>θ</sub> ℓ<sub>i</sub></div>` },
    ],
  },
  {
    src: [
      `#import "../../temp.typ": *`,      // 0
      `#show: note.with(`,                // 1
      `  title:  "Calculus",`,            // 2
      `  course: "MM536",`,               // 3
      `)`,                                // 4
      ``,                                 // 5
      `= Fundamental Theorem`,            // 6
      ``,                                 // 7
      `If $f$ is continuous on $[a,b]$ and`, // 8
      `$F' = f$, then:`,                  // 9
      ``,                                 // 10
      `$ integral_a^b  f(x) dx = F(b) - F(a) $`, // 11
      ``,                                 // 12
      `= Chain Rule`,                     // 13
      ``,                                 // 14
      `For $h(x) = f(g(x))$:`,            // 15
      ``,                                 // 16
      `$ dv(h, x) = dv(f, g) dot dv(g, x) $`, // 17
      ``,                                 // 18
      `In backprop: $ppv(loss, W)`,       // 19
      `= ppv(loss, z) dot ppv(z, W)$`,   // 20
      `applied layer by layer.`,          // 21
    ],
    chunks: [
      { atLine: 6,  html: `<h1>Fundamental Theorem</h1>` },
      { atLine: 9,  html: `<p>If <em>f</em> is continuous on [<em>a</em>, <em>b</em>] and <em>F</em>′ = <em>f</em>, then:</p>` },
      { atLine: 11, html: `<div class="math">∫<sub><em>a</em></sub><sup><em>b</em></sup> <em>f</em>(<em>x</em>) d<em>x</em> = <em>F</em>(<em>b</em>) − <em>F</em>(<em>a</em>)</div>` },
      { atLine: 13, html: `<h1>Chain Rule</h1>` },
      { atLine: 15, html: `<p>For <em>h</em>(<em>x</em>) = <em>f</em>(<em>g</em>(<em>x</em>)):</p>` },
      { atLine: 17, html: `<div class="math">d<em>h</em>/d<em>x</em> = (d<em>f</em>/d<em>g</em>) · (d<em>g</em>/d<em>x</em>)</div>` },
      { atLine: 21, html: `<p>In neural nets: ∂ℒ/∂<em>W</em> = (∂ℒ/∂<em>z</em>)(∂<em>z</em>/∂<em>W</em>) applied layer by layer.</p>` },
    ],
  },
];

let demoIdx = 0;
let charPos = 0;
let phase = 'typing';   // 'typing' | 'hold' | 'clearing'
let holdTick = 0;
let clearTick = 0;
let lastRenderedLine = -1;

const CHAR_MS   = 48;   // ms per character
const HOLD_MS   = 2800;
const CLEAR_MS  = 350;

function currentSrc() {
  const full = DEMOS[demoIdx].src.join('\n');
  return full.slice(0, charPos);
}

// how many complete lines have been typed so far
function completedLines() {
  const full    = DEMOS[demoIdx].src.join('\n');
  const partial = full.slice(0, charPos);
  // a line is complete once the newline after it has been typed
  return partial.split('\n').length - 1;
}

function highlight(text) {
  const esc = (s) =>
    s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

  return text.split('\n').map(line => {
    // heading lines: one or more = at start
    if (/^=+\s/.test(line))
      return `<span style="color:#dcdcaa;font-weight:600">${esc(line)}</span>`;

    let out = '';
    let i   = 0;
    while (i < line.length) {
      const ch = line[i];

      // line comment //
      if (ch === '/' && line[i+1] === '/') {
        out += `<span style="color:#555">${esc(line.slice(i))}</span>`;
        i = line.length;

      // #function or #keyword
      } else if (ch === '#' && i + 1 < line.length && /\w/.test(line[i+1])) {
        let j = i + 1;
        while (j < line.length && /\w/.test(line[j])) j++;
        out += `<span style="color:#4db6c4">${esc(line.slice(i, j))}</span>`;
        i = j;

      // "string"
      } else if (ch === '"') {
        let j = i + 1;
        while (j < line.length && line[j] !== '"') j++;
        if (j < line.length) j++;
        out += `<span style="color:#ce9178">${esc(line.slice(i, j))}</span>`;
        i = j;

      // $math$
      } else if (ch === '$') {
        let j = i + 1;
        while (j < line.length && line[j] !== '$') j++;
        if (j < line.length) j++;
        out += `<span style="color:#b5cea8">${esc(line.slice(i, j))}</span>`;
        i = j;

      } else {
        out += esc(ch);
        i++;
      }
    }
    return out;
  }).join('\n');
}

function render() {
  const text  = currentSrc();
  const lines = text.split('\n');

  // source pane
  srcEl.innerHTML = highlight(text) + '<span class="cursor">▮</span>';

  // line numbers (always show all lines of the demo, grey out future ones)
  const total = DEMOS[demoIdx].src.length;
  lineEl.innerHTML = Array.from({ length: total }, (_, i) =>
    `<span style="opacity:${i < lines.length ? 1 : 0.2}">${i + 1}</span>`
  ).join('');

  // paper — append chunks as their trigger line completes
  const done = completedLines();
  if (done !== lastRenderedLine) {
    lastRenderedLine = done;
    const visible = DEMOS[demoIdx].chunks
      .filter(c => c.atLine <= done)
      .map(c => c.html)
      .join('');
    paperEl.innerHTML = visible;
  }
}

function step() {
  const fullLen = DEMOS[demoIdx].src.join('\n').length;

  if (phase === 'typing') {
    if (charPos < fullLen) {
      charPos += 1;
    } else {
      phase = 'hold';
      holdTick = 0;
    }
    render();
    setTimeout(step, CHAR_MS);

  } else if (phase === 'hold') {
    holdTick += 16;
    if (holdTick < HOLD_MS) {
      setTimeout(step, 16);
    } else {
      phase = 'clearing';
      clearTick = 0;
      setTimeout(step, 16);
    }

  } else {
    clearTick += 16;
    const t = Math.min(clearTick / CLEAR_MS, 1);
    paperEl.style.opacity = String(1 - t);
    srcEl.style.opacity   = String(1 - t);
    lineEl.style.opacity  = String(1 - t);
    if (t < 1) {
      setTimeout(step, 16);
    } else {
      demoIdx           = (demoIdx + 1) % DEMOS.length;
      charPos           = 0;
      lastRenderedLine  = -1;
      phase             = 'typing';
      paperEl.innerHTML = '';
      paperEl.style.opacity = '1';
      srcEl.style.opacity   = '1';
      lineEl.style.opacity  = '1';
      srcEl.innerHTML   = '<span class="cursor">▮</span>';
      lineEl.innerHTML  = '<span>1</span>';
      setTimeout(step, 300);
    }
  }
}

step();
</script>

<style>
h1 { font-size: 1.6rem; font-weight: 600; margin-bottom: 0.35rem; }

.sub {
  font-size: 0.85rem;
  color: var(--text-dim);
  margin-bottom: 1.5rem;
}

/* ── Typst demo ─────────────────────── */
.typst-demo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border: 1px solid #2a2a2a;
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: 2.25rem;
  font-size: 0;   /* kill inline-block gaps */
}

.pane-bar {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 7px 10px;
  background: #1a1a1a;
  border-bottom: 1px solid #262626;
}

.dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}
.dot.red    { background: #ff5f57; }
.dot.yellow { background: #febc2e; }
.dot.green  { background: #28c840; }

.pane-title {
  font-family: var(--font-mono);
  font-size: 10px;
  color: #555;
  margin-left: 6px;
}

/* source side */
.demo-src {
  border-right: 1px solid #222;
  background: #111;
}

.editor {
  display: flex;
  height: 310px;
  overflow: hidden;
}

.line-nums {
  display: flex;
  flex-direction: column;
  padding: 10px 8px 10px 0;
  min-width: 28px;
  text-align: right;
  font-family: var(--font-mono);
  font-size: 10px;
  line-height: 1.6;
  color: #3a3a3a;
  background: #111;
  border-right: 1px solid #1e1e1e;
  user-select: none;
  flex-shrink: 0;
}

#typst-src {
  margin: 0;
  padding: 10px 10px 10px 10px;
  font-family: var(--font-mono);
  font-size: 10.5px;
  line-height: 1.6;
  color: #ccc;
  white-space: pre-wrap;
  word-break: break-all;
  background: #111;
  flex: 1;
  border: none;
  outline: none;
}

.cursor {
  color: #4db6c4;
  animation: blink 1s step-end infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* output side */
.demo-out {
  background: #e8e5dc;
  display: flex;
  flex-direction: column;
}

.demo-out .pane-bar {
  background: #d8d5cc;
  border-bottom: 1px solid #c8c5bc;
}

.demo-out .pane-title { color: #999; }

.paper-wrap {
  height: 310px;
  padding: 16px 18px;
  overflow: hidden;
  box-sizing: border-box;
}

.paper {
  font-family: 'Georgia', 'Times New Roman', serif;
  font-size: 11px;
  color: #111;
  line-height: 1.65;
  transition: opacity 0.25s;
}

.paper :global(h1) {
  font-size: 14px;
  font-weight: bold;
  margin: 0 0 10px;
  padding-bottom: 4px;
  border-bottom: 0.5px solid #bbb;
  color: #111;
}

.paper :global(h2) {
  font-size: 11px;
  font-weight: bold;
  margin: 10px 0 4px;
  color: #111;
}

.paper :global(p) {
  margin: 0 0 7px;
  color: #222;
  font-size: 10.5px;
}

.paper :global(.math) {
  font-style: italic;
  text-align: center;
  margin: 8px 0;
  font-size: 11px;
  color: #111;
}

.paper :global(.def-box) {
  border: 0.5px solid #aaa;
  padding: 6px 10px;
  margin: 8px 0;
  font-size: 10.5px;
  color: #222;
  background: #f2efe6;
}

.paper :global(ul) {
  margin: 4px 0 7px 14px;
  padding: 0;
  font-size: 10.5px;
  color: #222;
}

.paper :global(ul li) { margin-bottom: 2px; }

.paper :global(.mat) {
  font-family: 'Georgia', serif;
  font-size: 10px;
  line-height: 1.3;
  display: inline-block;
  vertical-align: middle;
  white-space: pre;
  letter-spacing: 0.04em;
}

/* ── rest of page ───────────────────── */
.typst-blurb {
  margin-bottom: 1.25rem;
}

.typst-blurb p {
  font-size: 0.85rem;
  color: var(--text-muted);
  line-height: 1.7;
  margin: 0;
}

.typst-blurb code {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--accent);
  background: rgba(77,182,196,0.08);
  padding: 1px 4px;
  border-radius: 3px;
}

.note-list {
  display: flex;
  flex-direction: column;
  border-top: 1px solid var(--border);
}

.note-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding: 0.8rem 0;
  border-bottom: 1px solid var(--border);
  opacity: 1 !important;
}

.note-row:hover .note-title { color: var(--accent); }

.note-title { font-size: 0.875rem; color: var(--text); }

.note-meta {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  white-space: nowrap;
}

.empty {
  font-size: 0.85rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
}
</style>
