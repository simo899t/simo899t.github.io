---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNotes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const studying = [
  'Knowledge Representation & Reasoning — A(RC), FOL, propositional logic',
  'Optimisation — KKT conditions, Lagrangian duality, convex analysis',
  'AI safety & interpretability',
];
---

<Layout title="Notes" description="Study notes by Simon Holm.">
  <div class="container page">
    <h1>Notes</h1>
    <p class="sub">
      Short write-ups on things I'm figuring out.
      Written in <a href="https://typst.app" target="_blank">Typst</a> —
      try the syntax with <a href="https://simo899t.github.io/typstnique" target="_blank">Typstnique</a>.
    </p>

    <div class="typst-demo">
      <div class="demo-pane demo-src">
        <div class="pane-label">source.typ</div>
        <pre id="typst-src"><span class="cursor">▮</span></pre>
      </div>
      <div class="demo-pane demo-out">
        <div class="pane-label">output</div>
        <canvas id="typst-canvas"></canvas>
      </div>
    </div>

    <div class="studying">
      <span class="label">currently studying</span>
      <ul>
        {studying.map(s => <li><span class="bullet">▸</span>{s}</li>)}
      </ul>
    </div>

    {allNotes.length > 0 ? (
      <div class="note-list">
        {allNotes.map(n => (
          <a href={`/notes/${n.slug}`} class="note-row">
            <span class="note-title">{n.data.title}</span>
            <span class="note-meta">
              {n.data.tags.join(' · ')} &nbsp;·&nbsp;
              {n.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">more coming soon</p>
    )}
  </div>
</Layout>

<script>
// ── Typst live demo ──────────────────────────────────────────────────────────
const srcEl    = document.getElementById('typst-src')!;
const outCanvas = document.getElementById('typst-canvas') as HTMLCanvasElement;
const ctx2     = outCanvas.getContext('2d')!;
const dpr2     = window.devicePixelRatio || 1;

// Snippets to cycle through: [source lines, rendered lines]
const DEMOS: Array<{ src: string[]; out: Array<{text:string; style:string; x?:number}> }> = [
  {
    src: [
      '= KKT Conditions',
      '',
      'For a minimisation problem,',
      'the stationarity condition:',
      '',
      '$nabla f(x^*) + sum_i mu_i$',
      '$quad nabla g_i(x^*) = 0$',
    ],
    out: [
      { text: 'KKT Conditions',        style: 'heading' },
      { text: '',                       style: 'gap' },
      { text: 'For a minimisation problem,', style: 'body' },
      { text: 'the stationarity condition:', style: 'body' },
      { text: '',                       style: 'gap' },
      { text: '∇f(x*) + Σᵢ μᵢ ∇gᵢ(x*) = 0', style: 'math' },
    ],
  },
  {
    src: [
      '#import "template.typ": *',
      '#show: note.with(',
      '  title: "Gradient Descent",',
      '  date: datetime.today(),',
      ')',
      '',
      '== Update rule',
      '$theta <- theta - alpha nabla L$',
    ],
    out: [
      { text: 'Gradient Descent',  style: 'heading' },
      { text: '',                  style: 'gap' },
      { text: 'Update rule',       style: 'subheading' },
      { text: '',                  style: 'gap' },
      { text: 'θ ← θ − α ∇L(θ)',  style: 'math' },
    ],
  },
  {
    src: [
      '== Attention mechanism',
      '',
      'Given queries $Q$, keys $K$,',
      'values $V$:',
      '',
      '$"Attention"(Q,K,V) =$',
      '$"softmax"(Q K^T / sqrt(d_k)) V$',
    ],
    out: [
      { text: 'Attention mechanism', style: 'subheading' },
      { text: '',                    style: 'gap' },
      { text: 'Given Q, K, V:',      style: 'body' },
      { text: '',                    style: 'gap' },
      { text: 'Attention(Q,K,V) =',  style: 'math' },
      { text: 'softmax(QKᵀ/√dₖ)·V', style: 'math' },
    ],
  },
];

let demoIdx   = 0;
let charIdx   = 0;
let lineIdx   = 0;
let phase: 'typing' | 'pause' | 'erasing' = 'typing';
let tick2     = 0;
const CHAR_DELAY = 2;  // ticks per character
const PAUSE_TICKS = 80;

function fullSrc(d: typeof DEMOS[0], lines: number, chars: number) {
  const parts: string[] = [];
  for (let i = 0; i < lines; i++) {
    parts.push(d.src[i]);
  }
  if (chars < d.src[lines]?.length ?? 0) {
    parts.push(d.src[lines].slice(0, chars));
  }
  return parts.join('\n');
}

function coloriseLine(line: string): string {
  return line
    .replace(/^(=+\s)/g, '<span class="kw">$1</span>')
    .replace(/(#\w+)/g, '<span class="fn">$1</span>')
    .replace(/(".*?")/g, '<span class="str">$1</span>')
    .replace(/(\$[^$]+\$)/g, '<span class="math2">$1</span>');
}

function renderSrc(text: string) {
  const lines = text.split('\n');
  srcEl.innerHTML = lines.map(l => coloriseLine(l)).join('\n') + '<span class="cursor">▮</span>';
}

function setupOutCanvas() {
  const w = outCanvas.parentElement!.clientWidth;
  const h = 180;
  outCanvas.width  = w * dpr2;
  outCanvas.height = h * dpr2;
  outCanvas.style.width  = w + 'px';
  outCanvas.style.height = h + 'px';
  ctx2.scale(dpr2, dpr2);
}

function renderOut(demo: typeof DEMOS[0], progress: number) {
  const w = outCanvas.clientWidth;
  const h = outCanvas.clientHeight;
  ctx2.fillStyle = '#0f1a1c';
  ctx2.fillRect(0, 0, w, h);

  // page-like inner rect
  ctx2.fillStyle = '#f8f6f0';
  ctx2.fillRect(12, 10, w - 24, h - 20);

  let y = 28;
  const totalChars = demo.src.slice(0, Math.ceil(progress * demo.src.length)).join('').length;
  const outLines   = Math.ceil((progress * demo.out.length));

  for (let i = 0; i < Math.min(outLines, demo.out.length); i++) {
    const row = demo.out[i];
    if (row.style === 'gap') { y += 6; continue; }
    ctx2.textBaseline = 'top';
    if (row.style === 'heading') {
      ctx2.font = 'bold 13px Georgia, serif';
      ctx2.fillStyle = '#111';
      ctx2.fillText(row.text, 20, y);
      y += 18;
      ctx2.fillStyle = '#bbb';
      ctx2.fillRect(20, y, w - 44, 0.5);
      y += 6;
    } else if (row.style === 'subheading') {
      ctx2.font = 'bold 10px Georgia, serif';
      ctx2.fillStyle = '#222';
      ctx2.fillText(row.text, 20, y);
      y += 15;
    } else if (row.style === 'math') {
      ctx2.font = 'italic 10px Georgia, serif';
      ctx2.fillStyle = '#1a1a6e';
      ctx2.fillText(row.text, 20, y);
      y += 14;
    } else {
      ctx2.font = '9px system-ui, sans-serif';
      ctx2.fillStyle = '#333';
      ctx2.fillText(row.text, 20, y);
      y += 13;
    }
  }
}

function animLoop() {
  tick2++;
  const demo = DEMOS[demoIdx];
  const totalSrcLen = demo.src.join('').length;

  if (phase === 'typing') {
    if (tick2 % CHAR_DELAY === 0) {
      const curLineLen = demo.src[lineIdx]?.length ?? 0;
      if (charIdx < curLineLen) {
        charIdx++;
      } else if (lineIdx < demo.src.length - 1) {
        lineIdx++;
        charIdx = 0;
      } else {
        phase = 'pause';
        tick2 = 0;
      }
      renderSrc(fullSrc(demo, lineIdx, charIdx));
      const progress = (lineIdx * 10 + charIdx) / (demo.src.length * 10);
      renderOut(demo, Math.min(progress * 1.4, 1));
    }
  } else if (phase === 'pause') {
    if (tick2 > PAUSE_TICKS) { phase = 'erasing'; tick2 = 0; }
    renderOut(demo, 1);
  } else {
    // erasing — just clear and move to next
    if (tick2 > 20) {
      demoIdx  = (demoIdx + 1) % DEMOS.length;
      lineIdx  = 0;
      charIdx  = 0;
      phase    = 'typing';
      tick2    = 0;
      srcEl.textContent = '';
      ctx2.clearRect(0, 0, outCanvas.clientWidth, outCanvas.clientHeight);
    }
  }

  requestAnimationFrame(animLoop);
}

setupOutCanvas();
animLoop();
</script>

<style>
h1 {
  font-size: 1.6rem;
  font-weight: 600;
  margin-bottom: 0.35rem;
}

.sub {
  font-size: 0.85rem;
  color: var(--text-dim);
  margin-bottom: 1.5rem;
}

.typst-demo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 2rem;
}

.demo-pane {
  display: flex;
  flex-direction: column;
}

.pane-label {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-dim);
  padding: 0.4rem 0.75rem;
  background: #0f0f0f;
  border-bottom: 1px solid var(--border);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.demo-src {
  border-right: 1px solid var(--border);
}

.demo-src pre {
  margin: 0;
  padding: 0.75rem;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  line-height: 1.6;
  color: #aaa;
  min-height: 180px;
  white-space: pre-wrap;
  word-break: break-all;
  background: #0d0d0d;
}

.cursor {
  color: var(--accent);
  animation: blink 1s step-end infinite;
}

@keyframes blink { 50% { opacity: 0; } }

:global(.kw)    { color: #569cd6; }
:global(.fn)    { color: #4db6c4; }
:global(.str)   { color: #ce9178; }
:global(.math2) { color: #b5cea8; }

#typst-canvas {
  display: block;
  width: 100%;
}

.studying {
  margin-bottom: 2rem;
}

.label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  display: block;
  margin-bottom: 0.6rem;
}

.studying ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.studying li {
  font-size: 0.85rem;
  color: var(--text-muted);
  display: flex;
  gap: 0.5rem;
}

.bullet {
  color: var(--accent);
  flex-shrink: 0;
}

.note-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border-top: 1px solid var(--border);
}

.note-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding: 0.8rem 0;
  border-bottom: 1px solid var(--border);
  opacity: 1 !important;
}

.note-row:hover .note-title { color: var(--accent); }

.note-title {
  font-size: 0.875rem;
  color: var(--text);
}

.note-meta {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  white-space: nowrap;
}

.empty {
  font-size: 0.85rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
}
</style>
