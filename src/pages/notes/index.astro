---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNotes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const studying = [
  'Knowledge Representation & Reasoning — A(RC), FOL, propositional logic',
  'Optimisation — KKT conditions, Lagrangian duality, convex analysis',
  'AI safety & interpretability',
];
---

<Layout title="Notes" description="Study notes by Simon Holm.">
  <div class="container page">
    <h1>Notes</h1>
    <p class="sub">
      Short write-ups on things I'm figuring out.
      Written in <a href="https://typst.app" target="_blank">Typst</a> —
      try the syntax with <a href="https://simo899t.github.io/typstnique" target="_blank">Typstnique</a>.
    </p>

    <canvas id="tree-canvas"></canvas>

    <div class="studying">
      <span class="label">currently studying</span>
      <ul>
        {studying.map(s => <li><span class="bullet">▸</span>{s}</li>)}
      </ul>
    </div>

    {allNotes.length > 0 ? (
      <div class="note-list">
        {allNotes.map(n => (
          <a href={`/notes/${n.slug}`} class="note-row">
            <span class="note-title">{n.data.title}</span>
            <span class="note-meta">
              {n.data.tags.join(' · ')} &nbsp;·&nbsp;
              {n.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">more coming soon</p>
    )}
  </div>
</Layout>

<script>
const canvas = document.getElementById('tree-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const BG    = '#141414';
const LINE  = '#2a2a2a';
const NODE_EMPTY = '#1e1e1e';
const NODE_FILL  = '#1a2a2d';
const NODE_CUR   = '#4db6c4';
const TEXT_COL   = '#555';

interface TreeNode {
  val: number;
  x: number; y: number;
  left: TreeNode | null;
  right: TreeNode | null;
}

const H = 120;
let W: number;
let root: TreeNode | null = null;
let insertQueue: number[] = [];
let animating: TreeNode | null = null;
let animPath: TreeNode[] = [];
let animStep = 0;
let frame = 0;

function setup() {
  W = canvas.parentElement!.clientWidth;
  canvas.width  = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  reset();
}

function reset() {
  root = null;
  insertQueue = shuffle([...Array(15)].map((_, i) => i + 1));
  animating = null;
  animPath = [];
  animStep = 0;
  frame = 0;
}

function shuffle<T>(a: T[]) {
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function layout(node: TreeNode | null, x: number, y: number, spread: number) {
  if (!node) return;
  node.x = x; node.y = y;
  layout(node.left,  x - spread, y + 28, spread / 2);
  layout(node.right, x + spread, y + 28, spread / 2);
}

function insert(node: TreeNode | null, val: number, path: TreeNode[]): TreeNode {
  if (!node) {
    const n: TreeNode = { val, x: 0, y: 0, left: null, right: null };
    path.push(n);
    return n;
  }
  path.push(node);
  if (val < node.val) node.left  = insert(node.left,  val, path);
  else                node.right = insert(node.right, val, path);
  return node;
}

function drawTree(node: TreeNode | null) {
  if (!node) return;
  ctx.strokeStyle = LINE;
  ctx.lineWidth = 1;
  if (node.left)  { ctx.beginPath(); ctx.moveTo(node.x, node.y); ctx.lineTo(node.left.x,  node.left.y);  ctx.stroke(); }
  if (node.right) { ctx.beginPath(); ctx.moveTo(node.x, node.y); ctx.lineTo(node.right.x, node.right.y); ctx.stroke(); }
  drawTree(node.left);
  drawTree(node.right);

  const isAnim = animPath.slice(0, animStep).includes(node);
  const isCur  = animPath[animStep - 1] === node;
  ctx.beginPath();
  ctx.arc(node.x, node.y, 9, 0, Math.PI * 2);
  ctx.fillStyle = isCur ? NODE_CUR : isAnim ? NODE_FILL : NODE_EMPTY;
  ctx.fill();
  ctx.strokeStyle = isCur ? NODE_CUR : '#2a2a2a';
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.fillStyle = isCur ? '#141414' : TEXT_COL;
  ctx.font = `${7 * dpr / dpr}px Consolas, monospace`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(String(node.val), node.x, node.y + 0.5);
}

function tick() {
  frame++;

  // Every 18 frames: advance animation step or start a new insertion
  if (frame % 18 === 0) {
    if (animating && animStep < animPath.length) {
      animStep++;
    } else if (insertQueue.length > 0) {
      const val = insertQueue.shift()!;
      const path: TreeNode[] = [];
      root = insert(root, val, path);
      layout(root, W / 2, 18, W / 5);
      animPath = path;
      animStep = 1;
      animating = path[path.length - 1];
    } else {
      // all inserted — pause then reset
      setTimeout(reset, 1500);
    }
  }

  ctx.fillStyle = BG;
  ctx.fillRect(0, 0, W, H);
  if (root) drawTree(root);
  requestAnimationFrame(tick);
}

setup();
tick();
window.addEventListener('resize', setup);
</script>

<style>
h1 {
  font-size: 1.6rem;
  font-weight: 600;
  margin-bottom: 0.35rem;
}

.sub {
  font-size: 0.85rem;
  color: var(--text-dim);
  margin-bottom: 1.5rem;
}

#tree-canvas {
  display: block;
  border-radius: 3px;
  margin-bottom: 1.5rem;
}

.studying {
  margin-bottom: 2rem;
}

.label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  display: block;
  margin-bottom: 0.6rem;
}

.studying ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.studying li {
  font-size: 0.85rem;
  color: var(--text-muted);
  display: flex;
  gap: 0.5rem;
}

.bullet {
  color: var(--accent);
  flex-shrink: 0;
}

.note-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border-top: 1px solid var(--border);
}

.note-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding: 0.8rem 0;
  border-bottom: 1px solid var(--border);
  opacity: 1 !important;
}

.note-row:hover .note-title { color: var(--accent); }

.note-title {
  font-size: 0.875rem;
  color: var(--text);
}

.note-meta {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  white-space: nowrap;
}

.empty {
  font-size: 0.85rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
}
</style>
