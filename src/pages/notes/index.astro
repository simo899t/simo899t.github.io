---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync } from 'fs';
import { resolve } from 'path';

// Drop PDFs into public/notes-pdf/ — they appear here automatically.
// Name files like: "DM561 Linear Algebra.pdf" or "AI505-Gradient-Descent.pdf"
const pdfDir = resolve('public/notes-pdf');
const pdfs = readdirSync(pdfDir)
  .filter(f => f.endsWith('.pdf'))
  .sort()
  .map(f => ({
    filename: f,
    title: f.replace(/\.pdf$/i, '').replace(/[-_]/g, ' '),
    url: `/notes-pdf/${f}`,
  }));

function highlightTypst(raw: string): string {
  const e = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const lines = raw.split('\n');
  return lines.map(line => {
    // headings
    if (/^=+\s/.test(line)) {
      return `<span class="ch-heading">${e(line)}</span>`;
    }
    // comments
    if (line.trimStart().startsWith('//')) {
      return `<span class="ch-comment">${e(line)}</span>`;
    }
    let out = '';
    let i = 0;
    while (i < line.length) {
      // inline math $...$
      if (line[i] === '$') {
        const end = line.indexOf('$', i + 1);
        if (end !== -1) {
          out += `<span class="ch-math">${e(line.slice(i, end + 1))}</span>`;
          i = end + 1;
          continue;
        }
      }
      // #keyword
      if (line[i] === '#') {
        const m = line.slice(i).match(/^#[a-zA-Z_][a-zA-Z0-9_-]*/);
        if (m) {
          out += `<span class="ch-kw">${e(m[0])}</span>`;
          i += m[0].length;
          continue;
        }
      }
      // *bold*
      if (line[i] === '*') {
        const end = line.indexOf('*', i + 1);
        if (end !== -1) {
          out += `<span class="ch-bold">${e(line.slice(i, end + 1))}</span>`;
          i = end + 1;
          continue;
        }
      }
      // strings
      if (line[i] === '"') {
        const end = line.indexOf('"', i + 1);
        if (end !== -1) {
          out += `<span class="ch-str">${e(line.slice(i, end + 1))}</span>`;
          i = end + 1;
          continue;
        }
      }
      out += e(line[i]);
      i++;
    }
    return out;
  }).join('\n');
}

// Code examples — drop .typ + matching .png into public/code-examples/src/ and they appear automatically.
const ceDir = resolve('public/code-examples/src');
const codeExamples = readdirSync(ceDir)
  .filter(f => f.endsWith('.typ'))
  .sort()
  .map(f => {
    const slug = f.replace(/\.typ$/, '');
    const imgFile = slug + '.png';
    const hasImg = readdirSync(ceDir).includes(imgFile);
    const raw = readFileSync(resolve(ceDir, f), 'utf8')
      .split('\n')
      .filter(line => !/^\s*#import\s+"@local\/sdust/.test(line))
      .join('\n')
      .replace(/^\n+/, '')
      .trimEnd();
    return {
      slug,
      label: slug.replace(/[-_]/g, ' '),
      code: raw,
      highlighted: highlightTypst(raw),
      img: hasImg ? `/code-examples/src/${imgFile}` : null,
    };
  });

// Resolve VSCode snippet placeholders (${1:foo}, $0, \$) into plain display text,
// the same way the editor shows them right after expansion.
function resolveSnippetBody(body: string): string {
  return body
    .replace(/\$\{\d+:([^}]*)\}/g, '$1')
    .replace(/\$\{\d+\}/g, '')
    .replace(/\$0/g, '')
    .replace(/\\\$/g, '$');
}

// VSCode snippets — copy your typst.json into public/snippets/typst.json to show them here.
// Only these snippets get an animated card; edit this list to change the selection.
const SNIPPET_WHITELIST = ['Definition', 'Tree (tidy-tree)', 'SDU template import', 'Induction proof', 'Pseudocode algorithm', 'SDU note'];

const snippetsPath = resolve('public/snippets/typst.json');
let snippets: { name: string; prefix: string; body: string; expanded: string; description: string; json: string; height: number }[] = [];
try {
  const raw = JSON.parse(readFileSync(snippetsPath, 'utf8'));
  snippets = Object.entries(raw)
    .filter(([name]) => SNIPPET_WHITELIST.includes(name))
    .sort((a, b) => SNIPPET_WHITELIST.indexOf(a[0]) - SNIPPET_WHITELIST.indexOf(b[0]))
    .map(([name, def]: [string, any]) => {
      const body = Array.isArray(def.body) ? def.body.join('\n') : def.body;
      const lineCount = body.split('\n').length;
      return {
        name,
        prefix: def.prefix,
        body,
        expanded: resolveSnippetBody(body),
        description: def.description || '',
        json: JSON.stringify({ [name]: def }, null, 2).replace(/^\{\n/, '').replace(/\n\}$/, ''),
        height: Math.max(lineCount * 22 + 24, 170),
      };
    });
} catch (e) { snippets = []; }

// Snippet bodies used to drive the "typed as a real snippet, then fields
// filled in" animation in the Live Demo tab. Keyed by prefix so the client
// script can look up the placeholder template for whatever trigger it hits
// (e.g. "#definition(" → the "def" snippet body) and animate real content
// into its fields instead of just pasting the whole block in one jump.
const DEMO_SNIPPET_PREFIXES = ['def', 'theorem', 'example', 'proof', 'induct', 'sum', 'integral', 'product', 'code', 'frac'];
let demoSnippetDefs: Record<string, { prefix: string; body: string; description: string }> = {};
try {
  const raw = JSON.parse(readFileSync(snippetsPath, 'utf8'));
  for (const def of Object.values(raw) as any[]) {
    if (DEMO_SNIPPET_PREFIXES.includes(def.prefix)) {
      const body = Array.isArray(def.body) ? def.body.join('\n') : def.body;
      demoSnippetDefs[def.prefix] = { prefix: def.prefix, body, description: def.description || '' };
    }
  }
} catch (e) { demoSnippetDefs = {}; }

const demoSnippetDefsJson = JSON.stringify(demoSnippetDefs);

// Read the .typ source files — edit those files to change the animation.
// Lines before "// ── CONTENT" that start with # are hidden source preamble
// (compiled but not animated). Lines after the marker are animated.

function loadDemo(slug: string, title: string, course: string) {
  const raw = readFileSync(resolve('public/demo/src', slug + '.typ'), 'utf8');
  const allLines = raw.split('\n');
  const markerIdx = allLines.findIndex(l => l.startsWith('// ── CONTENT'));
  const beforeMarker = markerIdx >= 0 ? allLines.slice(0, markerIdx) : [];
  const afterMarker  = markerIdx >= 0 ? allLines.slice(markerIdx + 1) : allLines;

  // #-prefixed lines before the marker → hidden preamble sent to compiler only
  const hiddenDefs = beforeMarker.filter(l => l.trimStart().startsWith('#'));

  const content = [...afterMarker];
  while (content.length && content[content.length - 1].trim() === '') content.pop();

  const animPreamble = [
    '#import "@local/sdust:0.1.0": *',
    '#show: note.with(',
    `  title:  "${title}",`,
    `  course: "${course}",`,
    ')',
  ];
  return {
    slug,
    title,
    course,
    preamble: animPreamble.length,
    hiddenDefs,
    lines: [...animPreamble, '', ...content],
  };
}

const demos = [
  loadDemo('calculus',         'Taylor Series',             'MM531'),
  loadDemo('binary-search',    'Binary Search & Big-O',     'DM578'),
  loadDemo('induction',        'Proof by Induction',        'DM549'),
  loadDemo('linear-algebra',   'Gauss Elimination',         'DM561'),
  loadDemo('np-reduction',     '3-SAT to Independent Set',  'DM572'),
  loadDemo('newton-method',    "Newton's Method",           'MM538'),
];

const demosJson = JSON.stringify(demos);

const packages = [
  {
    name: 'sdust',
    repo: 'https://github.com/simo899t/sdust',
    tag: 'SDU themed package',
    desc: `A package for writing Typst documents faster: document templates (<code>note</code>, <code>exercise</code>, <code>assignment</code>, <code>project</code>, <code>exam</code>), theorem-style blocks like <code>#theorem</code> and <code>#definition</code>, and helpers for graphs, trees, and pseudocode.`,
    importCode: '#import "@local/sdust:0.1.0": *\n#show: note.with(\n  title:  "Lecture Notes",\n  course: "DM000 — Course Name",\n)',
  },
  {
    name: 'tempst',
    repo: 'https://github.com/simo899t/tempst',
    tag: 'personal shortcut package',
    desc: `Builds directly on <code>sdust</code> and adds the math shorthands I use day to day, like <code>apx</code> (≈), <code>loss</code> (ℒ), and <code>px(f,x)</code> (∂f/∂x). This is the package my own notes import.`,
    importCode: '#import "@local/tempst:0.1.0": *\n#show: note.with(\n  title:  "Lecture Notes",\n  course: "DM000 — Course Name",\n)',
  },
].map(p => ({ ...p, importHighlighted: highlightTypst(p.importCode) }));

const usefulPackages = [
  { name: 'codly',        repo: 'https://typst.app/universe/package/codly',        desc: 'Nicer code blocks — line numbers, highlighting, and language labels. Used live in the demo above.' },
  { name: 'lovelace',     repo: 'https://typst.app/universe/package/lovelace',     desc: 'Pseudocode blocks with proper line numbering and indentation. Also used live in the demo above.' },
  { name: 'cetz',         repo: 'https://typst.app/universe/package/cetz',         desc: 'A general-purpose drawing/plotting library for diagrams, plots, and geometry.' },
  { name: 'fletcher',     repo: 'https://typst.app/universe/package/fletcher',     desc: 'Node-and-arrow diagrams (graphs, flowcharts, commutative diagrams), built on cetz.' },
  { name: 'physica',      repo: 'https://typst.app/universe/package/physica',      desc: 'Shorthands for physics notation — vectors, derivatives, bra-ket, and more.' },
  { name: 'mitex',        repo: 'https://typst.app/universe/package/mitex',        desc: 'Renders raw LaTeX math syntax directly in Typst — handy for pasting in existing LaTeX.' },
];
---

<Layout title="Notes" description="Study notes by Simon Holm.">
  <div class="container page">
    <div class="typst-blurb">
      <h1>How I write my notes</h1>
      <p>
        All my lecture notes, exercises, and assignments are written in <a href="https://typst.app/open-source/" target="_blank">Typst</a> using a pair of packages I built myself to make documents easier to build — see the <strong>Packages</strong> tab below for details.
      </p>

      <h2 class="blurb-heading">What is Typst?</h2>
      <p>
        <a href="https://typst.app/open-source/" target="_blank">Typst</a> is a modern typesetting language and a significant improvement over LaTeX. Typst is used to produce high-quality PDFs and is particularly well suited for mathematics and the natural sciences.  Where other typesetting languages like LaTeX is decades old and notoriously difficult to debug, Typst offers a clean and readable syntax, near-instant compilation, and clear error messages. Typst is open source and built in Rust.
      </p>

      <p class="see-how-label">See how it works with real examples 😃:</p>
    </div>

    <div class="demo-tabs">
      <button class="demo-tab active" data-tab="live-demo">Live Demo</button>
      <button class="demo-tab" data-tab="code-examples">Code Examples</button>
      <button class="demo-tab" data-tab="assignment-examples">Assignment Examples</button>
      <button class="demo-tab" data-tab="snippets">Snippets</button>
      <button class="demo-tab" data-tab="my-packages">Packages</button>
    </div>

    <div class="tab-panels">

      <!-- Live Demo -->
      <div class="tab-panel active" id="panel-live-demo">
        <div class="demo-window">
          <div class="pane pane-src">
            <div class="titlebar">
              <span class="tb-dot red"></span>
              <span class="tb-dot yellow"></span>
              <span class="tb-dot green"></span>
              <span class="tb-name">notes.typ</span>
            </div>
            <div class="editor-body">
              <div class="editor-inner">
                <div id="line-nums" class="line-nums"></div>
                <pre id="code" class="code"></pre>
              </div>
              <div class="demo-snippet-dropdown" id="demo-dropdown"></div>
            </div>
          </div>
          <div class="pane pane-out">
            <div class="titlebar titlebar-light">
              <span class="tb-dot red"></span>
              <span class="tb-dot yellow"></span>
              <span class="tb-dot green"></span>
              <span class="tb-name tb-name-dark">notes.pdf</span>
            </div>
            <div class="output-body">
              <div id="render-out" class="render-out">
                <span class="render-status">loading typst…</span>
              </div>
            </div>
          </div>
        </div>
        <div class="demo-picker" id="demo-picker">
          {demos.map((d, i) => (
            <button class="demo-picker-dot" data-demo-index={i} title={d.title}>{i + 1}</button>
          ))}
        </div>
      </div>

      <!-- Code Examples -->
      <div class="tab-panel" id="panel-code-examples">
        <div class="code-examples-list">
          {codeExamples.map(ex => (
            <div class="code-example">
              <div class="ce-editor">
                <div class="ce-titlebar">
                  <span class="tb-dot red"></span>
                  <span class="tb-dot yellow"></span>
                  <span class="tb-dot green"></span>
                  <span class="ce-filename">{ex.slug}.typ</span>
                </div>
                <div class="ce-code-wrap">
                  <div class="line-nums ce-line-nums">
                    {ex.code.split('\n').map((_, li) => <span>{li + 1}</span>)}
                  </div>
                  <pre class="ce-code" set:html={ex.highlighted}></pre>
                </div>
              </div>
              <div class="ce-preview-pane">
                <div class="titlebar titlebar-light">
                  <span class="tb-dot red"></span>
                  <span class="tb-dot yellow"></span>
                  <span class="tb-dot green"></span>
                  <span class="ce-filename">{ex.slug}.pdf</span>
                </div>
                <div class="ce-preview">
                  {ex.img
                    ? <img src={ex.img} alt={ex.label} />
                    : <span class="render-status">no preview</span>
                  }
                </div>
              </div>
            </div>
          ))}
          </div>

        </div>
      </div>

      <!-- Assignment Examples -->
      <div class="tab-panel" id="panel-assignment-examples">
        <p class="snippets-intro">These are some fully compiled examples so you can see the capabilities of Typst.</p>
        {pdfs.length > 0 ? (
          <div class="note-list">
            {pdfs.map(p => (
              <a href={p.url} target="_blank" rel="noopener" class="note-row">
                <span class="note-title">{p.title}</span>
                <span class="note-meta pdf-tag">PDF</span>
              </a>
            ))}
          </div>
        ) : (
          <p class="empty">coming soon</p>
        )}
      </div>

      <!-- Snippets -->
      <div class="tab-panel" id="panel-snippets">
        <p class="snippets-intro">Snippets are small shortcuts in my editor. One can type a prefix like <code>def</code>, and pick the snippet from the autocomplete dropdown and it expands into a ready-made block as shown below. Download my full snippets file <a href="/snippets/typst.json" download>here</a>. I use VSCode, where it's accessed via:</p>
        <ul class="snippets-paths">
          <li><strong>macOS:</strong> <code>~/Library/Application Support/Code/User/snippets/typst.json</code></li>
          <li><strong>Windows:</strong> <code>%APPDATA%\Code\User\snippets\typst.json</code></li>
          <li><strong>Linux:</strong> <code>~/.config/Code/User/snippets/typst.json</code></li>
        </ul>
        {snippets.length > 0 ? (
          <div class="snippet-list">
            {snippets.map((s, i) => (
              <div class="snippet-row">
                <div class="snippet-pair">
                  <div class="snippet-editor">
                    <div class="ce-titlebar">
                      <span class="tb-dot red"></span>
                      <span class="tb-dot yellow"></span>
                      <span class="tb-dot green"></span>
                      <span class="ce-filename">notes.typ</span>
                    </div>
                    <div class="snippet-code-wrap" style={`height: ${s.height}px`}>
                      <div class="snippet-inner">
                        <div class="line-nums snippet-anim-linenums"></div>
                        <pre
                          class="snippet-anim"
                          data-prefix={s.prefix}
                          data-body={s.body}
                          data-expanded={s.expanded}
                          data-description={s.description}
                        ></pre>
                      </div>
                      <div class="snippet-dropdown"></div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="empty">coming soon</p>
        )}
      </div>

      <!-- My Packages -->
      <div class="tab-panel" id="panel-my-packages">
        <p class="snippets-intro">
          Everything on this page is built with two Typst packages I maintain myself, a
          custom SDU themed package, and a personal shortcut package. Either one is free to use, and shown below.
        </p>
        <div class="package-list">
          {packages.map(p => (
            <div class="package-card">
              <div class="package-head">
                <a href={p.repo} target="_blank" class="package-name">{p.name}</a>
                <span class="package-tag">{p.tag}</span>
              </div>
              <p class="package-desc" set:html={p.desc} />
              <div class="ce-editor package-import">
                <div class="ce-titlebar">
                  <span class="tb-dot red"></span>
                  <span class="tb-dot yellow"></span>
                  <span class="tb-dot green"></span>
                  <span class="ce-filename">notes.typ</span>
                </div>
                <div class="ce-code-wrap">
                  <div class="line-nums ce-line-nums">
                    {p.importCode.split('\n').map((_, li) => <span>{li + 1}</span>)}
                  </div>
                  <pre class="ce-code" set:html={p.importHighlighted}></pre>
                </div>
              </div>
            </div>
          ))}
        </div>
        <p class="snippets-intro">Both packages are actively maintained and may introduce breaking changes.</p>

        <h2 class="blurb-heading">Other useful packages</h2>
        <p class="snippets-intro">A few other Typst packages worth knowing about, from the wider ecosystem — browse more on <a href="https://typst.app/universe" target="_blank">Typst Universe</a>.</p>
        <div class="useful-package-list">
          {usefulPackages.map(p => (
            <a class="useful-package-card" href={p.repo} target="_blank">
              <span class="useful-package-name">{p.name}</span>
              <span class="useful-package-desc">{p.desc}</span>
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</Layout>

<script is:inline define:vars={{ demosJson, demoSnippetDefsJson }}>
(function () {

// ── tabs ──────────────────────────────────────────────────────────────────────
let snippetAnimsStarted = false;

document.querySelectorAll('.demo-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    const tab = btn.dataset.tab;
    document.querySelectorAll('.demo-tab').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel-' + tab).classList.add('active');
    if (tab === 'snippets' && !snippetAnimsStarted) {
      snippetAnimsStarted = true;
      initSnippetAnimations();
    }
  });
});

// ── snippet dropdown animations ────────────────────────────────────────────────
function escapeHtml(s) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function highlightTypstClient(raw) {
  const lines = raw.split('\n');
  return lines.map(line => {
    if (/^=+\s/.test(line)) {
      return '<span class="ch-heading">' + escapeHtml(line) + '</span>';
    }
    if (line.trimStart().startsWith('//')) {
      return '<span class="ch-comment">' + escapeHtml(line) + '</span>';
    }
    let out = '';
    let i = 0;
    while (i < line.length) {
      // \uE000/\uE001 sentinels mark a word "selected" (like
      // double-clicking it in a real editor) right before emphasis markers
      // wrap it — used by the */_ reveal steps below, never present in
      // real Typst source.
      if (line[i] === '\uE000') {
        const selEnd = line.indexOf('\uE001', i + 1);
        if (selEnd !== -1) {
          out += '<span class="word-sel">' + escapeHtml(line.slice(i + 1, selEnd)) + '</span>';
          i = selEnd + 1;
          continue;
        }
      }
      if (line[i] === '$') {
        const end = line.indexOf('$', i + 1);
        if (end !== -1) {
          out += '<span class="ch-math">' + escapeHtml(line.slice(i, end + 1)) + '</span>';
          i = end + 1;
          continue;
        }
      }
      if (line[i] === '#') {
        const m = line.slice(i).match(/^#[a-zA-Z_][a-zA-Z0-9_-]*/);
        if (m) {
          out += '<span class="ch-kw">' + escapeHtml(m[0]) + '</span>';
          i += m[0].length;
          continue;
        }
      }
      if (line[i] === '*') {
        const end = line.indexOf('*', i + 1);
        if (end !== -1) {
          out += '<span class="ch-bold">' + escapeHtml(line.slice(i, end + 1)) + '</span>';
          i = end + 1;
          continue;
        }
      }
      if (line[i] === '"') {
        const end = line.indexOf('"', i + 1);
        if (end !== -1) {
          out += '<span class="ch-str">' + escapeHtml(line.slice(i, end + 1)) + '</span>';
          i = end + 1;
          continue;
        }
      }
      out += escapeHtml(line[i]);
      i++;
    }
    return out;
  }).join('\n');
}

function parseSnippetFields(raw) {
  const segments = [];
  const re = /\$\{(\d+):([^}]*)\}|\$\{(\d+)\}|\$(\d+)|\\\$/g;
  let last = 0;
  let m;
  while ((m = re.exec(raw))) {
    if (m.index > last) segments.push({ type: 'text', value: raw.slice(last, m.index) });
    if (m[0] === '\\$') {
      segments.push({ type: 'text', value: '$' });
    } else if (m[1] !== undefined) {
      segments.push({ type: 'field', index: parseInt(m[1], 10), value: m[2] });
    } else {
      const idx = parseInt(m[3] !== undefined ? m[3] : m[4], 10);
      segments.push({ type: 'field', index: idx, value: '' });
    }
    last = re.lastIndex;
  }
  if (last < raw.length) segments.push({ type: 'text', value: raw.slice(last) });
  return segments;
}

function fieldOrder(segments) {
  const seen = new Set();
  segments.forEach(s => { if (s.type === 'field' && s.index !== 0) seen.add(s.index); });
  return Array.from(seen).sort((a, b) => a - b);
}

function renderSnippetStep(segments, activeIndex) {
  return segments.map(seg => {
    if (seg.type === 'text') return highlightTypstClient(seg.value);
    const cls = seg.index === activeIndex ? 'ts-field ts-active' : 'ts-field';
    return '<span class="' + cls + '">' + escapeHtml(seg.value) + '</span>';
  }).join('');
}

function initSnippetAnimations() {
  const cards = document.querySelectorAll('.snippet-anim');
  cards.forEach((animEl, idx) => {
    const prefix     = animEl.dataset.prefix || '';
    const body       = animEl.dataset.body || '';
    const description = animEl.dataset.description || '';
    const codeWrapEl = animEl.closest('.snippet-code-wrap');
    const ddEl = codeWrapEl.querySelector('.snippet-dropdown');
    const lineNumsEl = codeWrapEl.querySelector('.snippet-anim-linenums');

    const altSuffixes = ['ion', 'ive'];
    const alts = altSuffixes.map(suf => prefix + suf);

    ddEl.innerHTML = `
      <div class="dd-row active">
        <span class="dd-icon"></span>
        <span class="dd-prefix"><b>${prefix}</b></span>
        <span class="dd-desc">${description}</span>
      </div>
      ${alts.map(a => `
        <div class="dd-row">
          <span class="dd-icon abc">abc</span>
          <span class="dd-prefix"><b>${prefix}</b>${a.slice(prefix.length)}</span>
        </div>
      `).join('')}
    `;

    const segments = parseSnippetFields(body);
    const order = fieldOrder(segments);

    const TYPE_MS = 320;
    const DROPDOWN_HOLD_MS = 2600;
    const FLASH_MS = 260;
    const FIELD_HOLD_MS = 1400;
    const EXPANDED_HOLD_MS = 3200;
    const CLEAR_HOLD_MS = 900;

    let charPos = 0;
    let fieldStep = 0;
    let timer = null;

    function updateLineNums(text) {
      const lineCount = text.split('\n').length;
      lineNumsEl.innerHTML = Array.from({ length: lineCount }, (_, n) => `<span>${n + 1}</span>`).join('');
    }

    function setPlainText(text) {
      animEl.innerHTML = escapeHtml(text);
      const cursor = document.createElement('span');
      cursor.className = 'cursor';
      cursor.textContent = '\xa0';
      animEl.appendChild(cursor);
      updateLineNums(text);
    }

    function typeStep() {
      charPos++;
      setPlainText(prefix.slice(0, charPos));
      if (charPos < prefix.length) {
        timer = setTimeout(typeStep, TYPE_MS);
      } else {
        ddEl.classList.add('visible');
        timer = setTimeout(selectActive, DROPDOWN_HOLD_MS);
      }
    }

    function selectActive() {
      const activeRow = ddEl.querySelector('.dd-row.active');
      if (activeRow) activeRow.classList.add('flash');
      timer = setTimeout(showFieldStep, FLASH_MS);
    }

    function showFieldStep() {
      ddEl.classList.remove('visible');
      const activeIndex = order[fieldStep];
      animEl.innerHTML = renderSnippetStep(segments, activeIndex);
      const fullText = segments.map(s => s.value).join('');
      updateLineNums(fullText);
      fieldStep++;
      if (fieldStep < order.length) {
        timer = setTimeout(showFieldStep, FIELD_HOLD_MS);
      } else {
        timer = setTimeout(showFinal, FIELD_HOLD_MS);
      }
    }

    function showFinal() {
      let cursorInserted = false;
      const html = segments.map(seg => {
        if (seg.type === 'field' && seg.index === 0) {
          cursorInserted = true;
          return '<span class="cursor">\xa0</span>';
        }
        if (seg.type === 'text') return highlightTypstClient(seg.value);
        return escapeHtml(seg.value);
      }).join('') + (cursorInserted ? '' : '<span class="cursor">\xa0</span>');
      animEl.innerHTML = html;
      updateLineNums(segments.map(s => s.value).join(''));
      timer = setTimeout(clearAndRestart, EXPANDED_HOLD_MS);
    }

    function clearAndRestart() {
      animEl.textContent = '';
      charPos = 0;
      fieldStep = 0;
      timer = setTimeout(typeStep, CLEAR_HOLD_MS);
    }

    // stagger start so cards don't all animate in lockstep
    setTimeout(typeStep, idx * 220);
  });
}


// ── demos ─────────────────────────────────────────────────────────────────────
const DEMOS = JSON.parse(demosJson);

// ── state ─────────────────────────────────────────────────────────────────────
let di      = 0;
let charPos = 0;
let phase   = 'typing';  // 'typing' | 'hold' | 'clearing'
let holdMs  = 0;
let clearMs = 0;

const CHAR_MS = 140;
const HOLD_MS = 5000;
const FADE_MS = 600;

// ── DOM ───────────────────────────────────────────────────────────────────────
const codeEl      = document.getElementById('code');
const lineEl      = document.getElementById('line-nums');
const outEl       = document.getElementById('render-out');
const demoEl      = document.querySelector('.demo-window');
const editorBody  = document.querySelector('.editor-body');

var autoScroll           = true;
var autoScrollTimer      = null;
var programmaticScroll   = false;

if (editorBody) {
  editorBody.addEventListener('scroll', function() {
    if (programmaticScroll) return;
    autoScroll = false;
    clearTimeout(autoScrollTimer);
    autoScrollTimer = setTimeout(function() { autoScroll = true; }, 10000);
  }, { passive: true });
}

function scrollToBottom() {
  if (!autoScroll || !editorBody) return;
  // double rAF ensures DOM has reflowed before measuring scrollHeight
  requestAnimationFrame(function() {
    requestAnimationFrame(function() {
      programmaticScroll = true;
      editorBody.scrollTop = editorBody.scrollHeight;
      setTimeout(function() { programmaticScroll = false; }, 150);
    });
  });
}

// ── continuous compile ────────────────────────────────────────────────────────
// Always keep the latest content queued. As soon as a compile finishes, start
// the next one if content changed — so the preview updates as fast as possible.
let compileBusy   = false;
let pendingText   = null;

function triggerCompile(contentText) {
  pendingText = contentText;                                   // always track latest
  if (compileBusy) return;                                     // will drain on finish
  if (typeof window.__typstCompile !== 'function') return;
  drainCompile();
}

function closePartial(src) {
  var dollars = (src.match(/\$/g) || []).length;
  if (dollars % 2 !== 0) {
    // Inside an open math block — close unmatched parens/brackets first
    var opens  = (src.match(/\(/g) || []).length - (src.match(/\)/g) || []).length;
    var bracks = (src.match(/\[/g) || []).length - (src.match(/\]/g) || []).length;
    if (opens  > 0) src += ')'.repeat(opens);
    if (bracks > 0) src += ']'.repeat(bracks);
    return src + ' $';
  }
  // Outside math — strip completed math blocks, then check text-mode * and _
  var textOnly = src.replace(/\$[^$]*\$/g, '');
  var stars = (textOnly.match(/\*/g) || []).length;
  if (stars % 2 !== 0) src += '*';
  var underscores = (textOnly.match(/_/g) || []).length;
  if (underscores % 2 !== 0) src += '_';
  return src;
}

function drainCompile() {
  if (pendingText === null) return;
  compileBusy = true;
  var src = closePartial(pendingText);
  pendingText = null;
  window.__typstCompile(src, function(svgStr) {
    compileBusy = false;
    if (svgStr) {
      outEl.innerHTML     = svgStr;
      outEl.style.opacity = '1';
      fitOutputToBox();
    }
    drainCompile();   // compile again if more content arrived while busy
  });
}

// Fit the compiled SVG to the box's width, at a fixed zoom. The svg's
// width never changes as content is typed (it's the page width, fixed by
// buildPageSetup) — only its height grows — so this scale is already
// stable across an entire typing run. The window's own height is set
// separately, once, by presizeWindow() before typing starts; we must NOT
// touch it here on every frame, or the box visibly grows while typing.
function fitOutputToBox() {
  var svg = outEl.querySelector('svg');
  var box = outEl.parentElement; // .output-body
  if (!svg || !box) return;
  var bw = box.clientWidth - 32; // minus .output-body padding (16px each side)
  var vb = svg.viewBox && svg.viewBox.baseVal;
  var sw = (vb && vb.width)  || (svg.width  && svg.width.baseVal  && svg.width.baseVal.value)  || svg.getBoundingClientRect().width;
  var sh = (vb && vb.height) || (svg.height && svg.height.baseVal && svg.height.baseVal.value) || svg.getBoundingClientRect().height;
  if (!sw || !sh || !bw) return;
  var scale = (bw / sw) * ZOOM_FIXED;
  outEl.style.width     = sw + 'px';
  outEl.style.height    = sh + 'px';
  outEl.style.transform = 'scale(' + scale + ')';
}
var ZOOM_FIXED = 1.12;

// Compile a demo's FULL final content once (invisibly) to measure its
// rendered size, so the window can be set to its final height *before*
// the typing animation starts — instead of resizing on every keystroke.
// The demo window's size is fixed once via CSS (.demo-window's
// aspect-ratio) and never changed by JS again — no per-demo resizing, so
// switching demos never makes the box grow or shrink. This function is
// kept as a no-op call site so goToDemo()'s flow doesn't need to change.
function presizeWindow(demo, cb) {
  cb();
}

window.addEventListener('resize', fitOutputToBox);

// ── syntax highlight ──────────────────────────────────────────────────────────
function hl(text) {
  var esc = function(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  };
  return text.split('\n').map(function(line) {
    if (/^=+\s/.test(line))
      return '<span class="ch-heading">' + esc(line) + '</span>';
    var out = '', i = 0;
    while (i < line.length) {
      var ch = line[i];
      if (ch === '/' && line[i+1] === '/') {
        out += '<span class="ch-comment">' + esc(line.slice(i)) + '</span>';
        i = line.length;
      } else if (ch === '#' && i+1 < line.length && /\w/.test(line[i+1])) {
        var j = i+1; while (j < line.length && /\w/.test(line[j])) j++;
        out += '<span class="ch-kw">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else if (ch === '*') {
        var j = i+1; while (j < line.length && line[j] !== '*') j++; if (j < line.length) j++;
        out += '<span class="ch-bold">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else if (ch === '"') {
        var j = i+1; while (j < line.length && line[j] !== '"') j++; if (j < line.length) j++;
        out += '<span class="ch-str">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else if (ch === '$') {
        var j = i+1; while (j < line.length && line[j] !== '$') j++; if (j < line.length) j++;
        out += '<span class="ch-math">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else { out += esc(ch); i++; }
    }
    return out;
  }).join('\n');
}

// ── snippet-expand simulation ──────────────────────────────────────────────────
// When the typer reaches one of these constructs, it types the short snippet
// prefix (as if the real VSCode snippet were used), shows the autocomplete
// dropdown and selects it (like the Snippets tab), then reveals the snippet's
// placeholder fields and "tabs" through them, typing the real title/body/code
// that already exists in the source over each placeholder — instead of just
// pasting the whole finished block in one jump.
var DEMO_SNIPPETS = JSON.parse(demoSnippetDefsJson);

// Card blocks (#definition/#theorem/#example/#proof) use their real VSCode
// snippet bodies fetched from typst.json (see DEMO_SNIPPETS below). Code
// fences and #pseudo don't need that — any language fence or pseudo block
// gets a small synthetic single-field snippet built on the fly, so this
// works generically instead of being hardcoded to Python.
var SNIPPET_TRIGGERS = [
  { match: '#definition(', prefix: 'def' },
  { match: '#theorem(',    prefix: 'theorem' },
  { match: '#example(',    prefix: 'example' },
  { match: '#proof(',      prefix: 'proof' },
];

// #name(title: "TITLE")[\n  BODY\n]  →  { end, fields: [TITLE, BODY] }
function parseBracketBlock(full, pos) {
  var m = /^#\w+\(title:\s*"([^"]*)"\)\[\n([\s\S]*?)\n\]/.exec(full.slice(pos));
  if (!m) return null;
  return { end: pos + m[0].length, fields: [m[1], m[2]] };
}

// ```lang\nCODE\n```  →  { end, fields: [CODE] }
function parseFenceBlock(full, pos, matchStr) {
  var afterOpen = full.indexOf('\n', pos + matchStr.length);
  if (afterOpen === -1) return null;
  // The closing ``` may itself be indented (e.g. nested inside
  // #example[...]), so match optional leading whitespace, not just "\n```".
  var closeMatch = /\n[ \t]*```/.exec(full.slice(afterOpen));
  if (!closeMatch) return null;
  var closeIdx = afterOpen + closeMatch.index;
  return { end: closeIdx + closeMatch[0].length, fields: [full.slice(afterOpen + 1, closeIdx)] };
}

// #pseudo[\n  STEPS\n]  →  { end, fields: [STEPS] }
function parsePseudoBlock(full, pos) {
  var m = /^#pseudo\[\n([\s\S]*?)\n\]/.exec(full.slice(pos));
  if (!m) return null;
  return { end: pos + m[0].length, fields: [m[1]] };
}

// Build a regex straight from a real multi-field VSCode snippet body (e.g.
// the "Induction proof" snippet, which has 4 fields, not just title+body)
// so real content matching that exact scaffold can be matched and its
// field values extracted generically — no per-snippet parser needed.
// Newlines in the scaffold become "any newline + any indentation", since
// real content is usually indented differently than the raw snippet body.
function buildScaffoldRegex(body) {
  // VSCode snippet bodies escape literal "$" as "\$" (to avoid colliding
  // with tabstop syntax) — that backslash is stripped by the editor on
  // expansion and never appears in real typed content, so strip it here
  // too before building the match pattern (otherwise the regex demands a
  // literal backslash that will never actually be in the document).
  body = body.replace(/\\\$/g, '$');
  var fieldRe = /\$\{(\d+):[^}]*\}|\$\{(\d+)\}|\$(\d+)/g;
  var fieldNums = [];
  var patternSrc = '';
  var last = 0;
  var m;
  function escSeg(s) {
    return s.split(/\n[ \t]*/).map(function(part) {
      return part.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }).join('\\n[ \\t]*');
  }
  var lastFieldOpen = false;
  while ((m = fieldRe.exec(body))) {
    var literalBefore = body.slice(last, m.index);
    patternSrc += escSeg(literalBefore);
    if (literalBefore.length > 0) lastFieldOpen = false;
    var num = m[1] !== undefined ? m[1] : (m[2] !== undefined ? m[2] : m[3]);
    if (num !== '0') {
      fieldNums.push(parseInt(num, 10));
      patternSrc += '([\\s\\S]*?)';
      lastFieldOpen = true; // true unless more literal text follows it below
    }
    // $0 itself isn't a captured field and doesn't reset lastFieldOpen —
    // only literal text appearing after the last real field should.
    last = fieldRe.lastIndex;
  }
  var tail = body.slice(last);
  if (tail.length > 0) lastFieldOpen = false;
  patternSrc += escSeg(tail);
  // The snippet body's tail (e.g. "\n]\n$0") expects more document content
  // to follow — but the block may be the very last thing in the file, with
  // no trailing newline at all. Make that final connector optional so the
  // match doesn't fail purely for being at the end of the document.
  patternSrc = patternSrc.replace(/\\n\[ \\t\]\*$/, '(?:\\n[ \\t]*)?');
  // If the last field has NO literal text after it at all (e.g. "sum_(a)^(b)
  // ${3:c}$0" — nothing follows but the empty $0), a plain non-greedy
  // group matches zero characters, since nothing forces it to consume
  // more. That silently drops the entire argument. Bound it instead to
  // stop at a sensible math boundary: a top-level "=", a line break, or
  // the end of the string.
  if (lastFieldOpen) {
    patternSrc = patternSrc.replace(/\(\[\\s\\S\]\*\?\)$/, '([\\s\\S]*?)(?=\\s*=(?!=)|\\\\|$)');
  }
  return { regex: new RegExp('^' + patternSrc), fieldNums: fieldNums };
}

function parseByRealSnippet(full, pos, def) {
  var built = buildScaffoldRegex(def.body);
  var m = built.regex.exec(full.slice(pos));
  if (!m) return null;
  // A non-greedy field can stop at the wrong (inner) closing paren/bracket
  // when a real argument contains its own parens, e.g. matching only
  // "summ(n=0, k, (-1)" instead of the full call. Reject any match whose
  // consumed span isn't itself paren/bracket-balanced, rather than
  // silently truncating — the caller falls back to the (correct)
  // depth-counting path for calls this can't safely handle.
  var consumed = m[0];
  var parenBalance  = (consumed.match(/\(/g) || []).length - (consumed.match(/\)/g) || []).length;
  var bracketBalance = (consumed.match(/\[/g) || []).length - (consumed.match(/\]/g) || []).length;
  if (parenBalance !== 0 || bracketBalance !== 0) return null;
  var fields = built.fieldNums.map(function(_, i) { return m[i + 1]; });
  return { end: pos + m[0].length, fields: fields };
}

function detectSnippetTrigger(full, pos) {
  // Any code fence, any language — ```py, ```java, ```c, ```output, ... Use
  // the real "code" VSCode snippet (```${1:lang}\n${2:code}\n```\n$0) so
  // typing "code" shows the real dropdown, then the language and body get
  // filled in as separate tabstops, same as it really happens in the editor.
  var fenceM = /^```([a-zA-Z0-9_+-]*)/.exec(full.slice(pos));
  if (fenceM) {
    var codeDef = DEMO_SNIPPETS['code'];
    if (codeDef) {
      var parsedByCode = parseByRealSnippet(full, pos, codeDef);
      if (parsedByCode) {
        return { prefix: 'code', def: codeDef, end: parsedByCode.end, fields: parsedByCode.fields };
      }
    }
    var parsedFence = parseFenceBlock(full, pos, fenceM[0]);
    if (parsedFence) {
      var lang  = fenceM[1];
      var label = lang || 'code';
      var fenceDef = {
        prefix: label,
        body: '```' + lang + '\n${1:code}\n```\n$0',
      };
      return { prefix: label, def: fenceDef, end: parsedFence.end, fields: parsedFence.fields, skipPrefix: true };
    }
  }

  // #pseudo[...] — prefer the real "Induction proof" snippet (types
  // "induct", shows the dropdown, then expands into all 4 real fields —
  // goal, base case, hypothesis, inductive step — tabbing through each
  // exactly like the real editor) if the content matches its scaffold;
  // otherwise fall back to a generic single-field reveal.
  if (full.startsWith('#pseudo[', pos)) {
    var inductDef = DEMO_SNIPPETS['induct'];
    if (inductDef) {
      var parsedInduct = parseByRealSnippet(full, pos, inductDef);
      if (parsedInduct) {
        return { prefix: 'induct', def: inductDef, end: parsedInduct.end, fields: parsedInduct.fields };
      }
    }
    var parsedPseudo = parsePseudoBlock(full, pos);
    if (parsedPseudo) {
      var pseudoDef = {
        prefix: 'pseudo',
        body: '#pseudo[\n${1:steps}\n]\n$0',
        description: 'Pseudocode / proof block',
      };
      return { prefix: 'pseudo', def: pseudoDef, end: parsedPseudo.end, fields: parsedPseudo.fields, skipPrefix: true };
    }
  }

  // Card blocks — use the real VSCode snippet body so title+body fields
  // match what actually gets typed in the editor.
  for (var i = 0; i < SNIPPET_TRIGGERS.length; i++) {
    var t = SNIPPET_TRIGGERS[i];
    if (!full.startsWith(t.match, pos)) continue;
    var def = DEMO_SNIPPETS[t.prefix];
    if (!def) continue;
    var parsed = parseBracketBlock(full, pos);
    if (!parsed) continue;
    return { prefix: t.prefix, def: def, end: parsed.end, fields: parsed.fields };
  }
  return null;
}

// ── snippet-anim state machine ─────────────────────────────────────────────────
// phases: 'prefix' → 'dropdown' → 'select' → 'field-hold' → 'field-type' →
//         'field-pause' (loops back to field-hold for next field) → done
var snippetAnim = null;
var TYPE_MS_FAST = 200;

// Lightweight sibling to snippetAnim, for a single display-math equation
// encountered in plain prose (not inside a card/pseudo/fence). Reuses
// buildFieldRevealSteps so "$" pairs appear together, same as fields.
var mathReveal = null;

// Steps produced by revealChunks (for a nested real snippet like sum/frac
// found inside math or field content) may carry a "dd" dropdown event —
// perform it and return how long to hold before the next tick, matching
// the timing the top-level snippetAnim uses for the same phases.
// Whitespace types much faster than real characters everywhere in the demo
// (see the plain top-level typing loop below) — steps advanced through
// buildFieldRevealSteps (card fields, math reveal) grow by one character at
// a time in the common case, so the newly-revealed tail character tells us
// whether this step just typed whitespace.
function stepCharDelay(step, fallback) {
  if (!step || !step.display) return fallback;
  var last = step.display[step.display.length - 1];
  return (last === ' ' || last === '\t') ? 8 : fallback;
}

function applyStepDropdown(step, defaultDelay) {
  if (!step) return defaultDelay;
  if (step.dd === 'show')  { showDropdown(step.ddDef); return 850; }
  if (step.dd === 'flash') { flashDropdown(); return 220; }
  if (step.dd === 'hide')  { hideDropdown(); return 450; }
  if (step.holdMs) return step.holdMs;
  return stepCharDelay(step, defaultDelay);
}

function advanceMathReveal() {
  mathReveal.step++;
  renderCode();
  scrollToBottom();
  if (mathReveal.step < mathReveal.steps.length - 1) {
    scheduleTick(applyStepDropdown(mathReveal.steps[mathReveal.step], CHAR_MS));
  } else {
    charPos = mathReveal.spanEnd;
    mathReveal = null;
    scheduleTick(CHAR_MS);
  }
}

// Build the sequence of "revealed so far" strings for typing a field's real
// value, at the same fidelity as a real editor: whenever a $...$ math span
// is reached, both $ delimiters are placed immediately (like the "im"/"dm"
// snippets do — $$ with the cursor in between), then the interior is typed
// character by character, matching how the rest of the demo already reveals
// its surrounding scaffold (e.g. the closing "]" of a block) before the
// content inside is filled in.
// Each step tracks two strings: `display` (exactly what's shown — the real
// characters typed so far, nothing added) and `compileSafe` (the same, but
// with any parens/brackets opened-but-not-yet-closed inside the CURRENT
// math span auto-closed, e.g. mid-typing "mat(a_11, dots, a" gets a
// trailing ")" appended only for compilation). Without this, a $...$ span
// is already fully delimited (both $ appear together) so the old
// odd-dollar-count check in closePartial() never kicks in, and the preview
// just freezes on unbalanced-paren syntax errors until the whole
// expression is typed.
function autoCloseMathInterior(s) {
  var opens  = (s.match(/\(/g)  || []).length - (s.match(/\)/g)  || []).length;
  var bracks = (s.match(/\[/g)  || []).length - (s.match(/\]/g)  || []).length;
  if (opens  > 0) s += ')'.repeat(opens);
  if (bracks > 0) s += ']'.repeat(bracks);
  return s;
}

// Reveal a piece of math text so that function calls like "summ(...)" or
// "mat(...)" get their parens placed together first ("summ()"), then the
// arguments typed between them — instead of typing "(" and eventually ")"
// far apart in strict left-to-right order. Recurses into arguments so
// nested calls (e.g. a summ(...) inside another summ(...)) get the same
// treatment. Returns an array of progressively-revealed plain strings.
// Find the index just after the ")" that balances an opening "(" at
// openIdx, or -1 if unbalanced.
function matchBalancedParen(text, openIdx) {
  var depth = 1;
  var j = openIdx + 1;
  while (j < text.length && depth > 0) {
    if (text[j] === '(') depth++;
    else if (text[j] === ')') depth--;
    j++;
  }
  return depth === 0 ? j : -1;
}

// Real tempst snippets whose expansion doesn't start with "identifier(" —
// "sum"/"integral"/"product" now expand to native "sum_(a)^(b) c" syntax,
// not a function call — so they need to be checked as their own bare
// pattern rather than via the "identifier(" call detector below.
var BARE_SNIPPET_KEYS = ['sum', 'integral', 'product'];

// Push a plain step (no dropdown event) with the given text.
function pushChunk(chunks, text, dd, ddDef) {
  var chunk = { text: text };
  if (dd) { chunk.dd = dd; chunk.ddDef = ddDef; }
  chunks.push(chunk);
}

// Append the "type prefix → show dropdown → flash → hide → expand" steps
// for a real snippet, given the already-typed prefix string `rPrefix` and
// the snippet def — mirrors the real card-block snippetAnim's
// prefix/dropdown/select phases, but inline within a chunk sequence
// instead of the tick loop.
function pushSnippetIntro(chunks, rPrefix, realDef, typedPrefix, placeholderText) {
  for (var ni = 1; ni <= typedPrefix.length; ni++) {
    pushChunk(chunks, rPrefix + typedPrefix.slice(0, ni));
  }
  var afterPrefix = rPrefix + typedPrefix;
  chunks.push({ text: afterPrefix, dd: 'show', ddDef: { prefix: realDef.prefix, description: realDef.description } });
  chunks.push({ text: afterPrefix, dd: 'flash' });
  chunks.push({ text: afterPrefix, dd: 'hide' });
  pushChunk(chunks, rPrefix + placeholderText);
}

// Full reveal of a matched real snippet: prefix/dropdown/expand, then
// overwrite each field with its real value (recursing so nested calls
// inside an argument get the same treatment).
function pushRealSnippetReveal(chunks, rPrefix, realDef, matched) {
  var scaffoldBody = realDef.body.replace(/\\\$/g, '$');
  var segs = parseSnippetFields(scaffoldBody);
  var ord = fieldOrder(segs);
  var placeholderText = segs.map(function(seg) { return seg.value; }).join('');
  pushSnippetIntro(chunks, rPrefix, realDef, realDef.prefix, placeholderText);
  for (var fi = 0; fi < ord.length; fi++) {
    var realVal = matched.fields[fi] || '';
    var partialChunks = revealChunks(realVal);
    for (var pk = 1; pk < partialChunks.length; pk++) {
      var composed = segs.map(function(seg) {
        if (seg.type === 'text') return seg.value;
        var pos = ord.indexOf(seg.index);
        if (pos < fi) return matched.fields[pos] || '';
        if (pos === fi) return partialChunks[pk].text;
        return seg.value;
      }).join('');
      pushChunk(chunks, rPrefix + composed, partialChunks[pk].dd, partialChunks[pk].ddDef);
    }
  }
}

function revealChunks(text) {
  var chunks = [{ text: '' }];
  var i = 0;
  while (i < text.length) {
    var barePrefix = chunks[chunks.length - 1].text;
    var bareMatched = null;
    var bareDef = null;
    for (var bk = 0; bk < BARE_SNIPPET_KEYS.length; bk++) {
      var candDef = DEMO_SNIPPETS[BARE_SNIPPET_KEYS[bk]];
      if (!candDef) continue;
      var candMatched = parseByRealSnippet(text, i, candDef);
      if (candMatched) { bareMatched = candMatched; bareDef = candDef; break; }
    }
    if (bareMatched) {
      pushRealSnippetReveal(chunks, barePrefix, bareDef, bareMatched);
      i = bareMatched.end;
      continue;
    }

    var callM = /^([a-zA-Z_][a-zA-Z0-9_.]*)\(/.exec(text.slice(i));
    if (callM) {
      var openLen = callM[0].length;
      var depth = 1;
      var j = i + openLen;
      while (j < text.length && depth > 0) {
        if (text[j] === '(') depth++;
        else if (text[j] === ')') depth--;
        j++;
      }
      if (depth === 0) {
        var namePart = callM[1] + '(';
        var argsText = text.slice(i + openLen, j - 1);
        var cPrefix = chunks[chunks.length - 1].text;
        pushChunk(chunks, cPrefix + namePart + ')');
        var argChunks = revealChunks(argsText);
        for (var a = 1; a < argChunks.length; a++) {
          pushChunk(chunks, cPrefix + namePart + argChunks[a].text + ')', argChunks[a].dd, argChunks[a].ddDef);
        }
        i = j;
        continue;
      }
    }

    // Fraction "(num)/(den)" — the real "frac" snippet's shape. Type "frac"
    // as a prefix, show the dropdown, expand to "()/()", then fill the
    // numerator and denominator in tabstop order. Tolerates optional
    // whitespace around the slash ("(a)/(b)" and "(a) / (b)" both appear).
    if (text[i] === '(') {
      var numEnd = matchBalancedParen(text, i);
      if (numEnd !== -1) {
        var afterNumM = /^\s*\/\s*\(/.exec(text.slice(numEnd));
        if (afterNumM) {
          var denOpenIdx = numEnd + afterNumM[0].length - 1; // index of den's "("
          var denEnd = matchBalancedParen(text, denOpenIdx);
          if (denEnd !== -1) {
            var numText = text.slice(i + 1, numEnd - 1);
            var denText = text.slice(denOpenIdx + 1, denEnd - 1);
            var sep = text.slice(numEnd, denOpenIdx); // whitespace + "/" + whitespace, as written
            var fPrefix = chunks[chunks.length - 1].text;
            var fracDef = DEMO_SNIPPETS['frac'];
            if (fracDef) {
              pushSnippetIntro(chunks, fPrefix, fracDef, fracDef.prefix || 'frac', '()' + sep + '()');
            } else {
              pushChunk(chunks, fPrefix + '()' + sep + '()');
            }
            var numChunks = revealChunks(numText);
            for (var nA = 1; nA < numChunks.length; nA++) {
              pushChunk(chunks, fPrefix + '(' + numChunks[nA].text + ')' + sep + '()', numChunks[nA].dd, numChunks[nA].ddDef);
            }
            var denChunks = revealChunks(denText);
            for (var dA = 1; dA < denChunks.length; dA++) {
              pushChunk(chunks, fPrefix + '(' + numText + ')' + sep + '(' + denChunks[dA].text + ')', denChunks[dA].dd, denChunks[dA].ddDef);
            }
            i = denEnd;
            continue;
          }
        }
      }
    }

    pushChunk(chunks, chunks[chunks.length - 1].text + text[i]);
    i++;
  }
  return chunks;
}

function buildFieldRevealSteps(text) {
  var steps = [{ display: '', compileSafe: '' }];
  var i = 0;
  while (i < text.length) {
    // Code fence NESTED inside this field's own content (e.g. a ```py
    // block inside #example[...]) — place both fences immediately, then
    // reveal the code between them, same trick as top-level fences get
    // from detectSnippetTrigger. Without this, a fence inside a card's
    // field just gets typed as plain characters with no special reveal.
    var fenceM = /^```([a-zA-Z0-9_+-]*)\n/.exec(text.slice(i));
    if (fenceM) {
      var fenceOpen = fenceM[0];
      var afterOpen = i + fenceOpen.length;
      var closeMatch = /\n[ \t]*```/.exec(text.slice(afterOpen));
      if (closeMatch) {
        var fClose = closeMatch[0];
        var closeIdx = afterOpen + closeMatch.index;
        var code = text.slice(afterOpen, closeIdx);
        var fPrefix = steps[steps.length - 1].display;
        steps.push({ display: fPrefix + fenceOpen + fClose, compileSafe: fPrefix + fenceOpen + fClose });
        for (var fk = 1; fk <= code.length; fk++) {
          var fpc = code.slice(0, fk);
          steps.push({
            display:     fPrefix + fenceOpen + fpc + fClose,
            compileSafe: fPrefix + fenceOpen + fpc + fClose,
          });
        }
        i = closeIdx + fClose.length;
        continue;
      }
    }
    if (text[i] === '$') {
      var close = text.indexOf('$', i + 1);
      if (close === -1) {
        var prev0 = steps[steps.length - 1];
        steps.push({ display: prev0.display + text[i], compileSafe: prev0.compileSafe + text[i] });
        i++;
        continue;
      }
      var interior = text.slice(i + 1, close);
      var prefix = steps[steps.length - 1].display;

      // Typst renders "$ ... $" (space touching both delimiters) as DISPLAY
      // math and "$...$" as INLINE math. If we just grew the interior left
      // to right, the mandatory trailing space wouldn't appear until the
      // very last character — so the whole span would render inline for
      // the entire animation and only flip to display math on the final
      // keystroke. Instead, detect a display span upfront and keep both
      // boundary spaces present from the first step, only growing the core
      // content between them.
      var leadM  = interior.match(/^\s+/);
      var trailM = interior.match(/\s+$/);
      var isDisplay = !!leadM && !!trailM && leadM[0].length + trailM[0].length < interior.length + 1;
      if (isDisplay) {
        var lead  = leadM[0];
        var trail = trailM[0];
        var core  = interior.slice(lead.length, interior.length - trail.length);
        steps.push({ display: prefix + '$' + lead + trail + '$', compileSafe: prefix + '$' + lead + trail + '$' });
        var coreChunks = revealChunks(core);
        for (var k = 1; k < coreChunks.length; k++) {
          steps.push({
            display:     prefix + '$' + lead + coreChunks[k].text + trail + '$',
            compileSafe: prefix + '$' + lead + autoCloseMathInterior(coreChunks[k].text) + trail + '$',
            dd: coreChunks[k].dd,
            ddDef: coreChunks[k].ddDef,
          });
        }
      } else {
        steps.push({ display: prefix + '$$', compileSafe: prefix + '$$' });
        var interiorChunks = revealChunks(interior);
        for (var j = 1; j < interiorChunks.length; j++) {
          steps.push({
            display:     prefix + '$' + interiorChunks[j].text + '$',
            compileSafe: prefix + '$' + autoCloseMathInterior(interiorChunks[j].text) + '$',
            dd: interiorChunks[j].dd,
            ddDef: interiorChunks[j].ddDef,
          });
        }
      }
      i = close + 1;
      continue;
    }

    // *bold* / _italic_ — mimic typing the plain word first, then
    // "selecting" it (highlighted, like double-clicking a word) and
    // applying the formatting, rather than typing the markers inline as if
    // they were just more characters.
    if (text[i] === '*' || text[i] === '_') {
      var marker = text[i];
      var mClose = text.indexOf(marker, i + 1);
      if (mClose !== -1) {
        var inner = text.slice(i + 1, mClose);
        var mPrefix = steps[steps.length - 1].display;
        for (var mk = 1; mk <= inner.length; mk++) {
          var mPartial = inner.slice(0, mk);
          steps.push({ display: mPrefix + mPartial, compileSafe: mPrefix + mPartial });
        }
        // Hold the whole word highlighted (as if just selected) before the
        // markers land — the sentinel-wrapped copy renders as a selection
        // span in highlightTypstClient but compiles as the plain word.
        steps.push({
          display:     mPrefix + '' + inner + '',
          compileSafe: mPrefix + inner,
          holdMs: 550,
        });
        steps.push({
          display:     mPrefix + marker + inner + marker,
          compileSafe: mPrefix + marker + inner + marker,
        });
        i = mClose + 1;
        continue;
      }
    }

    var prev = steps[steps.length - 1];
    steps.push({ display: prev.display + text[i], compileSafe: prev.compileSafe + text[i] });
    i++;
  }
  return steps;
}

function startSnippetAnim(trigger) {
  var segments = parseSnippetFields(trigger.def.body);
  snippetAnim = {
    trigger: trigger,
    segments: segments,
    order: fieldOrder(segments),
    prefixCharPos: 0,
    fieldIdx: 0,
    fieldStep: 0,
    fieldSteps: [{ display: '', compileSafe: '' }],
    // Fences and #pseudo skip straight to placing the scaffold and typing
    // its field — no prefix-typing/dropdown for something that isn't
    // really "picked from a list" the way a card block snippet is.
    phase: trigger.skipPrefix ? 'field-hold' : 'prefix',
  };
  renderCode();
  scrollToBottom();
  scheduleTick(trigger.skipPrefix ? CHAR_MS : TYPE_MS_FAST);
}

function ddRowsHtml(def) {
  var alts = ['ion', 'ive'].map(function(suf) { return def.prefix + suf; });
  return (
    '<div class="dd-row active">' +
      '<span class="dd-icon"></span>' +
      '<span class="dd-prefix"><b>' + def.prefix + '</b></span>' +
      '<span class="dd-desc">' + def.description + '</span>' +
    '</div>' +
    alts.map(function(a) {
      return (
        '<div class="dd-row">' +
          '<span class="dd-icon abc">abc</span>' +
          '<span class="dd-prefix"><b>' + def.prefix + '</b>' + a.slice(def.prefix.length) + '</span>' +
        '</div>'
      );
    }).join('')
  );
}

function positionDropdown(ddEl) {
  var cursor = codeEl.querySelector('.cur');
  if (!cursor || !editorBody) return;
  var curRect  = cursor.getBoundingClientRect();
  var bodyRect = editorBody.getBoundingClientRect();
  ddEl.style.left = Math.max(0, curRect.left - bodyRect.left + editorBody.scrollLeft) + 'px';
  ddEl.style.top  = (curRect.bottom - bodyRect.top + editorBody.scrollTop + 4) + 'px';
}

function showDropdown(def) {
  var ddEl = document.getElementById('demo-dropdown');
  ddEl.innerHTML = ddRowsHtml(def);
  positionDropdown(ddEl);
  ddEl.classList.add('visible');
}

function flashDropdown() {
  var ddEl = document.getElementById('demo-dropdown');
  var active = ddEl.querySelector('.dd-row.active');
  if (active) active.classList.add('flash');
}

function hideDropdown() {
  var ddEl = document.getElementById('demo-dropdown');
  ddEl.classList.remove('visible', 'flash');
  ddEl.innerHTML = '';
}

// HTML for the block currently being animated (prefix typing / dropdown / field fill)
function renderSnippetAnimHtml(sa) {
  // The cursor is embedded directly in this HTML (right after the prefix, or
  // right after the currently-active field), never appended at the very end
  // of the whole document the way plain typing does — otherwise it would
  // sit past later, not-yet-reached fields/text instead of where typing is
  // actually happening.
  if (sa.phase === 'prefix' || sa.phase === 'dropdown' || sa.phase === 'select') {
    return '<span class="ch-kw">' + escapeHtml(sa.trigger.prefix.slice(0, sa.prefixCharPos)) + '</span><span class="cur">▮</span>';
  }
  // field-hold / field-type / field-pause: render the snippet body, replacing
  // each field placeholder with its real value as it gets "typed" over it.
  var activeFieldIndex = sa.order[sa.fieldIdx];
  return sa.segments.map(function(seg) {
    if (seg.type === 'text') return highlightTypstClient(seg.value);
    var fieldPos = sa.order.indexOf(seg.index);
    var isDone   = fieldPos !== -1 && fieldPos < sa.fieldIdx;
    var isActive = seg.index === activeFieldIndex;
    var display;
    if (isDone) {
      display = sa.trigger.fields[fieldPos] || '';
      return highlightTypstClient(display);
    }
    if (isActive) {
      display = sa.phase === 'field-type' ? sa.fieldSteps[sa.fieldStep].display : seg.value;
      return '<span class="ts-field ts-active">' + highlightTypstClient(display) + '</span><span class="cur">▮</span>';
    }
    return '<span class="ts-field">' + highlightTypstClient(seg.value) + '</span>';
  }).join('');
}

// Plain (unhighlighted) reconstruction of the same content, used to build the
// compiler source string — same field-fill rules as renderSnippetAnimHtml.
function plainSnippetAnimText(sa) {
  // Before the snippet is actually "chosen" from the dropdown, nothing but
  // the prefix has really been typed yet — the real editor wouldn't compile
  // the scaffold just because the autocomplete list is open. Matches what
  // renderSnippetAnimHtml already shows on screen for these phases.
  if (sa.phase === 'prefix' || sa.phase === 'dropdown' || sa.phase === 'select') {
    return sa.trigger.prefix.slice(0, sa.prefixCharPos);
  }
  var activeFieldIndex = sa.order[sa.fieldIdx];
  return sa.segments.map(function(seg) {
    if (seg.type === 'text') return seg.value;
    var fieldPos = sa.order.indexOf(seg.index);
    var isDone   = fieldPos !== -1 && fieldPos < sa.fieldIdx;
    if (isDone) return sa.trigger.fields[fieldPos] || '';
    if (seg.index === activeFieldIndex) {
      return sa.phase === 'field-type' ? sa.fieldSteps[sa.fieldStep].compileSafe : seg.value;
    }
    return seg.value;
  }).join('');
}

function advanceSnippetAnim() {
  var sa = snippetAnim;

  if (sa.phase === 'prefix') {
    sa.prefixCharPos++;
    renderCode();
    scrollToBottom();
    if (sa.prefixCharPos < sa.trigger.prefix.length) {
      scheduleTick(TYPE_MS_FAST);
    } else {
      sa.phase = 'dropdown';
      showDropdown(sa.trigger.def);
      scheduleTick(850);
    }
    return;
  }

  if (sa.phase === 'dropdown') {
    sa.phase = 'select';
    flashDropdown();
    scheduleTick(220);
    return;
  }

  if (sa.phase === 'select') {
    hideDropdown();
    sa.phase = 'field-hold';
    renderCode();
    scrollToBottom();
    scheduleTick(450);
    return;
  }

  if (sa.phase === 'field-hold') {
    sa.phase = 'field-type';
    sa.fieldSteps = buildFieldRevealSteps(sa.trigger.fields[sa.fieldIdx] || '');
    sa.fieldStep = 0;
    renderCode();
    scrollToBottom();
    scheduleTick(stepCharDelay(sa.fieldSteps[1], CHAR_MS));
    return;
  }

  if (sa.phase === 'field-type') {
    sa.fieldStep++;
    renderCode();
    scrollToBottom();
    if (sa.fieldStep < sa.fieldSteps.length - 1) {
      scheduleTick(applyStepDropdown(sa.fieldSteps[sa.fieldStep], CHAR_MS));
      return;
    }
    sa.fieldIdx++;
    if (sa.fieldIdx < sa.order.length) {
      sa.phase = 'field-pause';
      scheduleTick(300);
    } else {
      var end = sa.trigger.end;
      setTimeout(function() {
        charPos = end;
        snippetAnim = null;
        renderCode();
        scrollToBottom();
        scheduleTick(CHAR_MS);
      }, 400);
    }
    return;
  }

  if (sa.phase === 'field-pause') {
    sa.phase = 'field-hold';
    renderCode();
    scrollToBottom();
    scheduleTick(300);
    return;
  }
}

// ── render ────────────────────────────────────────────────────────────────────
function renderCode() {
  var demo          = DEMOS[di];
  var preambleLines = demo.lines.slice(0, demo.preamble + 1); // +1 for blank separator
  var contentFull   = demo.lines.slice(demo.preamble + 1).join('\n');
  var beforeAnim    = contentFull.slice(0, charPos);
  var animHtml      = '';
  var animPlain     = '';
  if (snippetAnim) {
    animHtml  = renderSnippetAnimHtml(snippetAnim);
    animPlain = plainSnippetAnimText(snippetAnim);
  } else if (mathReveal) {
    var mrStep = mathReveal.steps[mathReveal.step];
    animHtml  = highlightTypstClient(mrStep.display);
    animPlain = mrStep.compileSafe;
  }
  var plainSoFar    = beforeAnim + animPlain;

  var displayText   = preambleLines.join('\n') + '\n' + plainSoFar;
  var allLines      = displayText.split('\n');

  // preamble rendered dim, content rendered normally
  var preambleHtml = '<span style="opacity:0.35">' + hl(preambleLines.join('\n')) + '</span>\n';
  // A snippet's own HTML already embeds the cursor at the field currently
  // being typed (see renderSnippetAnimHtml) — appending another one here
  // would put it after the whole scaffold instead, past fields not yet
  // reached.
  codeEl.innerHTML = preambleHtml + hl(beforeAnim) + animHtml + (snippetAnim ? '' : '<span class="cur">▮</span>');
  lineEl.innerHTML = Array.from({length: allLines.length}, function(_, i) {
    return '<span>' + (i+1) + '</span>';
  }).join('');

  if (plainSoFar.length > 0) {
    var hidden = (demo.hiddenDefs || []).join('\n');
    var src = hidden ? hidden + '\n' + plainSoFar : plainSoFar;
    triggerCompile(src);
  }
}

// ── animation loop ────────────────────────────────────────────────────────────
// Every scheduled step goes through here so switching demos (or any other
// state reset) can cancel a still-pending timer instead of leaving it to
// fire later and silently double up with the new chain — that overlap was
// the cause of typing speed compounding after clicking around demos.
var tickTimer = null;
function scheduleTick(ms) {
  clearTimeout(tickTimer);
  tickTimer = setTimeout(tick, ms);
}

function tick() {
  var contentLines = DEMOS[di].lines.slice(DEMOS[di].preamble + 1);
  var full = contentLines.join('\n');

  if (phase === 'typing') {
    if (snippetAnim) {
      advanceSnippetAnim();
      return;
    }
    if (mathReveal) {
      advanceMathReveal();
      return;
    }

    if (charPos < full.length) {
      // Allow leading whitespace before the trigger (e.g. a ```py fence
      // indented inside an #example[...] block) — only require nothing
      // but whitespace typed so far on the current line.
      var lineStart   = full.lastIndexOf('\n', charPos - 1) + 1;
      var atLineStart = /^[ \t]*$/.test(full.slice(lineStart, charPos));
      var trigger = atLineStart ? detectSnippetTrigger(full, charPos) : null;
      if (trigger) {
        startSnippetAnim(trigger);
        return;
      }

      // Display math ("$ ... $", space touching both delimiters) needs its
      // trailing space present before Typst treats it as display rather
      // than inline — typing through it one character at a time means it
      // renders inline the whole time and only flips to display on the
      // very last keystroke, which reads as a glitch. Reuse the same
      // "place both $ first, then type the interior" trick already used
      // for snippet fields, instead of just pasting the whole equation.
      if (full[charPos] === '$' && /\s/.test(full[charPos + 1] || '')) {
        var priorDollars = (full.slice(0, charPos).match(/\$/g) || []).length;
        if (priorDollars % 2 === 0) {
          var mathCloseIdx = full.indexOf('$', charPos + 1);
          if (mathCloseIdx !== -1) {
            mathReveal = {
              spanStart: charPos,
              spanEnd: mathCloseIdx + 1,
              steps: buildFieldRevealSteps(full.slice(charPos, mathCloseIdx + 1)),
              step: 0,
            };
            renderCode();
            scrollToBottom();
            scheduleTick(stepCharDelay(mathReveal.steps[1], CHAR_MS));
            return;
          }
        }
      }

      // *bold* / _italic_ in plain prose — same "type the word, then
      // select-and-apply the formatting" trick as buildFieldRevealSteps
      // already does for field content.
      if (full[charPos] === '*' || full[charPos] === '_') {
        var emMarker = full[charPos];
        var emClose = full.indexOf(emMarker, charPos + 1);
        if (emClose !== -1) {
          mathReveal = {
            spanStart: charPos,
            spanEnd: emClose + 1,
            steps: buildFieldRevealSteps(full.slice(charPos, emClose + 1)),
            step: 0,
          };
          renderCode();
          scrollToBottom();
          scheduleTick(stepCharDelay(mathReveal.steps[1], CHAR_MS));
          return;
        }
      }

      charPos++;
      // rush past consecutive blank lines instantly
      while (charPos < full.length && full[charPos - 1] === '\n' && full[charPos] === '\n') {
        charPos++;
      }
    } else {
      phase  = 'hold';
      holdMs = 0;
    }
    renderCode();
    scrollToBottom();
    // Rush through whitespace (spaces, tabs, indentation) — no reason to
    // pace those at the same speed as real characters.
    var justTyped = full[charPos - 1];
    var justTypedIsSpace = justTyped === ' ' || justTyped === '\t';
    scheduleTick(justTypedIsSpace ? 8 : CHAR_MS);

  } else if (phase === 'hold') {
    holdMs += 16;
    if (holdMs < HOLD_MS) {
      scheduleTick(16);
    } else {
      phase   = 'clearing';
      clearMs = 0;
      scheduleTick(16);
    }

  } else { // clearing
    clearMs += 16;
    var t = Math.min(clearMs / FADE_MS, 1);
    codeEl.style.opacity = 1 - t;
    lineEl.style.opacity = 1 - t;
    outEl.style.opacity  = 1 - t;
    if (t < 1) {
      scheduleTick(16);
    } else {
      goToDemo((di + 1) % DEMOS.length);
    }
  }
}

function updatePickerActive() {
  document.querySelectorAll('.demo-picker-dot').forEach(function(btn, i) {
    btn.classList.toggle('active', i === di);
  });
}

function goToDemo(index) {
  clearTimeout(tickTimer);
  di      = index;
  charPos = 0;
  phase   = 'typing';
  holdMs  = 0;
  clearMs = 0;
  if (snippetAnim) hideDropdown();
  snippetAnim = null;
  mathReveal  = null;
  compileBusy = false;
  pendingText = null;
  autoScroll  = true;
  window.__demoMeta = DEMOS[di];
  clearTimeout(autoScrollTimer);
  if (editorBody) editorBody.scrollTop = 0;
  codeEl.style.opacity = 1;
  lineEl.style.opacity = 1;
  outEl.style.opacity  = 1;
  outEl.innerHTML      = '<span class="render-status">loading typst…</span>';
  codeEl.innerHTML = '<span class="cur">▮</span>';
  lineEl.innerHTML = '<span>1</span>';
  updatePickerActive();
  presizeWindow(DEMOS[di], function() {
    scheduleTick(300);
  });
}

document.querySelectorAll('.demo-picker-dot').forEach(function(btn) {
  btn.addEventListener('click', function() {
    goToDemo(parseInt(btn.dataset.demoIndex, 10));
  });
});

// expose current demo meta for the compile script
window.__demoMeta = DEMOS[di];
updatePickerActive();

presizeWindow(DEMOS[di], function() { tick(); });


})();
</script>

<script is:inline>
(async function () {
  // "text" is the keyword that loads all NewCM10 + NewCMMath fonts from typst-assets CDN

  function buildPageSetup(meta) {
    var title  = (meta && meta.title)  || 'Course Notes';
    var course = (meta && meta.course) || '';
    return [
      // height: auto — a fixed height would force a second page once content
      // (e.g. a theorem/definition card) makes the note taller than one
      // page, and typst.svg() renders all pages stacked into one SVG, which
      // made fitOutputToBox() shrink everything to fit that taller image
      // (looked like an unwanted "zoom out"). Auto keeps it exactly one
      // page sized to its content, so the box never has to shrink for that.
      '#set page(width: 500pt, height: auto, margin: (x: 30pt, top: 38pt, bottom: 20pt))',
      '#set text(size: 12pt, font: "New Computer Modern")',
      '#let loss = $cal(L)$',
      '#let apx = $approx$',
      '#let RR = $bb(R)$',
      '#let EE = $bb(E)$',
      '#let mid = "|"',
      '#let px(f, x) = $(partial #f) / (partial #x)$',
      '#let dv(f, x) = $(dif #f) / (dif #x)$',
      '#let dx = $dif x$',
      '#let norm(x) = $parallel #x parallel$',
      '#let inv(x) = $#x^sans(-1)$',
      // Real tempst shorthand, reused as-is (trivial, no external deps).
      '#let summ(a, b, c) = $sum_(#a)^(#b) #c$',
      '#let kplus = $k+1$',
      '#let qquad = $quad quad$',
      // Real sdust's #pseudo — pseudocode-list(body) from the actual
      // lovelace package (fetched live via Snippet.fetchPackageRegistry(),
      // same as codly), so this matches real sdust exactly instead of
      // being a hand-rolled lookalike.
      '#import "@preview/lovelace:0.3.0": *',
      '#let pseudo(body) = {',
      '  show math.equation.where(block: true): eq => block(width: 100%, align(center, eq))',
      '  pseudocode-list(body)',
      '}',
      // Lightweight, self-contained stand-ins for sdust's theorem-style card
      // blocks (matching its colors) — avoids importing the real sdust
      // package here, which would pull in its full @preview dependency
      // chain (fletcher, cetz, lovelace, ...) just for this preview pane.
      '#let _card(title, header-fill, body-fill, border, body-text-fill, content) = block(',
      '  width: 100%, stroke: 0.5pt + border, radius: 2pt, clip: true, inset: 0pt,',
      '  stack(spacing: 0pt,',
      '    block(width: 100%, above: 0pt, below: 0pt, fill: header-fill, inset: (left: 14pt, right: 14pt, top: 8pt, bottom: 8pt), text(fill: white, weight: "bold", size: 10.5pt, title)),',
      '    block(width: 100%, above: 0pt, below: 0pt, fill: body-fill, inset: (left: 14pt, right: 14pt, top: 10pt, bottom: 10pt), { set text(fill: body-text-fill, size: 10.5pt); content }),',
      '  ),',
      ')',
      // Auto-prefix card titles with their kind ("Definition: Matrix"),
      // unless no custom title was given — then just the bare kind name.
      '#let _labeled(kind, title) = if title == kind { kind } else { kind + ": " + title }',
      '#let theorem(title: "Theorem", content) = _card(_labeled("Theorem", title), rgb("#1565c0"), rgb("#ecf3fc"), rgb("#b3cdeb"), rgb("#0d2e57"), content)',
      '#let definition(title: "Definition", content) = _card(_labeled("Definition", title), rgb("#2e7d32"), rgb("#ecfdf5"), rgb("#a7f3d0"), rgb("#14532d"), content)',
      '#let example(title: "Example", content) = _card(_labeled("Example", title), rgb("#c62828"), rgb("#fdeced"), rgb("#f2b9bc"), rgb("#5a1212"), content)',
      '#let corollary(title: "Corollary", content) = _card(_labeled("Corollary", title), rgb("#6d28d9"), rgb("#f3ecfd"), rgb("#d8b9f2"), rgb("#3b1257"), content)',
      '#let QED = [#h(1fr) $square$]',
      '#let proof(title: "Proof", content) = _card(_labeled("Proof", title), rgb("#4b5563"), white, rgb("#d1d5db"), rgb("#1f2937"), [#content #QED])',
      // Real codly (same as sdust's actual code-style), fetched live from
      // the @preview registry via Snippet.fetchPackageRegistry() above.
      '#import "@preview/codly:1.3.0": codly, codly-init, no-codly',
      '#import "@preview/codly-languages:0.1.10": codly-languages',
      '#show: codly-init',
      '#codly(',
      '  languages: codly-languages,',
      '  zebra-fill: luma(246),',
      '  display-name: true,',
      '  display-icon: true,',
      '  radius: 5pt,',
      '  inset: (left: 6pt, right: 6pt, top: 4pt, bottom: 4pt),',
      '  stroke: 0.8pt + luma(220),',
      // codly leaves non-zebra rows transparent by default, so a code block
      // nested inside a colored card (e.g. #example) let that card's tint
      // bleed through every other line — force an opaque white base instead.
      '  fill: white,',
      ')',
      '#show raw.where(block: false): it => box(',
      '  fill: rgb("#eeeeee"), inset: (x: 3pt, y: 0pt), outset: (y: 3pt), radius: 2pt,',
      '  text(fill: rgb("#1c1e26"), font: ("Menlo", "DejaVu Sans Mono"), size: 9pt, it),',
      ')',
      '#set par(leading: 0.65em)',
      '#set block(spacing: 0.75em)',
      '#set math.equation(numbering: none)',
      '#set heading(numbering: "1.1")',
      '#show heading.where(level: 1): it => block(above: 1em, below: 0.35em)[',
      '  #text(size: 10.5pt, weight: "bold")[#counter(heading).display() #it.body]',
      ']',
      '#show heading.where(level: 2): it => block(above: 0.75em, below: 0.25em)[',
      '  #text(size: 9.5pt, weight: "bold")[#counter(heading).display() #it.body]',
      ']',
      '#align(center, stack(spacing: 0pt,',
      '  line(length: 100%, stroke: 2.5pt + rgb("#2c5aa0")),',
      '  v(0.7em),',
      '  text(size: 6pt, fill: rgb("#2c5aa0"), tracking: 2pt, weight: "bold")[LECTURE NOTES],',
      '  v(1.2em),',
      '  text(size: 16pt, weight: "bold")[' + title + '],',
      '  v(0.7em),',
      '  line(length: 28%, stroke: 0.5pt + rgb("#bbbbbb")),',
      '  v(0.5em),',
      '  text(size: 9pt, fill: rgb("#444444"))[' + course + '],',
      '  v(0.8em),',
      '))',
      '#line(length: 100%, stroke: 0.4pt + rgb("#dddddd"))',
      '#v(8pt)',
      '',
    ].join('\n');
  }

  var outEl = document.getElementById('render-out');

  try {
    await import('/typst-lite.js');
    var typst  = window.$typst;
    var Snippet = window.TypstSnippet;

    // Preload logo for use in Typst headers
    var logoBytes = null;
    try {
      var resp = await fetch('/sdu-logo.png');
      logoBytes = new Uint8Array(await resp.arrayBuffer());
    } catch (e) { logoBytes = null; }

    // Map sdust package so @local/sdust:0.1.0 resolves in the browser compiler
    try {
      var sdustResp = await fetch('/sdust-lib.typ');
      var sdustBytes = new Uint8Array(await sdustResp.arrayBuffer());
      typst.mapShadow('/packages/local/sdust/0.1.0/lib.typ', sdustBytes);
    } catch (e) { /* non-fatal */ }

    // Preload fonts via typst.use() before first compile
    typst.use(
      Snippet.preloadFontAssets({ assets: ['text'] })
    );

    // Let real @preview packages (codly, codly-languages) resolve over the
    // network, so the code blocks can use the actual codly styling instead
    // of a hand-rolled lookalike.
    try {
      typst.use(await Snippet.fetchPackageRegistry());
    } catch (e) { /* non-fatal — falls back to whatever's already cached */ }

    typst.setCompilerInitOptions({
      getModule: function() {
        return fetch('https://cdn.jsdelivr.net/npm/@myriaddreamin/typst-ts-web-compiler@0.7.0/pkg/typst_ts_web_compiler_bg.wasm')
          .then(function(r) { return r.arrayBuffer(); });
      },
    });

    typst.setRendererInitOptions({
      getModule: function() {
        return fetch('https://cdn.jsdelivr.net/npm/@myriaddreamin/typst-ts-renderer@0.7.0/pkg/typst_ts_renderer_bg.wasm')
          .then(function(r) { return r.arrayBuffer(); });
      },
    });

    window.__typstCompile = async function(contentText, cb) {
      try {
        var setup = buildPageSetup(window.__demoMeta);
        if (logoBytes) typst.mapShadow('/sdu-logo.png', logoBytes);
        var svg = await typst.svg({ mainContent: setup + contentText });
        cb(svg);
      } catch (err) {
        cb('');  // must always call cb so compileBusy resets
      }
    };

  } catch (err) {
    if (outEl) outEl.innerHTML = '<pre style="font-size:9px;color:#c66;padding:8px;white-space:pre-wrap">' + err.message + '</pre>';
  }
})();
</script>

