---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { readFileSync } from 'fs';
import { resolve } from 'path';

const allNotes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Read the .typ source files — edit those files to change the animation.
// Lines before "// ── CONTENT" that start with # are hidden source preamble
// (compiled but not animated). Lines after the marker are animated.

function loadDemo(slug: string, title: string, course: string) {
  const raw = readFileSync(resolve('public/demo/src', slug + '.typ'), 'utf8');
  const allLines = raw.split('\n');
  const markerIdx = allLines.findIndex(l => l.startsWith('// ── CONTENT'));
  const beforeMarker = markerIdx >= 0 ? allLines.slice(0, markerIdx) : [];
  const afterMarker  = markerIdx >= 0 ? allLines.slice(markerIdx + 1) : allLines;

  // #-prefixed lines before the marker → hidden preamble sent to compiler only
  const hiddenDefs = beforeMarker.filter(l => l.trimStart().startsWith('#'));

  const content = [...afterMarker];
  while (content.length && content[content.length - 1].trim() === '') content.pop();

  const animPreamble = [
    '#import "../../temp.typ": *',
    '#show: note.with(',
    `  title:  "${title}",`,
    `  course: "${course}",`,
    ')',
  ];
  return {
    slug,
    preamble: animPreamble.length,
    hiddenDefs,
    lines: [...animPreamble, '', ...content],
  };
}

const demos = [
  loadDemo('linear-algebra',   'Linear Algebra',   'DM561'),
  loadDemo('gradient-descent', 'Gradient Descent', 'AI505'),
  loadDemo('calculus',         'Calculus',         'MM536'),
];

const demosJson = JSON.stringify(demos);
---

<Layout title="Notes" description="Study notes by Simon Holm.">
  <div class="container page">
    <h1>Notes</h1>
    <p class="sub">
      Short write-ups on things I'm figuring out. Written in
      <a href="https://typst.app" target="_blank">Typst</a> —
      try the syntax with <a href="https://simo899t.github.io/typstnique" target="_blank">Typstnique</a>.
    </p>

    <div class="typst-blurb">
      <p>
        I write all my lecture notes in <a href="https://typst.app/open-source/" target="_blank">Typst</a>. I have a shared <code>temp.typ</code> every
        course imports: custom <code>#theorem</code> / <code>#definition</code> boxes, shorthands like <code>apx</code> (≈) or <code>loss</code> (ℒ), calculus operators like <code>#px(f,x)</code> (∂f/∂x).
        The demo below cycles through real snippets, compiled live in your browser.
      </p>
    </div>

    <!-- two-pane demo window -->
    <div class="demo-window">

      <!-- left: editor -->
      <div class="pane pane-src">
        <div class="titlebar">
          <span class="tb-dot red"></span>
          <span class="tb-dot yellow"></span>
          <span class="tb-dot green"></span>
          <span class="tb-name">notes.typ</span>
        </div>
        <div class="editor-body">
          <div id="line-nums" class="line-nums"></div>
          <pre id="code" class="code"></pre>
        </div>
      </div>

      <!-- right: rendered output -->
      <div class="pane pane-out">
        <div class="titlebar titlebar-light">
          <span class="tb-dot red"></span>
          <span class="tb-dot yellow"></span>
          <span class="tb-dot green"></span>
          <span class="tb-name tb-name-dark">notes.pdf</span>
        </div>
        <div class="output-body">
          <div id="render-out" class="render-out">
            <span class="render-status">loading typst…</span>
          </div>
        </div>
      </div>

    </div>

    {allNotes.length > 0 ? (
      <div class="note-list">
        {allNotes.map(n => (
          <a href={`/notes/${n.slug}`} class="note-row">
            <span class="note-title">{n.data.title}</span>
            <span class="note-meta">
              {n.data.tags.join(' · ')} &nbsp;·&nbsp;
              {n.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">more coming soon</p>
    )}
  </div>
</Layout>

<script is:inline define:vars={{ demosJson }}>
(function () {

// ── demos ─────────────────────────────────────────────────────────────────────
const DEMOS = JSON.parse(demosJson);

// ── state ─────────────────────────────────────────────────────────────────────
let di      = 0;
let charPos = 0;
let phase   = 'typing';  // 'typing' | 'hold' | 'clearing'
let holdMs  = 0;
let clearMs = 0;

const CHAR_MS = 65;
const HOLD_MS = 5000;
const FADE_MS = 380;

// ── DOM ───────────────────────────────────────────────────────────────────────
const codeEl      = document.getElementById('code');
const lineEl      = document.getElementById('line-nums');
const outEl       = document.getElementById('render-out');
const demoEl      = document.querySelector('.demo-window');
const editorBody  = document.querySelector('.editor-body');

function growIfNeeded() {
  if (!demoEl) return;
  var text      = DEMOS[di].lines.join('\n').slice(0, charPos);
  var lineCount = text.split('\n').length;
  var lineH     = 12 * 1.65;  // font-size × line-height = 19.8px
  var buffer    = lineH * 4;  // grow 4 lines before overflow
  var needed    = lineCount * lineH + 24 + 31 + buffer;
  if (needed > demoEl.clientHeight) demoEl.style.height = Math.ceil(needed) + 'px';
}

// ── continuous compile ────────────────────────────────────────────────────────
// Always keep the latest content queued. As soon as a compile finishes, start
// the next one if content changed — so the preview updates as fast as possible.
let compileBusy   = false;
let pendingText   = null;

function triggerCompile(contentText) {
  pendingText = contentText;                                   // always track latest
  if (compileBusy) return;                                     // will drain on finish
  if (typeof window.__typstCompile !== 'function') return;
  drainCompile();
}

function closePartial(src) {
  var dollars = (src.match(/\$/g) || []).length;
  if (dollars % 2 !== 0) {
    // Inside an open math block — close unmatched parens/brackets first
    var opens  = (src.match(/\(/g) || []).length - (src.match(/\)/g) || []).length;
    var bracks = (src.match(/\[/g) || []).length - (src.match(/\]/g) || []).length;
    if (opens  > 0) src += ')'.repeat(opens);
    if (bracks > 0) src += ']'.repeat(bracks);
    return src + ' $';
  }
  // Outside math — strip completed math blocks, then check text-mode * and _
  var textOnly = src.replace(/\$[^$]*\$/g, '');
  var stars = (textOnly.match(/\*/g) || []).length;
  if (stars % 2 !== 0) src += '*';
  var underscores = (textOnly.match(/_/g) || []).length;
  if (underscores % 2 !== 0) src += '_';
  return src;
}

function drainCompile() {
  if (pendingText === null) return;
  compileBusy = true;
  var src = closePartial(pendingText);
  pendingText = null;
  window.__typstCompile(src, function(svgStr) {
    compileBusy = false;
    if (svgStr) {
      outEl.innerHTML     = svgStr;
      outEl.style.opacity = '1';
    }
    drainCompile();   // compile again if more content arrived while busy
  });
}

// ── syntax highlight ──────────────────────────────────────────────────────────
function hl(text) {
  var esc = function(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  };
  return text.split('\n').map(function(line) {
    if (/^=+\s/.test(line))
      return '<span style="color:#dcdcaa;font-weight:600">' + esc(line) + '</span>';
    var out = '', i = 0;
    while (i < line.length) {
      var ch = line[i];
      if (ch === '/' && line[i+1] === '/') {
        out += '<span style="color:#555">' + esc(line.slice(i)) + '</span>';
        i = line.length;
      } else if (ch === '#' && i+1 < line.length && /\w/.test(line[i+1])) {
        var j = i+1; while (j < line.length && /\w/.test(line[j])) j++;
        out += '<span style="color:#4db6c4">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else if (ch === '"') {
        var j = i+1; while (j < line.length && line[j] !== '"') j++; if (j < line.length) j++;
        out += '<span style="color:#ce9178">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else if (ch === '$') {
        var j = i+1; while (j < line.length && line[j] !== '$') j++; if (j < line.length) j++;
        out += '<span style="color:#b5cea8">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else { out += esc(ch); i++; }
    }
    return out;
  }).join('\n');
}

// ── render ────────────────────────────────────────────────────────────────────
function renderCode() {
  var full    = DEMOS[di].lines.join('\n');
  var text    = full.slice(0, charPos);
  var typed   = text.split('\n');
  var total   = DEMOS[di].lines.length;

  codeEl.innerHTML = hl(text) + '<span class="cur">▮</span>';
  lineEl.innerHTML = Array.from({length: total}, function(_, i) {
    return '<span style="opacity:' + (i < typed.length ? 1 : 0.25) + '">' + (i+1) + '</span>';
  }).join('');

  // compile on every character — drainCompile throttles via compileBusy
  var preamble     = DEMOS[di].preamble;
  var contentLines = typed.slice(preamble + 1); // +1 for blank separator line
  if (contentLines.length > 0) {
    var hidden = (DEMOS[di].hiddenDefs || []).join('\n');
    var src = hidden ? hidden + '\n' + contentLines.join('\n') : contentLines.join('\n');
    triggerCompile(src);
  }
}

// ── animation loop ────────────────────────────────────────────────────────────
function tick() {
  var full = DEMOS[di].lines.join('\n');

  if (phase === 'typing') {
    if (charPos < full.length) {
      charPos++;
    } else {
      phase  = 'hold';
      holdMs = 0;
    }
    renderCode();
    growIfNeeded();
    setTimeout(tick, CHAR_MS);

  } else if (phase === 'hold') {
    holdMs += 16;
    if (holdMs < HOLD_MS) {
      setTimeout(tick, 16);
    } else {
      phase   = 'clearing';
      clearMs = 0;
      setTimeout(tick, 16);
    }

  } else { // clearing
    clearMs += 16;
    var t = Math.min(clearMs / FADE_MS, 1);
    codeEl.style.opacity = 1 - t;
    lineEl.style.opacity = 1 - t;
    outEl.style.opacity  = 1 - t;
    if (t < 1) {
      setTimeout(tick, 16);
    } else {
      di      = (di + 1) % DEMOS.length;
      charPos = 0;
      phase   = 'typing';
      compileBusy = false;
      pendingText = null;
      codeEl.style.opacity = 1;
      lineEl.style.opacity = 1;
      outEl.style.opacity  = 1;
      outEl.innerHTML      = '<span class="render-status">loading typst…</span>';
      codeEl.innerHTML = '<span class="cur">▮</span>';
      lineEl.innerHTML = '<span>1</span>';
      setTimeout(tick, 300);
    }
  }
}

tick();


})();
</script>

<script is:inline>
(async function () {
  // "text" is the keyword that loads all NewCM10 + NewCMMath fonts from typst-assets CDN

  var PAGE_SETUP = [
    '#set page(width: 270pt, height: auto, margin: (x: 18pt, y: 16pt))',
    '#set text(size: 10pt, font: "New Computer Modern")',
    '// shorthands mirroring temp.typ',
    '#let loss = $cal(L)$',
    '#let apx = $approx$',
    '#let RR = $bb(R)$',
    '#let mid = "|"',
    '#let px(f, x) = $(partial #f) / (partial #x)$',
    '#let pv(f, x) = $(d #f) / (d #x)$',
    '#let dx = $upright(d)x$',
    '#set par(leading: 0.7em)',
    '#set block(spacing: 0.8em)',
    '#set heading(numbering: none)',
    '#show heading.where(level: 1): it => block(above: 1em, below: 0.4em)[',
    '  #text(size: 11pt, weight: "bold")[#it.body]',
    ']',
    '#show heading.where(level: 2): it => block(above: 0.8em, below: 0.3em)[',
    '  #text(size: 10pt, weight: "bold", style: "italic")[#it.body]',
    ']',
    '#grid(',
    '  columns: (1fr, 1fr),',
    '  align(left)[#text(weight: "bold", size: 10pt)[Course notes]],',
    '  align(right)[#text(size: 8pt, fill: luma(140))[Simon Holm · SDU]],',
    ')',
    '#v(2pt)',
    '#line(length: 100%, stroke: 0.5pt + luma(180))',
    '#v(6pt)',
    '',
  ].join('\n');

  var outEl = document.getElementById('render-out');

  try {
    await import('/typst-lite.js');
    var typst  = window.$typst;
    var Snippet = window.TypstSnippet;

    // Preload fonts via typst.use() before first compile
    typst.use(
      Snippet.preloadFontAssets({ assets: ['text'] })
    );

    typst.setCompilerInitOptions({
      getModule: function() {
        return fetch('https://cdn.jsdelivr.net/npm/@myriaddreamin/typst-ts-web-compiler@0.7.0/pkg/typst_ts_web_compiler_bg.wasm')
          .then(function(r) { return r.arrayBuffer(); });
      },
    });

    typst.setRendererInitOptions({
      getModule: function() {
        return fetch('https://cdn.jsdelivr.net/npm/@myriaddreamin/typst-ts-renderer@0.7.0/pkg/typst_ts_renderer_bg.wasm')
          .then(function(r) { return r.arrayBuffer(); });
      },
    });

    window.__typstCompile = async function(contentText, cb) {
      try {
        var svg = await typst.svg({ mainContent: PAGE_SETUP + contentText });
        cb(svg);
      } catch (err) {
        cb('');  // must always call cb so compileBusy resets
      }
    };

  } catch (err) {
    if (outEl) outEl.innerHTML = '<pre style="font-size:9px;color:#c66;padding:8px;white-space:pre-wrap">' + err.message + '</pre>';
  }
})();
</script>

<style>
h1 { font-size: 1.6rem; font-weight: 600; margin-bottom: 0.35rem; }

.sub {
  font-size: 0.85rem;
  color: var(--text-dim);
  margin-bottom: 1rem;
}

.typst-blurb {
  margin-bottom: 1.5rem;
}
.typst-blurb p {
  font-size: 0.85rem;
  color: var(--text-muted);
  line-height: 1.7;
  margin: 0;
}
.typst-blurb code {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--accent);
  background: rgba(77,182,196,0.08);
  padding: 1px 4px;
  border-radius: 3px;
}

/* ── demo window ── */
.demo-window {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: stretch;
  height: 300px;
  border-radius: 8px;
  overflow: hidden;
  transition: height 0.3s ease;
  border: 1px solid #2a2a2a;
  margin-bottom: 2.5rem;
  box-shadow: 0 4px 24px rgba(0,0,0,0.4);
  resize: vertical;
}

.pane { display: flex; flex-direction: column; min-width: 0; }

.titlebar {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  background: #1c1c1c;
  border-bottom: 1px solid #2a2a2a;
  flex-shrink: 0;
}
.titlebar-light {
  background: #d0cdc4;
  border-bottom: 1px solid #b8b5ac;
}

.tb-dot {
  width: 11px; height: 11px;
  border-radius: 50%;
  flex-shrink: 0;
}
.tb-dot.red    { background: #ff5f57; }
.tb-dot.yellow { background: #febc2e; }
.tb-dot.green  { background: #28c840; }

.tb-name {
  font-family: var(--font-mono);
  font-size: 11px;
  color: #555;
  margin-left: 4px;
}
.tb-name-dark { color: #888; }

/* left pane */
.pane-src {
  background: #111;
  border-right: 1px solid #222;
}

.editor-body {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.line-nums {
  display: flex;
  flex-direction: column;
  padding: 12px 8px 12px 8px;
  min-width: 34px;
  text-align: right;
  font-family: var(--font-mono);
  font-size: 12px;
  line-height: 1.65;
  color: #3a3a3a;
  border-right: 1px solid #1e1e1e;
  user-select: none;
  flex-shrink: 0;
}

.code {
  margin: 0;
  padding: 12px 12px;
  font-family: var(--font-mono);
  font-size: 12px;
  line-height: 1.65;
  color: #ccc;
  white-space: pre-wrap;
  word-break: break-all;
  flex: 1;
  overflow: hidden;
}

.cur {
  color: #4db6c4;
  animation: blink 1s step-end infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* right pane */
.pane-out {
  background: #c5c2b8;
}

.output-body {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  display: flex;
  justify-content: center;
  align-items: flex-start;
}

.render-out {
  width: 100%;
  max-width: 320px;
  background: #fff;
  border-radius: 2px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.28);
  transition: opacity 0.15s ease;
  overflow: hidden;
}

.render-out svg {
  width: 100%;
  height: auto;
  display: block;
}

.render-status {
  font-size: 10px;
  color: #999;
  font-family: var(--font-mono);
  display: block;
  padding: 10px;
}

/* ── notes list ── */
.note-list {
  display: flex;
  flex-direction: column;
  border-top: 1px solid var(--border);
}

.note-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding: 0.8rem 0;
  border-bottom: 1px solid var(--border);
}
.note-row:hover .note-title { color: var(--accent); }

.note-title { font-size: 0.875rem; color: var(--text); }
.note-meta {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  white-space: nowrap;
}

.empty {
  font-size: 0.85rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
}
</style>
