---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync } from 'fs';
import { resolve } from 'path';

// Drop PDFs into public/notes-pdf/ — they appear here automatically.
// Name files like: "DM561 Linear Algebra.pdf" or "AI505-Gradient-Descent.pdf"
const pdfDir = resolve('public/notes-pdf');
const pdfs = readdirSync(pdfDir)
  .filter(f => f.endsWith('.pdf'))
  .sort()
  .map(f => ({
    filename: f,
    title: f.replace(/\.pdf$/i, '').replace(/[-_]/g, ' '),
    url: `/notes-pdf/${f}`,
  }));

function highlightTypst(raw: string): string {
  const e = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const lines = raw.split('\n');
  return lines.map(line => {
    // headings
    if (/^=+\s/.test(line)) {
      return `<span class="ch-heading">${e(line)}</span>`;
    }
    // comments
    if (line.trimStart().startsWith('//')) {
      return `<span class="ch-comment">${e(line)}</span>`;
    }
    let out = '';
    let i = 0;
    while (i < line.length) {
      // inline math $...$
      if (line[i] === '$') {
        const end = line.indexOf('$', i + 1);
        if (end !== -1) {
          out += `<span class="ch-math">${e(line.slice(i, end + 1))}</span>`;
          i = end + 1;
          continue;
        }
      }
      // #keyword
      if (line[i] === '#') {
        const m = line.slice(i).match(/^#[a-zA-Z_][a-zA-Z0-9_-]*/);
        if (m) {
          out += `<span class="ch-kw">${e(m[0])}</span>`;
          i += m[0].length;
          continue;
        }
      }
      // *bold*
      if (line[i] === '*') {
        const end = line.indexOf('*', i + 1);
        if (end !== -1) {
          out += `<span class="ch-bold">${e(line.slice(i, end + 1))}</span>`;
          i = end + 1;
          continue;
        }
      }
      // strings
      if (line[i] === '"') {
        const end = line.indexOf('"', i + 1);
        if (end !== -1) {
          out += `<span class="ch-str">${e(line.slice(i, end + 1))}</span>`;
          i = end + 1;
          continue;
        }
      }
      out += e(line[i]);
      i++;
    }
    return out;
  }).join('\n');
}

// Code examples — drop .typ + matching .png into public/code-examples/src/ and they appear automatically.
const ceDir = resolve('public/code-examples/src');
const codeExamples = readdirSync(ceDir)
  .filter(f => f.endsWith('.typ'))
  .sort()
  .map(f => {
    const slug = f.replace(/\.typ$/, '');
    const imgFile = slug + '.png';
    const hasImg = readdirSync(ceDir).includes(imgFile);
    const raw = readFileSync(resolve(ceDir, f), 'utf8')
      .split('\n')
      .filter(line => !/^\s*#import\s+"@local\/sdust/.test(line))
      .join('\n')
      .replace(/^\n+/, '')
      .trimEnd();
    return {
      slug,
      label: slug.replace(/[-_]/g, ' '),
      code: raw,
      highlighted: highlightTypst(raw),
      img: hasImg ? `/code-examples/src/${imgFile}` : null,
    };
  });

// Resolve VSCode snippet placeholders (${1:foo}, $0, \$) into plain display text,
// the same way the editor shows them right after expansion.
function resolveSnippetBody(body: string): string {
  return body
    .replace(/\$\{\d+:([^}]*)\}/g, '$1')
    .replace(/\$\{\d+\}/g, '')
    .replace(/\$0/g, '')
    .replace(/\\\$/g, '$');
}

// VSCode snippets — copy your typst.json into public/snippets/typst.json to show them here.
// Only these snippets get an animated card; edit this list to change the selection.
const SNIPPET_WHITELIST = ['Definition', 'Tree (tidy-tree)', 'SDU template import', 'Induction proof', 'Pseudocode algorithm', 'SDU note'];

const snippetsPath = resolve('public/snippets/typst.json');
let snippets: { name: string; prefix: string; body: string; expanded: string; description: string; json: string; height: number }[] = [];
try {
  const raw = JSON.parse(readFileSync(snippetsPath, 'utf8'));
  snippets = Object.entries(raw)
    .filter(([name]) => SNIPPET_WHITELIST.includes(name))
    .sort((a, b) => SNIPPET_WHITELIST.indexOf(a[0]) - SNIPPET_WHITELIST.indexOf(b[0]))
    .map(([name, def]: [string, any]) => {
      const body = Array.isArray(def.body) ? def.body.join('\n') : def.body;
      const lineCount = body.split('\n').length;
      return {
        name,
        prefix: def.prefix,
        body,
        expanded: resolveSnippetBody(body),
        description: def.description || '',
        json: JSON.stringify({ [name]: def }, null, 2).replace(/^\{\n/, '').replace(/\n\}$/, ''),
        height: Math.max(lineCount * 22 + 24, 170),
      };
    });
} catch (e) { snippets = []; }

// Read the .typ source files — edit those files to change the animation.
// Lines before "// ── CONTENT" that start with # are hidden source preamble
// (compiled but not animated). Lines after the marker are animated.

function loadDemo(slug: string, title: string, course: string) {
  const raw = readFileSync(resolve('public/demo/src', slug + '.typ'), 'utf8');
  const allLines = raw.split('\n');
  const markerIdx = allLines.findIndex(l => l.startsWith('// ── CONTENT'));
  const beforeMarker = markerIdx >= 0 ? allLines.slice(0, markerIdx) : [];
  const afterMarker  = markerIdx >= 0 ? allLines.slice(markerIdx + 1) : allLines;

  // #-prefixed lines before the marker → hidden preamble sent to compiler only
  const hiddenDefs = beforeMarker.filter(l => l.trimStart().startsWith('#'));

  const content = [...afterMarker];
  while (content.length && content[content.length - 1].trim() === '') content.pop();

  const animPreamble = [
    '#import "@local/sdust:0.1.0": *',
    '#show: note.with(',
    `  title:  "${title}",`,
    `  course: "${course}",`,
    ')',
  ];
  return {
    slug,
    title,
    course,
    preamble: animPreamble.length,
    hiddenDefs,
    lines: [...animPreamble, '', ...content],
  };
}

const demos = [
  loadDemo('linear-algebra',   'Linear Algebra',   'DM561'),
  loadDemo('gradient-descent', 'Gradient Descent', 'AI505'),
  loadDemo('calculus',         'Calculus',         'MM536'),
];

const demosJson = JSON.stringify(demos);
---

<Layout title="Notes" description="Study notes by Simon Holm.">
  <div class="container page">
    <div class="typst-blurb">
      <h1>How I write my notes</h1>
      <p>
        All lecture notes, exercises, and assignments are written in <a href="https://typst.app/open-source/" target="_blank">Typst</a> using <a href="https://github.com/simo899t/sdu-notes" target="_blank">sdust</a>, a package I developed to streamline academic document authoring. It provides document templates, structured environments such as <code>#theorem</code> and <code>#definition</code>, and mathematical shorthands including <code>apx</code> (≈), <code>loss</code> (ℒ), and <code>px(f,x)</code> (∂f/∂x). The package is open to use, though it is actively maintained and may introduce breaking changes.
      </p>

      <h2 class="blurb-heading">What is Typst?</h2>
      <p>
        <a href="https://typst.app/open-source/" target="_blank">Typst</a> is a modern typesetting language and a significant improvement over LaTeX. Typst is used to produce high-quality PDFs and is particularly well suited for mathematics and the natural sciences.  Where other typesetting languages like LaTeX is decades old and notoriously difficult to debug, Typst offers a clean and readable syntax, near-instant compilation, and clear error messages. Typst is open source and built in Rust.
      </p>

      <p class="see-how-label">See how it works with real examples 😃:</p>
    </div>

    <div class="demo-tabs">
      <button class="demo-tab active" data-tab="live-demo">Live Demo</button>
      <button class="demo-tab" data-tab="code-examples">Code Examples</button>
      <button class="demo-tab" data-tab="assignment-examples">Assignment Examples</button>
      <button class="demo-tab" data-tab="snippets">Snippets</button>
    </div>

    <div class="tab-panels">

      <!-- Live Demo -->
      <div class="tab-panel active" id="panel-live-demo">
        <div class="demo-window">
          <div class="pane pane-src">
            <div class="titlebar">
              <span class="tb-dot red"></span>
              <span class="tb-dot yellow"></span>
              <span class="tb-dot green"></span>
              <span class="tb-name">notes.typ</span>
            </div>
            <div class="editor-body">
              <div class="editor-inner">
                <div id="line-nums" class="line-nums"></div>
                <pre id="code" class="code"></pre>
              </div>
            </div>
          </div>
          <div class="pane pane-out">
            <div class="titlebar titlebar-light">
              <span class="tb-dot red"></span>
              <span class="tb-dot yellow"></span>
              <span class="tb-dot green"></span>
              <span class="tb-name tb-name-dark">notes.pdf</span>
            </div>
            <div class="output-body">
              <div id="render-out" class="render-out">
                <span class="render-status">loading typst…</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Code Examples -->
      <div class="tab-panel" id="panel-code-examples">
        <div class="code-examples-list">
          {codeExamples.map(ex => (
            <div class="code-example">
              <div class="ce-editor">
                <div class="ce-titlebar">
                  <span class="tb-dot red"></span>
                  <span class="tb-dot yellow"></span>
                  <span class="tb-dot green"></span>
                  <span class="ce-filename">{ex.slug}.typ</span>
                </div>
                <div class="ce-code-wrap">
                  <div class="line-nums ce-line-nums">
                    {ex.code.split('\n').map((_, li) => <span>{li + 1}</span>)}
                  </div>
                  <pre class="ce-code" set:html={ex.highlighted}></pre>
                </div>
              </div>
              <div class="ce-preview-pane">
                <div class="titlebar titlebar-light">
                  <span class="tb-dot red"></span>
                  <span class="tb-dot yellow"></span>
                  <span class="tb-dot green"></span>
                  <span class="ce-filename">{ex.slug}.pdf</span>
                </div>
                <div class="ce-preview">
                  {ex.img
                    ? <img src={ex.img} alt={ex.label} />
                    : <span class="render-status">no preview</span>
                  }
                </div>
              </div>
            </div>
          ))}
          </div>

        </div>
      </div>

      <!-- Assignment Examples -->
      <div class="tab-panel" id="panel-assignment-examples">
        <p class="snippets-intro">These are some fully compiled examples so you can see the capabilities of Typst.</p>
        {pdfs.length > 0 ? (
          <div class="note-list">
            {pdfs.map(p => (
              <a href={p.url} target="_blank" rel="noopener" class="note-row">
                <span class="note-title">{p.title}</span>
                <span class="note-meta pdf-tag">PDF</span>
              </a>
            ))}
          </div>
        ) : (
          <p class="empty">coming soon</p>
        )}
      </div>

      <!-- Snippets -->
      <div class="tab-panel" id="panel-snippets">
        <p class="snippets-intro">Snippets are small shortcuts in my editor. One can type a prefix like <code>def</code>, and pick the snippet from the autocomplete dropdown and it expands into a ready-made block as shown below. Download my full snippets file <a href="/snippets/typst.json" download>here</a>. I use VSCode, where it's accessed via:</p>
        <ul class="snippets-paths">
          <li><strong>macOS:</strong> <code>~/Library/Application Support/Code/User/snippets/typst.json</code></li>
          <li><strong>Windows:</strong> <code>%APPDATA%\Code\User\snippets\typst.json</code></li>
          <li><strong>Linux:</strong> <code>~/.config/Code/User/snippets/typst.json</code></li>
        </ul>
        {snippets.length > 0 ? (
          <div class="snippet-list">
            {snippets.map((s, i) => (
              <div class="snippet-row">
                <div class="snippet-pair">
                  <div class="snippet-editor">
                    <div class="ce-titlebar">
                      <span class="tb-dot red"></span>
                      <span class="tb-dot yellow"></span>
                      <span class="tb-dot green"></span>
                      <span class="ce-filename">notes.typ</span>
                    </div>
                    <div class="snippet-code-wrap" style={`height: ${s.height}px`}>
                      <div class="snippet-inner">
                        <div class="line-nums snippet-anim-linenums"></div>
                        <pre
                          class="snippet-anim"
                          data-prefix={s.prefix}
                          data-body={s.body}
                          data-expanded={s.expanded}
                          data-description={s.description}
                        ></pre>
                      </div>
                      <div class="snippet-dropdown"></div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="empty">coming soon</p>
        )}
      </div>

    </div>
  </div>
</Layout>

<script is:inline define:vars={{ demosJson }}>
(function () {

// ── tabs ──────────────────────────────────────────────────────────────────────
let snippetAnimsStarted = false;

document.querySelectorAll('.demo-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    const tab = btn.dataset.tab;
    document.querySelectorAll('.demo-tab').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel-' + tab).classList.add('active');
    if (tab === 'snippets' && !snippetAnimsStarted) {
      snippetAnimsStarted = true;
      initSnippetAnimations();
    }
  });
});

// ── snippet dropdown animations ────────────────────────────────────────────────
function escapeHtml(s) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function highlightTypstClient(raw) {
  const lines = raw.split('\n');
  return lines.map(line => {
    if (/^=+\s/.test(line)) {
      return '<span class="ch-heading">' + escapeHtml(line) + '</span>';
    }
    if (line.trimStart().startsWith('//')) {
      return '<span class="ch-comment">' + escapeHtml(line) + '</span>';
    }
    let out = '';
    let i = 0;
    while (i < line.length) {
      if (line[i] === '$') {
        const end = line.indexOf('$', i + 1);
        if (end !== -1) {
          out += '<span class="ch-math">' + escapeHtml(line.slice(i, end + 1)) + '</span>';
          i = end + 1;
          continue;
        }
      }
      if (line[i] === '#') {
        const m = line.slice(i).match(/^#[a-zA-Z_][a-zA-Z0-9_-]*/);
        if (m) {
          out += '<span class="ch-kw">' + escapeHtml(m[0]) + '</span>';
          i += m[0].length;
          continue;
        }
      }
      if (line[i] === '*') {
        const end = line.indexOf('*', i + 1);
        if (end !== -1) {
          out += '<span class="ch-bold">' + escapeHtml(line.slice(i, end + 1)) + '</span>';
          i = end + 1;
          continue;
        }
      }
      if (line[i] === '"') {
        const end = line.indexOf('"', i + 1);
        if (end !== -1) {
          out += '<span class="ch-str">' + escapeHtml(line.slice(i, end + 1)) + '</span>';
          i = end + 1;
          continue;
        }
      }
      out += escapeHtml(line[i]);
      i++;
    }
    return out;
  }).join('\n');
}

function parseSnippetFields(raw) {
  const segments = [];
  const re = /\$\{(\d+):([^}]*)\}|\$\{(\d+)\}|\$(\d+)|\\\$/g;
  let last = 0;
  let m;
  while ((m = re.exec(raw))) {
    if (m.index > last) segments.push({ type: 'text', value: raw.slice(last, m.index) });
    if (m[0] === '\\$') {
      segments.push({ type: 'text', value: '$' });
    } else if (m[1] !== undefined) {
      segments.push({ type: 'field', index: parseInt(m[1], 10), value: m[2] });
    } else {
      const idx = parseInt(m[3] !== undefined ? m[3] : m[4], 10);
      segments.push({ type: 'field', index: idx, value: '' });
    }
    last = re.lastIndex;
  }
  if (last < raw.length) segments.push({ type: 'text', value: raw.slice(last) });
  return segments;
}

function fieldOrder(segments) {
  const seen = new Set();
  segments.forEach(s => { if (s.type === 'field' && s.index !== 0) seen.add(s.index); });
  return Array.from(seen).sort((a, b) => a - b);
}

function renderSnippetStep(segments, activeIndex) {
  return segments.map(seg => {
    if (seg.type === 'text') return highlightTypstClient(seg.value);
    const cls = seg.index === activeIndex ? 'ts-field ts-active' : 'ts-field';
    return '<span class="' + cls + '">' + escapeHtml(seg.value) + '</span>';
  }).join('');
}

function initSnippetAnimations() {
  const cards = document.querySelectorAll('.snippet-anim');
  cards.forEach((animEl, idx) => {
    const prefix     = animEl.dataset.prefix || '';
    const body       = animEl.dataset.body || '';
    const description = animEl.dataset.description || '';
    const codeWrapEl = animEl.closest('.snippet-code-wrap');
    const ddEl = codeWrapEl.querySelector('.snippet-dropdown');
    const lineNumsEl = codeWrapEl.querySelector('.snippet-anim-linenums');

    const altSuffixes = ['ion', 'ive'];
    const alts = altSuffixes.map(suf => prefix + suf);

    ddEl.innerHTML = `
      <div class="dd-row active">
        <span class="dd-icon"></span>
        <span class="dd-prefix"><b>${prefix}</b></span>
        <span class="dd-desc">${description}</span>
      </div>
      ${alts.map(a => `
        <div class="dd-row">
          <span class="dd-icon abc">abc</span>
          <span class="dd-prefix"><b>${prefix}</b>${a.slice(prefix.length)}</span>
        </div>
      `).join('')}
    `;

    const segments = parseSnippetFields(body);
    const order = fieldOrder(segments);

    const TYPE_MS = 320;
    const DROPDOWN_HOLD_MS = 2600;
    const FLASH_MS = 260;
    const FIELD_HOLD_MS = 1400;
    const EXPANDED_HOLD_MS = 3200;
    const CLEAR_HOLD_MS = 900;

    let charPos = 0;
    let fieldStep = 0;
    let timer = null;

    function updateLineNums(text) {
      const lineCount = text.split('\n').length;
      lineNumsEl.innerHTML = Array.from({ length: lineCount }, (_, n) => `<span>${n + 1}</span>`).join('');
    }

    function setPlainText(text) {
      animEl.innerHTML = escapeHtml(text);
      const cursor = document.createElement('span');
      cursor.className = 'cursor';
      cursor.textContent = '\xa0';
      animEl.appendChild(cursor);
      updateLineNums(text);
    }

    function typeStep() {
      charPos++;
      setPlainText(prefix.slice(0, charPos));
      if (charPos < prefix.length) {
        timer = setTimeout(typeStep, TYPE_MS);
      } else {
        ddEl.classList.add('visible');
        timer = setTimeout(selectActive, DROPDOWN_HOLD_MS);
      }
    }

    function selectActive() {
      const activeRow = ddEl.querySelector('.dd-row.active');
      if (activeRow) activeRow.classList.add('flash');
      timer = setTimeout(showFieldStep, FLASH_MS);
    }

    function showFieldStep() {
      ddEl.classList.remove('visible');
      const activeIndex = order[fieldStep];
      animEl.innerHTML = renderSnippetStep(segments, activeIndex);
      const fullText = segments.map(s => s.value).join('');
      updateLineNums(fullText);
      fieldStep++;
      if (fieldStep < order.length) {
        timer = setTimeout(showFieldStep, FIELD_HOLD_MS);
      } else {
        timer = setTimeout(showFinal, FIELD_HOLD_MS);
      }
    }

    function showFinal() {
      let cursorInserted = false;
      const html = segments.map(seg => {
        if (seg.type === 'field' && seg.index === 0) {
          cursorInserted = true;
          return '<span class="cursor">\xa0</span>';
        }
        if (seg.type === 'text') return highlightTypstClient(seg.value);
        return escapeHtml(seg.value);
      }).join('') + (cursorInserted ? '' : '<span class="cursor">\xa0</span>');
      animEl.innerHTML = html;
      updateLineNums(segments.map(s => s.value).join(''));
      timer = setTimeout(clearAndRestart, EXPANDED_HOLD_MS);
    }

    function clearAndRestart() {
      animEl.textContent = '';
      charPos = 0;
      fieldStep = 0;
      timer = setTimeout(typeStep, CLEAR_HOLD_MS);
    }

    // stagger start so cards don't all animate in lockstep
    setTimeout(typeStep, idx * 220);
  });
}


// ── demos ─────────────────────────────────────────────────────────────────────
const DEMOS = JSON.parse(demosJson);

// ── state ─────────────────────────────────────────────────────────────────────
let di      = 0;
let charPos = 0;
let phase   = 'typing';  // 'typing' | 'hold' | 'clearing'
let holdMs  = 0;
let clearMs = 0;

const CHAR_MS = 140;
const HOLD_MS = 5000;
const FADE_MS = 600;

// ── DOM ───────────────────────────────────────────────────────────────────────
const codeEl      = document.getElementById('code');
const lineEl      = document.getElementById('line-nums');
const outEl       = document.getElementById('render-out');
const demoEl      = document.querySelector('.demo-window');
const editorBody  = document.querySelector('.editor-body');

var autoScroll           = true;
var autoScrollTimer      = null;
var programmaticScroll   = false;

if (editorBody) {
  editorBody.addEventListener('scroll', function() {
    if (programmaticScroll) return;
    autoScroll = false;
    clearTimeout(autoScrollTimer);
    autoScrollTimer = setTimeout(function() { autoScroll = true; }, 10000);
  }, { passive: true });
}

function scrollToBottom() {
  if (!autoScroll || !editorBody) return;
  // double rAF ensures DOM has reflowed before measuring scrollHeight
  requestAnimationFrame(function() {
    requestAnimationFrame(function() {
      programmaticScroll = true;
      editorBody.scrollTop = editorBody.scrollHeight;
      setTimeout(function() { programmaticScroll = false; }, 150);
    });
  });
}

// ── continuous compile ────────────────────────────────────────────────────────
// Always keep the latest content queued. As soon as a compile finishes, start
// the next one if content changed — so the preview updates as fast as possible.
let compileBusy   = false;
let pendingText   = null;

function triggerCompile(contentText) {
  pendingText = contentText;                                   // always track latest
  if (compileBusy) return;                                     // will drain on finish
  if (typeof window.__typstCompile !== 'function') return;
  drainCompile();
}

function closePartial(src) {
  var dollars = (src.match(/\$/g) || []).length;
  if (dollars % 2 !== 0) {
    // Inside an open math block — close unmatched parens/brackets first
    var opens  = (src.match(/\(/g) || []).length - (src.match(/\)/g) || []).length;
    var bracks = (src.match(/\[/g) || []).length - (src.match(/\]/g) || []).length;
    if (opens  > 0) src += ')'.repeat(opens);
    if (bracks > 0) src += ']'.repeat(bracks);
    return src + ' $';
  }
  // Outside math — strip completed math blocks, then check text-mode * and _
  var textOnly = src.replace(/\$[^$]*\$/g, '');
  var stars = (textOnly.match(/\*/g) || []).length;
  if (stars % 2 !== 0) src += '*';
  var underscores = (textOnly.match(/_/g) || []).length;
  if (underscores % 2 !== 0) src += '_';
  return src;
}

function drainCompile() {
  if (pendingText === null) return;
  compileBusy = true;
  var src = closePartial(pendingText);
  pendingText = null;
  window.__typstCompile(src, function(svgStr) {
    compileBusy = false;
    if (svgStr) {
      outEl.innerHTML     = svgStr;
      outEl.style.opacity = '1';
    }
    drainCompile();   // compile again if more content arrived while busy
  });
}

// ── syntax highlight ──────────────────────────────────────────────────────────
function hl(text) {
  var esc = function(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  };
  return text.split('\n').map(function(line) {
    if (/^=+\s/.test(line))
      return '<span class="ch-heading">' + esc(line) + '</span>';
    var out = '', i = 0;
    while (i < line.length) {
      var ch = line[i];
      if (ch === '/' && line[i+1] === '/') {
        out += '<span class="ch-comment">' + esc(line.slice(i)) + '</span>';
        i = line.length;
      } else if (ch === '#' && i+1 < line.length && /\w/.test(line[i+1])) {
        var j = i+1; while (j < line.length && /\w/.test(line[j])) j++;
        out += '<span class="ch-kw">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else if (ch === '*') {
        var j = i+1; while (j < line.length && line[j] !== '*') j++; if (j < line.length) j++;
        out += '<span class="ch-bold">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else if (ch === '"') {
        var j = i+1; while (j < line.length && line[j] !== '"') j++; if (j < line.length) j++;
        out += '<span class="ch-str">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else if (ch === '$') {
        var j = i+1; while (j < line.length && line[j] !== '$') j++; if (j < line.length) j++;
        out += '<span class="ch-math">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else { out += esc(ch); i++; }
    }
    return out;
  }).join('\n');
}

// ── render ────────────────────────────────────────────────────────────────────
function renderCode() {
  var demo          = DEMOS[di];
  var preambleLines = demo.lines.slice(0, demo.preamble + 1); // +1 for blank separator
  var contentLines  = demo.lines.slice(demo.preamble + 1);
  var contentFull   = contentLines.join('\n');
  var contentTyped  = contentFull.slice(0, charPos);

  var displayText   = preambleLines.join('\n') + '\n' + contentTyped;
  var allLines      = displayText.split('\n');

  // preamble rendered dim, content rendered normally
  var preambleHtml = '<span style="opacity:0.35">' + hl(preambleLines.join('\n')) + '</span>\n';
  codeEl.innerHTML = preambleHtml + hl(contentTyped) + '<span class="cur">▮</span>';
  lineEl.innerHTML = Array.from({length: allLines.length}, function(_, i) {
    return '<span>' + (i+1) + '</span>';
  }).join('');

  if (contentTyped.length > 0) {
    var hidden = (demo.hiddenDefs || []).join('\n');
    var src = hidden ? hidden + '\n' + contentTyped : contentTyped;
    triggerCompile(src);
  }
}

// ── animation loop ────────────────────────────────────────────────────────────
function tick() {
  var contentLines = DEMOS[di].lines.slice(DEMOS[di].preamble + 1);
  var full = contentLines.join('\n');

  if (phase === 'typing') {
    if (charPos < full.length) {
      charPos++;
      // rush past consecutive blank lines instantly
      while (charPos < full.length && full[charPos - 1] === '\n' && full[charPos] === '\n') {
        charPos++;
      }
    } else {
      phase  = 'hold';
      holdMs = 0;
    }
    renderCode();
    scrollToBottom();
    setTimeout(tick, charPos < full.length && full[charPos] === ' ' ? 10 : CHAR_MS);

  } else if (phase === 'hold') {
    holdMs += 16;
    if (holdMs < HOLD_MS) {
      setTimeout(tick, 16);
    } else {
      phase   = 'clearing';
      clearMs = 0;
      setTimeout(tick, 16);
    }

  } else { // clearing
    clearMs += 16;
    var t = Math.min(clearMs / FADE_MS, 1);
    codeEl.style.opacity = 1 - t;
    lineEl.style.opacity = 1 - t;
    outEl.style.opacity  = 1 - t;
    if (t < 1) {
      setTimeout(tick, 16);
    } else {
      di      = (di + 1) % DEMOS.length;
      charPos = 0;
      phase   = 'typing';
      compileBusy = false;
      pendingText = null;
      autoScroll  = true;
      window.__demoMeta = DEMOS[di];
      clearTimeout(autoScrollTimer);
      if (editorBody) editorBody.scrollTop = 0;
      codeEl.style.opacity = 1;
      lineEl.style.opacity = 1;
      outEl.style.opacity  = 1;
      outEl.innerHTML      = '<span class="render-status">loading typst…</span>';
      codeEl.innerHTML = '<span class="cur">▮</span>';
      lineEl.innerHTML = '<span>1</span>';
      setTimeout(tick, 300);
    }
  }
}

// expose current demo meta for the compile script
window.__demoMeta = DEMOS[di];

tick();


})();
</script>

<script is:inline>
(async function () {
  // "text" is the keyword that loads all NewCM10 + NewCMMath fonts from typst-assets CDN

  function buildPageSetup(meta) {
    var title  = (meta && meta.title)  || 'Course Notes';
    var course = (meta && meta.course) || '';
    return [
      '#set page(width: 500pt, height: 350pt, margin: (x: 30pt, top: 38pt, bottom: 20pt))',
      '#set text(size: 12pt, font: "New Computer Modern")',
      '#let loss = $cal(L)$',
      '#let apx = $approx$',
      '#let RR = $bb(R)$',
      '#let mid = "|"',
      '#let px(f, x) = $(partial #f) / (partial #x)$',
      '#let pv(f, x) = $(d #f) / (d #x)$',
      '#let dx = $upright(d)x$',
      '#set par(leading: 0.65em)',
      '#set block(spacing: 0.75em)',
      '#set math.equation(numbering: none)',
      '#set heading(numbering: "1.1")',
      '#show heading.where(level: 1): it => block(above: 1em, below: 0.35em)[',
      '  #text(size: 10.5pt, weight: "bold")[#counter(heading).display() #it.body]',
      ']',
      '#show heading.where(level: 2): it => block(above: 0.75em, below: 0.25em)[',
      '  #text(size: 9.5pt, weight: "bold")[#counter(heading).display() #it.body]',
      ']',
      '#align(center, stack(spacing: 0pt,',
      '  line(length: 100%, stroke: 2.5pt + rgb("#2c5aa0")),',
      '  v(0.7em),',
      '  text(size: 6pt, fill: rgb("#2c5aa0"), tracking: 2pt, weight: "bold")[LECTURE NOTES],',
      '  v(1.2em),',
      '  text(size: 16pt, weight: "bold")[' + title + '],',
      '  v(0.7em),',
      '  line(length: 28%, stroke: 0.5pt + rgb("#bbbbbb")),',
      '  v(0.5em),',
      '  text(size: 9pt, fill: rgb("#444444"))[' + course + '],',
      '  v(0.8em),',
      '))',
      '#line(length: 100%, stroke: 0.4pt + rgb("#dddddd"))',
      '#v(8pt)',
      '',
    ].join('\n');
  }

  var outEl = document.getElementById('render-out');

  try {
    await import('/typst-lite.js');
    var typst  = window.$typst;
    var Snippet = window.TypstSnippet;

    // Preload logo for use in Typst headers
    var logoBytes = null;
    try {
      var resp = await fetch('/sdu-logo.png');
      logoBytes = new Uint8Array(await resp.arrayBuffer());
    } catch (e) { logoBytes = null; }

    // Map sdust package so @local/sdust:0.1.0 resolves in the browser compiler
    try {
      var sdustResp = await fetch('/sdust-lib.typ');
      var sdustBytes = new Uint8Array(await sdustResp.arrayBuffer());
      typst.mapShadow('/packages/local/sdust/0.1.0/lib.typ', sdustBytes);
    } catch (e) { /* non-fatal */ }

    // Preload fonts via typst.use() before first compile
    typst.use(
      Snippet.preloadFontAssets({ assets: ['text'] })
    );

    typst.setCompilerInitOptions({
      getModule: function() {
        return fetch('https://cdn.jsdelivr.net/npm/@myriaddreamin/typst-ts-web-compiler@0.7.0/pkg/typst_ts_web_compiler_bg.wasm')
          .then(function(r) { return r.arrayBuffer(); });
      },
    });

    typst.setRendererInitOptions({
      getModule: function() {
        return fetch('https://cdn.jsdelivr.net/npm/@myriaddreamin/typst-ts-renderer@0.7.0/pkg/typst_ts_renderer_bg.wasm')
          .then(function(r) { return r.arrayBuffer(); });
      },
    });

    window.__typstCompile = async function(contentText, cb) {
      try {
        var setup = buildPageSetup(window.__demoMeta);
        if (logoBytes) typst.mapShadow('/sdu-logo.png', logoBytes);
        var svg = await typst.svg({ mainContent: setup + contentText });
        cb(svg);
      } catch (err) {
        cb('');  // must always call cb so compileBusy resets
      }
    };

  } catch (err) {
    if (outEl) outEl.innerHTML = '<pre style="font-size:9px;color:#c66;padding:8px;white-space:pre-wrap">' + err.message + '</pre>';
  }
})();
</script>

