---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { readFileSync } from 'fs';
import { resolve } from 'path';

const allNotes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Read the .typ source files — edit those files to change the animation.
// Lines 1-6 are the comment block; content starts at line 7.
const SKIP = 6;

function loadDemo(slug: string, title: string, course: string) {
  const raw = readFileSync(resolve('public/demo/src', slug + '.typ'), 'utf8');
  const content = raw.split('\n').slice(SKIP);
  // Strip trailing empty lines
  while (content.length && content[content.length - 1].trim() === '') content.pop();
  const preamble = [
    '#import "../../temp.typ": *',
    '#show: note.with(',
    `  title:  "${title}",`,
    `  course: "${course}",`,
    ')',
  ];
  return { slug, preamble: preamble.length, lines: [...preamble, '', ...content] };
}

const demos = [
  loadDemo('linear-algebra',   'Linear Algebra',   'DM561'),
  loadDemo('gradient-descent', 'Gradient Descent', 'AI505'),
  loadDemo('calculus',         'Calculus',         'MM536'),
];

const demosJson = JSON.stringify(demos);
---

<Layout title="Notes" description="Study notes by Simon Holm.">
  <div class="container page">
    <h1>Notes</h1>
    <p class="sub">
      Short write-ups on things I'm figuring out. Written in
      <a href="https://typst.app" target="_blank">Typst</a> —
      try the syntax with <a href="https://simo899t.github.io/typstnique" target="_blank">Typstnique</a>.
    </p>

    <div class="typst-blurb">
      <p>
        I write all my lecture notes in <a href="https://typst.app/open-source/" target="_blank">Typst</a> —
        real math, clean PDFs, no LaTeX boilerplate. I have a shared <code>temp.typ</code> every
        course imports: custom <code>#theorem</code> / <code>#definition</code> boxes,
        matrix shorthands like <code>succ</code>, calculus operators like <code>#dv(f,x)</code>.
        The demo below cycles through real snippets, compiled live in your browser.
      </p>
    </div>

    <!-- two-pane demo window -->
    <div class="demo-window">

      <!-- left: editor -->
      <div class="pane pane-src">
        <div class="titlebar">
          <span class="tb-dot red"></span>
          <span class="tb-dot yellow"></span>
          <span class="tb-dot green"></span>
          <span class="tb-name">notes.typ</span>
        </div>
        <div class="editor-body">
          <div id="line-nums" class="line-nums"></div>
          <pre id="code" class="code"></pre>
        </div>
      </div>

      <!-- right: rendered output -->
      <div class="pane pane-out">
        <div class="titlebar titlebar-light">
          <span class="tb-dot red"></span>
          <span class="tb-dot yellow"></span>
          <span class="tb-dot green"></span>
          <span class="tb-name tb-name-dark">notes.pdf</span>
        </div>
        <div class="output-body">
          <img id="render-img" class="render-img" src="" alt="" style="opacity:0">
        </div>
      </div>

    </div>

    {allNotes.length > 0 ? (
      <div class="note-list">
        {allNotes.map(n => (
          <a href={`/notes/${n.slug}`} class="note-row">
            <span class="note-title">{n.data.title}</span>
            <span class="note-meta">
              {n.data.tags.join(' · ')} &nbsp;·&nbsp;
              {n.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">more coming soon</p>
    )}
  </div>
</Layout>

<script is:inline define:vars={{ demosJson }}>
(function () {

// ── demos ─────────────────────────────────────────────────────────────────────
const DEMOS = JSON.parse(demosJson);

// ── state ─────────────────────────────────────────────────────────────────────
let di      = 0;
let charPos = 0;
let phase   = 'typing';  // 'typing' | 'hold' | 'clearing'
let holdMs  = 0;
let clearMs = 0;

const CHAR_MS = 36;
const HOLD_MS = 3200;
const FADE_MS = 380;

// ── DOM ───────────────────────────────────────────────────────────────────────
const codeEl = document.getElementById('code');
const lineEl = document.getElementById('line-nums');
const imgEl  = document.getElementById('render-img');

// ── per-line compile ──────────────────────────────────────────────────────────
// Compile fires when a new content line completes, not on every character.
// A "busy" flag prevents concurrent compiles — if one is in flight we skip
// the intermediate result (the next line completion will trigger a new one).
let lastCompiledLineCount = -1;
let compileBusy           = false;
let lastBlobUrl           = null;

function triggerCompile(lineCount, contentText) {
  if (lineCount <= lastCompiledLineCount) return;   // nothing new
  if (typeof window.__typstCompile !== 'function') return;  // WASM not ready
  if (compileBusy) return;  // previous compile still running — skip, next line will catch up

  lastCompiledLineCount = lineCount;
  compileBusy = true;
  window.__typstCompile(contentText, function(svgStr) {
    compileBusy = false;
    if (!svgStr) return;
    const blob = new Blob([svgStr], { type: 'image/svg+xml' });
    const url  = URL.createObjectURL(blob);
    if (lastBlobUrl) URL.revokeObjectURL(lastBlobUrl);
    lastBlobUrl = url;
    imgEl.src   = url;
    imgEl.style.opacity = '1';
  });
}

// ── syntax highlight ──────────────────────────────────────────────────────────
function hl(text) {
  var esc = function(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  };
  return text.split('\n').map(function(line) {
    if (/^=+\s/.test(line))
      return '<span style="color:#dcdcaa;font-weight:600">' + esc(line) + '</span>';
    var out = '', i = 0;
    while (i < line.length) {
      var ch = line[i];
      if (ch === '/' && line[i+1] === '/') {
        out += '<span style="color:#555">' + esc(line.slice(i)) + '</span>';
        i = line.length;
      } else if (ch === '#' && i+1 < line.length && /\w/.test(line[i+1])) {
        var j = i+1; while (j < line.length && /\w/.test(line[j])) j++;
        out += '<span style="color:#4db6c4">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else if (ch === '"') {
        var j = i+1; while (j < line.length && line[j] !== '"') j++; if (j < line.length) j++;
        out += '<span style="color:#ce9178">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else if (ch === '$') {
        var j = i+1; while (j < line.length && line[j] !== '$') j++; if (j < line.length) j++;
        out += '<span style="color:#b5cea8">' + esc(line.slice(i,j)) + '</span>'; i = j;
      } else { out += esc(ch); i++; }
    }
    return out;
  }).join('\n');
}

// ── render ────────────────────────────────────────────────────────────────────
function renderCode() {
  var full    = DEMOS[di].lines.join('\n');
  var text    = full.slice(0, charPos);
  var typed   = text.split('\n');
  var total   = DEMOS[di].lines.length;

  codeEl.innerHTML = hl(text) + '<span class="cur">▮</span>';
  lineEl.innerHTML = Array.from({length: total}, function(_, i) {
    return '<span style="opacity:' + (i < typed.length ? 1 : 0.25) + '">' + (i+1) + '</span>';
  }).join('');

  // compile when a new content line is completed
  var preamble     = DEMOS[di].preamble;
  var contentLines = typed.slice(preamble + 1); // +1 for blank separator line
  if (contentLines.length > 0) {
    triggerCompile(contentLines.length, contentLines.join('\n'));
  }
}

// ── animation loop ────────────────────────────────────────────────────────────
function tick() {
  var full = DEMOS[di].lines.join('\n');

  if (phase === 'typing') {
    if (charPos < full.length) {
      charPos++;
    } else {
      phase  = 'hold';
      holdMs = 0;
    }
    renderCode();
    setTimeout(tick, CHAR_MS);

  } else if (phase === 'hold') {
    holdMs += 16;
    if (holdMs < HOLD_MS) {
      setTimeout(tick, 16);
    } else {
      phase   = 'clearing';
      clearMs = 0;
      setTimeout(tick, 16);
    }

  } else { // clearing
    clearMs += 16;
    var t = Math.min(clearMs / FADE_MS, 1);
    codeEl.style.opacity = 1 - t;
    lineEl.style.opacity = 1 - t;
    imgEl.style.opacity  = 1 - t;
    if (t < 1) {
      setTimeout(tick, 16);
    } else {
      di      = (di + 1) % DEMOS.length;
      charPos = 0;
      phase   = 'typing';
      lastCompiledLineCount = -1;
      compileBusy           = false;
      codeEl.style.opacity = 1;
      lineEl.style.opacity = 1;
      imgEl.style.opacity  = 0;
      imgEl.src            = '';
      if (lastBlobUrl) { URL.revokeObjectURL(lastBlobUrl); lastBlobUrl = null; }
      codeEl.innerHTML = '<span class="cur">▮</span>';
      lineEl.innerHTML = '<span>1</span>';
      setTimeout(tick, 300);
    }
  }
}

tick();

})();
</script>

<script is:inline>
(async function () {
  var FONT_BASE = 'https://cdn.jsdelivr.net/gh/typst/typst-assets@v0.13.1/files/fonts/';
  var FONTS = [
    'NewCM10-Regular.otf',
    'NewCM10-Bold.otf',
    'NewCM10-Italic.otf',
    'NewCM10-BoldItalic.otf',
    'NewCMMath-Regular.otf',
    'NewCMMath-Book.otf',
    'NewCMMath-Bold.otf',
  ];

  var PAGE_SETUP = [
    '#set page(width: 240pt, height: auto, margin: (x: 14pt, y: 12pt))',
    '#set text(size: 9.5pt, font: "New Computer Modern")',
    '#set block(spacing: 0.65em)',
    '#align(center)[',
    '  *Course notes* \\',
    '  #text(size: 8pt, fill: luma(120))[Simon Holm · SDU · 2025]',
    ']',
    '#v(3pt)',
    '#line(length: 100%, stroke: 0.4pt + luma(160))',
    '#v(8pt)',
    '',
  ].join('\n');

  var outEl = document.getElementById('render-img');

  try {
    await import('/typst-lite.js');
    var typst  = window.$typst;
    var Snippet = window.TypstSnippet;

    // Preload fonts via typst.use() before first compile
    typst.use(
      Snippet.preloadFontAssets({
        assets: FONTS,
        assetUrlPrefix: FONT_BASE,
      })
    );

    typst.setCompilerInitOptions({
      getModule: function() {
        return fetch('https://cdn.jsdelivr.net/npm/@myriaddreamin/typst-ts-web-compiler@0.7.0/pkg/typst_ts_web_compiler_bg.wasm')
          .then(function(r) { return r.arrayBuffer(); });
      },
    });

    typst.setRendererInitOptions({
      getModule: function() {
        return fetch('https://cdn.jsdelivr.net/npm/@myriaddreamin/typst-ts-renderer@0.7.0/pkg/typst_ts_renderer_bg.wasm')
          .then(function(r) { return r.arrayBuffer(); });
      },
    });

    window.__typstCompile = async function(contentText, cb) {
      try {
        var svg = await typst.svg({ mainContent: PAGE_SETUP + contentText });
        cb(svg);
      } catch (err) {
        // mid-expression compile errors (incomplete code) are expected
      }
    };

  } catch (err) {
    if (outEl) outEl.insertAdjacentHTML('afterend',
      '<pre style="font-size:9px;color:#c66;padding:8px">' + err.message + '</pre>');
  }
})();
</script>

<style>
h1 { font-size: 1.6rem; font-weight: 600; margin-bottom: 0.35rem; }

.sub {
  font-size: 0.85rem;
  color: var(--text-dim);
  margin-bottom: 1rem;
}

.typst-blurb {
  margin-bottom: 1.5rem;
}
.typst-blurb p {
  font-size: 0.85rem;
  color: var(--text-muted);
  line-height: 1.7;
  margin: 0;
}
.typst-blurb code {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--accent);
  background: rgba(77,182,196,0.08);
  padding: 1px 4px;
  border-radius: 3px;
}

/* ── demo window ── */
.demo-window {
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: 340px;
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid #2a2a2a;
  margin-bottom: 2.5rem;
  box-shadow: 0 4px 24px rgba(0,0,0,0.4);
}

.pane { display: flex; flex-direction: column; min-width: 0; }

.titlebar {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  background: #1c1c1c;
  border-bottom: 1px solid #2a2a2a;
  flex-shrink: 0;
}
.titlebar-light {
  background: #d0cdc4;
  border-bottom: 1px solid #b8b5ac;
}

.tb-dot {
  width: 11px; height: 11px;
  border-radius: 50%;
  flex-shrink: 0;
}
.tb-dot.red    { background: #ff5f57; }
.tb-dot.yellow { background: #febc2e; }
.tb-dot.green  { background: #28c840; }

.tb-name {
  font-family: var(--font-mono);
  font-size: 11px;
  color: #555;
  margin-left: 4px;
}
.tb-name-dark { color: #888; }

/* left pane */
.pane-src {
  background: #111;
  border-right: 1px solid #222;
}

.editor-body {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.line-nums {
  display: flex;
  flex-direction: column;
  padding: 10px 8px 10px 6px;
  min-width: 30px;
  text-align: right;
  font-family: var(--font-mono);
  font-size: 10.5px;
  line-height: 1.6;
  color: #3a3a3a;
  border-right: 1px solid #1e1e1e;
  user-select: none;
  flex-shrink: 0;
}

.code {
  margin: 0;
  padding: 10px;
  font-family: var(--font-mono);
  font-size: 10.5px;
  line-height: 1.6;
  color: #ccc;
  white-space: pre-wrap;
  word-break: break-all;
  flex: 1;
  overflow: hidden;
}

.cur {
  color: #4db6c4;
  animation: blink 1s step-end infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* right pane */
.pane-out {
  background: #f0ede4;
}

.output-body {
  flex: 1;
  overflow: hidden;
  padding: 14px 16px;
}

.render-img {
  width: 100%;
  display: block;
  object-fit: contain;
  object-position: top left;
  transition: opacity 0.12s ease;
}

/* ── notes list ── */
.note-list {
  display: flex;
  flex-direction: column;
  border-top: 1px solid var(--border);
}

.note-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding: 0.8rem 0;
  border-bottom: 1px solid var(--border);
}
.note-row:hover .note-title { color: var(--accent); }

.note-title { font-size: 0.875rem; color: var(--text); }
.note-meta {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  white-space: nowrap;
}

.empty {
  font-size: 0.85rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
}
</style>
