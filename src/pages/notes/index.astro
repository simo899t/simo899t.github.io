---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNotes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const studying = [
  'Knowledge Representation & Reasoning — A(RC), FOL, propositional logic',
  'Optimisation — KKT conditions, Lagrangian duality, convex analysis',
  'AI safety & interpretability',
];
---

<Layout title="Notes" description="Study notes by Simon Holm.">
  <div class="container page">
    <h1>Notes</h1>
    <p class="sub">
      Short write-ups on things I'm figuring out.
      Written in <a href="https://typst.app" target="_blank">Typst</a> —
      try the syntax with <a href="https://simo899t.github.io/typstnique" target="_blank">Typstnique</a>.
    </p>

    <div class="typst-demo">
      <div class="demo-src">
        <div class="pane-bar">
          <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
          <span class="pane-title">notes.typ</span>
        </div>
        <div class="editor">
          <div class="line-nums" id="line-nums"></div>
          <pre id="typst-src"></pre>
        </div>
      </div>
      <div class="demo-out">
        <div class="pane-bar">
          <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
          <span class="pane-title">notes.pdf</span>
        </div>
        <div class="paper-wrap">
          <div class="paper" id="paper"></div>
        </div>
      </div>
    </div>

    <div class="studying">
      <span class="label">currently studying</span>
      <ul>
        {studying.map(s => <li><span class="bullet">▸</span>{s}</li>)}
      </ul>
    </div>

    {allNotes.length > 0 ? (
      <div class="note-list">
        {allNotes.map(n => (
          <a href={`/notes/${n.slug}`} class="note-row">
            <span class="note-title">{n.data.title}</span>
            <span class="note-meta">
              {n.data.tags.join(' · ')} &nbsp;·&nbsp;
              {n.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">more coming soon</p>
    )}
  </div>
</Layout>

<script>
const srcEl   = document.getElementById('typst-src')!;
const lineEl  = document.getElementById('line-nums')!;
const paperEl = document.getElementById('paper')!;

// Each demo: array of source lines + the rendered HTML for the paper side
const DEMOS = [
  {
    src: [
      `#import "template.typ": note`,
      `#show: note.with(`,
      `  title: "KKT Conditions",`,
      `  date: 2026-06-01,`,
      `)`,
      ``,
      `= Stationarity`,
      ``,
      `For a minimisation problem with`,
      `inequality constraints $g_i(x) <= 0$:`,
      ``,
      `$ nabla f(x^*) + sum_i mu_i nabla g_i(x^*) = 0 $`,
      ``,
      `== Complementary slackness`,
      ``,
      `$ mu_i dot g_i(x^*) = 0, quad mu_i >= 0 $`,
    ],
    out: `
      <h1>KKT Conditions</h1>
      <h2>Stationarity</h2>
      <p>For a minimisation problem with inequality constraints <em>g<sub>i</sub>(x) ≤ 0</em>:</p>
      <div class="math">∇f(x*) + Σᵢ μᵢ ∇gᵢ(x*) = 0</div>
      <h2>Complementary slackness</h2>
      <div class="math">μᵢ · gᵢ(x*) = 0,&ensp; μᵢ ≥ 0</div>
    `,
  },
  {
    src: [
      `#import "template.typ": note`,
      `#show: note.with(title: "Attention")`,
      ``,
      `= Scaled Dot-Product Attention`,
      ``,
      `Given queries $Q$, keys $K$, values $V$`,
      `with dimension $d_k$:`,
      ``,
      `$ "Attn"(Q, K, V) = "softmax"`,
      `  (Q K^T / sqrt(d_k)) V $`,
      ``,
      `The $sqrt(d_k)$ scaling prevents`,
      `vanishing gradients in large $d_k$.`,
    ],
    out: `
      <h1>Scaled Dot-Product Attention</h1>
      <p>Given queries <em>Q</em>, keys <em>K</em>, values <em>V</em> with dimension <em>d<sub>k</sub></em>:</p>
      <div class="math">Attn(Q, K, V) = softmax( QKᵀ / √d<sub>k</sub> ) V</div>
      <p>The √d<sub>k</sub> scaling prevents vanishing gradients in large d<sub>k</sub>.</p>
    `,
  },
  {
    src: [
      `#import "template.typ": note`,
      `#show: note.with(title: "Entailment")`,
      ``,
      `= Entailment in $cal(A)$`,
      ``,
      `A model $cal(M)$ _satisfies_ All $p q$ iff`,
      `$[|p|] subset.eq [|q|]$.`,
      ``,
      `#definition[`,
      `  $Gamma models phi$ iff every model`,
      `  satisfying all of $Gamma$ also`,
      `  satisfies $phi$.`,
      `]`,
      ``,
      `This is a *universal* statement.`,
    ],
    out: `
      <h1>Entailment in 𝒜</h1>
      <p>A model ℳ <em>satisfies</em> All <em>p q</em> iff ⟦p⟧ ⊆ ⟦q⟧.</p>
      <div class="def-box">
        <strong>Definition.</strong> Γ ⊨ φ iff every model satisfying all of Γ also satisfies φ.
      </div>
      <p>This is a <strong>universal</strong> statement.</p>
    `,
  },
];

let demoIdx = 0;
let charPos = 0;       // absolute char position across all lines
let phase: 'typing' | 'hold' | 'clearing' = 'typing';
let holdTick = 0;
let clearTick = 0;

const CHAR_MS   = 28;
const HOLD_MS   = 2200;
const CLEAR_MS  = 400;

function currentSrc() {
  const lines = DEMOS[demoIdx].src;
  const full  = lines.join('\n');
  return full.slice(0, charPos);
}

function highlight(text: string): string {
  // colour by token type, VS Code dark theme inspired
  return text
    .replace(/^(#\w+)/gm, '<span style="color:#4db6c4">$1</span>')
    .replace(/(\"[^\"]*\")/g,        '<span style="color:#ce9178">$1</span>')
    .replace(/(\$[^\$\n]+\$)/g,      '<span style="color:#b5cea8">$1</span>')
    .replace(/\b(true|false)\b/g,    '<span style="color:#569cd6">$1</span>')
    .replace(/(\/\/[^\n]*)/g,        '<span style="color:#555">$1</span>')
    .replace(/^(=+\s[^\n]*)/gm,      '<span style="color:#dcdcaa; font-weight:600">$1</span>');
}

function render() {
  const text  = currentSrc();
  const lines = text.split('\n');
  const totalLines = DEMOS[demoIdx].src.length;

  // source pane
  srcEl.innerHTML = highlight(text) + '<span class="cursor">▮</span>';

  // line numbers
  lineEl.innerHTML = lines.map((_, i) =>
    `<span>${i + 1}</span>`
  ).join('');

  // paper — show progressively as typing advances
  const progress = charPos / DEMOS[demoIdx].src.join('\n').length;
  if (phase === 'hold') {
    paperEl.innerHTML = DEMOS[demoIdx].out;
    paperEl.style.opacity = '1';
  } else {
    // fade in paper content as typing progresses past halfway
    const opacity = Math.max(0, (progress - 0.3) / 0.7);
    paperEl.innerHTML = DEMOS[demoIdx].out;
    paperEl.style.opacity = String(Math.min(opacity, 1));
  }
}

function step() {
  const fullLen = DEMOS[demoIdx].src.join('\n').length;

  if (phase === 'typing') {
    if (charPos < fullLen) {
      charPos += 2;
      if (charPos > fullLen) charPos = fullLen;
    } else {
      phase = 'hold';
      holdTick = 0;
    }
    render();
    setTimeout(step, CHAR_MS);

  } else if (phase === 'hold') {
    holdTick += 16;
    render();
    if (holdTick < HOLD_MS) {
      setTimeout(step, 16);
    } else {
      phase = 'clearing';
      clearTick = 0;
      setTimeout(step, 16);
    }

  } else {
    clearTick += 16;
    const t = Math.min(clearTick / CLEAR_MS, 1);
    paperEl.style.opacity = String(1 - t);
    if (t < 1) {
      setTimeout(step, 16);
    } else {
      demoIdx = (demoIdx + 1) % DEMOS.length;
      charPos = 0;
      phase   = 'typing';
      paperEl.innerHTML = '';
      srcEl.innerHTML   = '<span class="cursor">▮</span>';
      lineEl.innerHTML  = '<span>1</span>';
      setTimeout(step, 300);
    }
  }
}

step();
</script>

<style>
h1 { font-size: 1.6rem; font-weight: 600; margin-bottom: 0.35rem; }

.sub {
  font-size: 0.85rem;
  color: var(--text-dim);
  margin-bottom: 1.5rem;
}

/* ── Typst demo ─────────────────────── */
.typst-demo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border: 1px solid #2a2a2a;
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: 2.25rem;
  font-size: 0;   /* kill inline-block gaps */
}

.pane-bar {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 7px 10px;
  background: #1a1a1a;
  border-bottom: 1px solid #262626;
}

.dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}
.dot.red    { background: #ff5f57; }
.dot.yellow { background: #febc2e; }
.dot.green  { background: #28c840; }

.pane-title {
  font-family: var(--font-mono);
  font-size: 10px;
  color: #555;
  margin-left: 6px;
}

/* source side */
.demo-src {
  border-right: 1px solid #222;
  background: #111;
}

.editor {
  display: flex;
  min-height: 220px;
  max-height: 280px;
  overflow: hidden;
}

.line-nums {
  display: flex;
  flex-direction: column;
  padding: 10px 8px 10px 0;
  min-width: 28px;
  text-align: right;
  font-family: var(--font-mono);
  font-size: 10px;
  line-height: 1.6;
  color: #3a3a3a;
  background: #111;
  border-right: 1px solid #1e1e1e;
  user-select: none;
  flex-shrink: 0;
}

#typst-src {
  margin: 0;
  padding: 10px 10px 10px 10px;
  font-family: var(--font-mono);
  font-size: 10.5px;
  line-height: 1.6;
  color: #ccc;
  white-space: pre-wrap;
  word-break: break-all;
  background: #111;
  flex: 1;
  border: none;
  outline: none;
}

.cursor {
  color: #4db6c4;
  animation: blink 1s step-end infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* output side */
.demo-out {
  background: #e8e5dc;
  display: flex;
  flex-direction: column;
}

.demo-out .pane-bar {
  background: #d8d5cc;
  border-bottom: 1px solid #c8c5bc;
}

.demo-out .pane-title { color: #999; }

.paper-wrap {
  flex: 1;
  padding: 16px 18px;
  overflow: hidden;
}

.paper {
  font-family: 'Georgia', 'Times New Roman', serif;
  font-size: 11px;
  color: #111;
  line-height: 1.65;
  transition: opacity 0.25s;
}

.paper :global(h1) {
  font-size: 14px;
  font-weight: bold;
  margin: 0 0 10px;
  padding-bottom: 4px;
  border-bottom: 0.5px solid #bbb;
  color: #111;
}

.paper :global(h2) {
  font-size: 11px;
  font-weight: bold;
  margin: 10px 0 4px;
  color: #111;
}

.paper :global(p) {
  margin: 0 0 7px;
  color: #222;
  font-size: 10.5px;
}

.paper :global(.math) {
  font-style: italic;
  text-align: center;
  margin: 8px 0;
  font-size: 11px;
  color: #111;
}

.paper :global(.def-box) {
  border: 0.5px solid #aaa;
  padding: 6px 10px;
  margin: 8px 0;
  font-size: 10.5px;
  color: #222;
  background: #f2efe6;
}

/* ── rest of page ───────────────────── */
.studying { margin-bottom: 2rem; }

.label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  display: block;
  margin-bottom: 0.6rem;
}

.studying ul { list-style: none; display: flex; flex-direction: column; gap: 0.3rem; }

.studying li {
  font-size: 0.85rem;
  color: var(--text-muted);
  display: flex;
  gap: 0.5rem;
}

.bullet { color: var(--accent); flex-shrink: 0; }

.note-list {
  display: flex;
  flex-direction: column;
  border-top: 1px solid var(--border);
}

.note-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding: 0.8rem 0;
  border-bottom: 1px solid var(--border);
  opacity: 1 !important;
}

.note-row:hover .note-title { color: var(--accent); }

.note-title { font-size: 0.875rem; color: var(--text); }

.note-meta {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  white-space: nowrap;
}

.empty {
  font-size: 0.85rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
}
</style>
