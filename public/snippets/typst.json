{
  "Inline math": {
    "prefix": "im",
    "body": "\\$$1$",
    "description": "Inline math with cursor between spaces"
  },
  "Display math": {
    "prefix": "dm",
    "body": "$ $1 $",
    "description": "Display math block"
  },
  "Pagebreak": {
    "prefix": "pb",
    "body": "#pagebreak()\n$0",
    "description": "Insert a page break"
  },
  "Figure with caption": {
    "prefix": "fig",
    "body": [
      "#figure(",
      "  ${1:none},",
      "  caption: [${3:Caption text}],",
      ") <${4:label}>",
      "$0"
    ],
    "description": "Figure with caption and label"
  },
  "Grid layout": {
    "prefix": "grid",
    "body": [
      "#grid(",
      "  columns: (${1:1fr, 1fr}),",
      "  column-gutter: ${2:1em},",
      "  row-gutter: ${3:1em},",
      "  ${4:cell1}, ${5:cell2},",
      ")",
      "$0"
    ],
    "description": "Grid layout with columns/gutters"
  },
  "Theorem": {
    "prefix": "theorem",
    "body": [
      "#theorem(title: \"${1:Theorem}\")[",
      "  ${2:statement}",
      "]",
      "$0"
    ],
    "description": "Blue theorem block (sdust)"
  },
  "Definition": {
    "prefix": "def",
    "body": [
      "#definition(title: \"${1:Definition}\")[",
      "  ${2:statement}",
      "]",
      "$0"
    ],
    "description": "Green definition block (sdust)"
  },
  "Example": {
    "prefix": "example",
    "body": [
      "#example(title: \"${1:Example}\")[",
      "  ${2:statement}",
      "]",
      "$0"
    ],
    "description": "Red example block (sdust)"
  },
  "Proof": {
    "prefix": "proof",
    "body": [
      "#proof(title: \"${1:Proof}\")[",
      "  ${2:reasoning}",
      "]",
      "$0"
    ],
    "description": "White/neutral proof block, ends with QED (sdust)"
  },
  "Tree (tidy-tree)": {
    "prefix": "tree",
    "body": [
      "#figure(",
      "  tree(",
      "    shape: \"${4:rectangle}\",",
      "    reverse: ${5:false},",
      "    spacing: (${6:40pt}, ${7:40pt}),",
      "  )[",
      "    - ${1:root}",
      "      - ${2:child 1}",
      "      - ${3:child 2}",
      "  ],",
      "  caption: [${7:Caption text}],",
      ") <${9:label}>",
      "$0"
    ],
    "description": "tree (tidy-tree) template"
  },
  "Proof tree (curryst)": {
    "prefix": "ptree",
    "body": [
      "#figure(",
      "  prooftree(rule(",
      "    \\$${1:conclusion}\\$,",
      "    \\$${2:premise-1}\\$,",
      "    \\$${3:premise-2}\\$,",
      "  )),",
      "  caption: [${4:Caption text}],",
      ") <${5:label}>",
      "$0"
    ],
    "description": "Proof tree template"
  },
  "Pseudocode algorithm": {
    "prefix": "pseudo",
    "body": [
      "#pseudo[",
      "  *Algorithm* ${1:Name}",
      "  - *Goal:* ${2:what the algorithm computes}",
      "  - *Input:* \\$${3:x}\\$",
      "  + *for* \\$${4:i = 1, dots, n}\\$ *do*",
      "    + ${5:\"body\"}",
      "  + *while* \\$${6:}\\$ *do*",
      "    + ${7:\"body\"}",
      "  + *return* ${8:}",
      "]",
      "$0"
    ],
    "description": "Pseudocode algorithm template"
  },
  "Induction proof": {
    "prefix": "induct",
    "body": [
      "#pseudo[",
      "*Proof by induction*",
      "- ${2:I want to prove that...}",
      "+ *\\$underline(\"Base case\")\\$*",
      "  + ${3:content}",
      "+ *\\$underline(\"Inductive hypothesis\")\\$*",
      "  + Assume that ${4:hypothesis}",
      "+ *\\$underline(\"Inductive step\")\\$*",
      "  + ${5:content}",
      "]",
      "$0"
    ],
    "description": "Induction proof template"
  },
  "SDU template import": {
    "prefix": "sdust",
    "body": ["#import \"@local/sdust:0.1.0\": *",
             "$0"],
    "description": "Import the SDU temp.typ template"
  },
  "SDU note": {
    "prefix": "note",
    "body": [
      "#import \"${1:../../temp.typ}\": *",
      "#show: note.with(",
      "  title:         \"${2:Lecture Notes}\",",
      "  course:        \"${3:DM000 — Course Name}\",",
      "  author:        \"${4:Simon Holm}\",",
      "  date:          \"${5:date}\",",
      "  outline:       true,",
      "  outline-depth: 2,",
      ")",
      "",
      "= ${6:First Section}",
      "$0"
    ],
    "description": "SDU lecture note document template"
  },
  "SDU exercise": {
    "prefix": "exercise",
    "body": [
      "#import \"${1:../../temp.typ}\": *",
      "#show: exercise.with(",
      "  title:         \"${2:Exercises 1}\",",
      "  course:        \"${3:DM000 — Course Name}\",",
      "  author:        \"${4:Simon Holm}\",",
      "  date:          \"${5:date}\",",
      "  outline:       true,",
      "  outline-depth: 2,",
      ")",
      "",
      "= ${6:Exercise 1}",
      "$0"
    ],
    "description": "SDU exercise document template"
  },
  "SDU project": {
    "prefix": "project",
    "body": [
      "#import \"${1:../../temp.typ}\": *",
      "#show: project.with(",
      "  title:         \"${2:Project Title}\",",
      "  course:        \"${3:DM000 — Course Name}\",",
      "  author:        \"${4:Simon Holm}\",",
      "  date:          \"${5:date}\",",
      "  group:         \"${6:Group no.}\",",
      "  supervisor:    \"${7:Prof. Firstname Lastname}\",",
      "  university:    \"University of Southern Denmark\",",
      "  outline:       true,",
      "  outline-depth: 2,",
      ")",
      "",
      "= ${8:Introduction}",
      "$0"
    ],
    "description": "SDU project document template"
  },
  "Python code block": {
    "prefix": "pycode",
    "body": [
      "```py",
      "${1:code}",
      "```",
      "$0"
    ],
    "description": "Fenced Python code block"
  }
  ,
  "Output/terminal code block": {
  "prefix": "outcode",
    "body": [
      "```output",
      "${1:code}",
      "```",
      "$0"
    ],
    "description": "Fenced terminal style code block"
  }
}
