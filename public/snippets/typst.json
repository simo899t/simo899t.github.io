{
  "Inline math": {
    "prefix": "im",
    "body": "\\$$1$",
    "description": "Inline math with cursor between spaces"
  },
  "Display math": {
    "prefix": "dm",
    "body": "$ $1 $",
    "description": "Display math block"
  },
  "Pagebreak": {
    "prefix": "pb",
    "body": "#pagebreak()\n$0",
    "description": "Insert a page break"
  },
  "Figure with caption": {
    "prefix": "fig",
    "body": [
      "#figure(",
      "  ${1:none},",
      "  caption: [${3:Caption text}],",
      ") <${4:label}>",
      "$0"
    ],
    "description": "Figure with caption and label"
  },
  "Grid layout": {
    "prefix": "grid",
    "body": [
      "#grid(",
      "  columns: 2,",
      "  column-gutter: 2em,",
      "  rows: 2,",
      "  row-gutter: 2em,",
      "  ${1:cell1}, ${2:cell2},",
      "  ${3:cell3}, ${4:cell4},",
      ")",
      "$0"
    ],
    "description": "2x2 grid layout with columns/gutters"
  },
  "Table layout": {
    "prefix": "table",
    "body": [
      "#table(",
      "  columns: ${1:2},",
      "  align: center + horizon,",
      "  ${2:cell1}, ${3:cell2},",
      "  ${4:cell3}, ${5:cell4},",
      ")",
      "$0"
    ],
    "description": "Table layout with columns"
  },
  "Theorem": {
    "prefix": "theorem",
    "body": [
      "#theorem(title: \"${1:Theorem}\")[",
      "  ${2:statement}",
      "]",
      "$0"
    ],
    "description": "Blue theorem block (sdust)"
  },
  "Definition": {
    "prefix": "def",
    "body": [
      "#definition(title: \"${1:Definition}\")[",
      "  ${2:statement}",
      "]",
      "$0"
    ],
    "description": "Green definition block (sdust)"
  },
  "Example": {
    "prefix": "example",
    "body": [
      "#example(title: \"${1:Example}\")[",
      "  ${2:statement}",
      "]",
      "$0"
    ],
    "description": "Red example block (sdust)"
  },
  "Corollary": {
    "prefix": "corollary",
    "body": [
      "#corollary(title: \"${1:Corollary}\")[",
      "  ${2:statement}",
      "]",
      "$0"
    ],
    "description": "Purple corollary block (sdust)"
  },
  "Proof": {
    "prefix": "proof",
    "body": [
      "#proof(title: \"${1:Proof}\")[",
      "  ${2:reasoning}",
      "]",
      "$0"
    ],
    "description": "White/neutral proof block, ends with QED (sdust)"
  },
  "Tree (tidy-tree)": {
    "prefix": "tree",
    "body": [
      "#figure(",
      "  tree(",
      "    shape: \"${4:rectangle}\",",
      "    reverse: ${5:false},",
      "    spacing: (${6:40pt}, ${7:40pt}),",
      "  )[",
      "    - ${1:root}",
      "      - ${2:child 1}",
      "      - ${3:child 2}",
      "  ],",
      "  caption: [${7:Caption text}],",
      ") <${9:label}>",
      "$0"
    ],
    "description": "tree (tidy-tree) template"
  },
  "Proof tree (curryst)": {
    "prefix": "ptree",
    "body": [
      "#figure(",
      "  prooftree(rule(",
      "    \\$${1:conclusion}\\$,",
      "    \\$${2:premise-1}\\$,",
      "    \\$${3:premise-2}\\$,",
      "  )),",
      "  caption: [${4:Caption text}],",
      ") <${5:label}>",
      "$0"
    ],
    "description": "Proof tree template"
  },
  "Pseudocode algorithm": {
    "prefix": "pseudo",
    "body": [
      "#pseudo[",
      "  *Algorithm* ${1:Name}",
      "  - *Goal:* ${2:what the algorithm computes}",
      "  - *Input:* \\$${3:x}\\$",
      "  + *for* \\$${4:i = 1, dots, n}\\$ *do*",
      "    + ${5:\"body\"}",
      "  + *while* \\$${6:}\\$ *do*",
      "    + ${7:\"body\"}",
      "  + *return* ${8:}",
      "]",
      "$0"
    ],
    "description": "Pseudocode algorithm template"
  },
  "Induction proof": {
    "prefix": "induct",
    "body": [
      "#pseudo[",
      "*Proof by induction*",
      "- ${2:I want to prove that...}",
      "+ *\\$underline(\"Base case\")\\$*",
      "  + ${3:content}",
      "+ *\\$underline(\"Inductive hypothesis\")\\$*",
      "  + Assume that ${4:hypothesis}",
      "+ *\\$underline(\"Inductive step\")\\$*",
      "  + ${5:content}",
      "]",
      "$0"
    ],
    "description": "Induction proof template"
  },
  "Graph (sdust)": {
    "prefix": "graph",
    "body": [
      "#graph(",
      "  nodes: (",
      "    (pos: (0,0), label: \\$${1:1}\\$),",
      "    (pos: (1,1), label: \\$${2:2}\\$),",
      "    (pos: (2,0), label: \\$${3:3}\\$),",
      "  ),",
      "  edges: (",
      "    ((0,0), (1,1)),",
      "    ((1,1), (2,0)),",
      "    ((0,0), (2,0)),",
      "  ),",
      "  caption: [${4:Caption text}],",
      ")",
      "$0"
    ],
    "description": "Node/edge graph diagram (sdust, fletcher-based)"
  },
  "SDU template import": {
    "prefix": "sdust",
    "body": ["#import \"@local/sdust:0.1.0\": *",
             "$0"],
    "description": "Import the SDU temp.typ template"
  },
  "Personal template import": {
    "prefix": "tempst",
    "body": ["#import \"@local/tempst:0.1.0\": *",
             "$0"],
    "description": "Import the SDU temp.typ template"
  },
  "SDU note": {
    "prefix": "note",
    "body": [
      "#import \"@local/tempst:0.1.0\": *",
      "#show: note.with(",
      "  title:         \"${1:Lecture Notes}\",",
      "  course:        \"${2:DM000 — Course Name}\",",
      "  author:        \"${3:Simon Holm}\",",
      "  date:          \"${4:date}\",",
      "  outline:       true,",
      "  outline-depth: 2,",
      ")",
      "",
      "= ${5:First Section}",
      "$0"
    ],
    "description": "SDU lecture note document template"
  },
  "SDU exercise": {
    "prefix": "exercise",
    "body": [
      "#import \"@local/tempst:0.1.0\": *",
      "#show: exercise.with(",
      "  title:         \"${1:Exercises 1}\",",
      "  course:        \"${2:DM000 — Course Name}\",",
      "  author:        \"${3:Simon Holm}\",",
      "  date:          \"${4:date}\",",
      "  outline:       true,",
      "  outline-depth: 2,",
      ")",
      "",
      "= ${5:Exercise 1}",
      "$0"
    ],
    "description": "SDU exercise document template"
  },
  "SDU project": {
    "prefix": "project",
    "body": [
      "#import \"@local/tempst:0.1.0\": *",
      "#show: project.with(",
      "  title:         \"${2:Project Title}\",",
      "  subtitle:      \"${3:Project Subtitle}\",",
      "  course:        \"${4:DM000 — Course Name}\",",
      "  author:        \"${5:Simon Holm}\",",
      "  date:          \"${6:date}\",",
      "  group:         \"${7:Group no.}\",",
      "  supervisor:    \"${8:Prof. Firstname Lastname}\",",
      "  university:    \"University of Southern Denmark\",",
      "  outline:       true,",
      "  outline-depth: 2,",
      ")",
      "$0"
    ],
    "description": "SDU project document template"
  },
  "SDU exam": {
    "prefix": "exam",
    "body": [
      "#import \"@local/tempst:0.1.0\": *",
      "#show: exam.with(",
      "  title:         \"${2:Exam Title}\",",
      "  course:        \"${4:DM000 — Course Name}\",",
      "  author:        \"${5:Simon Holm}\",",
      "  date:          \"${6:date}\",",
      "  university:    \"University of Southern Denmark\",",
      "  outline:       true,",
      "  outline-depth: 2,",
      ")",
      "$0"
    ],
    "description": "SDU exam document template"
  },
  "Python code block": {
    "prefix": "pycode",
    "body": [
      "```py",
      "${1:code}",
      "```",
      "$0"
    ],
    "description": "Fenced Python code block"
  },
  "Code block": {
    "prefix": "code",
    "body": [
      "```${1:lang}",
      "${2:code}",
      "```",
      "$0"
    ],
    "description": "Fenced code block, any language"
  },
  "Output/terminal code block": {
  "prefix": "outcode",
    "body": [
      "```output",
      "${1:code}",
      "```",
      "$0"
    ],
    "description": "Fenced terminal style code block"
  },
  "enum a)": {
  "prefix": "enuma",
    "body": [
      "#set enum(numbering: \"a)\")"
    ],
    "description": "Enum by a)"
  },
  "enum 1)": {
  "prefix": "enum1",
    "body": [
      "#set enum(numbering: \"1.\")"
    ],
    "description": "Enum by 1"
  },
  "sum": {
  "prefix": "sum",
    "body": [
      "sum_(${1:i=1})^(${2:n}) ${3:a_i}$0"
    ],
    "description": "native sum"
  },
  "integral": {
  "prefix": "int",
    "body": [
      "integral_(${1:a})^(${2:b}) ${3:f(x) dif x}$0"
    ],
    "description": "native integral from a to b"
  },
  "product": {
  "prefix": "prod",
    "body": [
      "product_(${1:i=1})^(${2:n}) ${3:a_i}$0"
    ],
    "description": "native product"
  },
  "limit": {
  "prefix": "lim",
    "body": [
      "lim_(${1:x to a}) ${2:f(x)}$0"
    ],
    "description": "native fraction"
  },
  "fractions": {
  "prefix": "frac",
    "body": [
      "(${1:})/(${2:})$0"
    ],
    "description": "native fraction"
  },
  "2D function plot": {
    "prefix": "plot2d",
    "body": [
      "#plot2d(",
      "    f: \"${1:sin(x)}\",",
      "    x: (${2:-1}, ${3:1}),",
      ")",
      "$0"
    ],
    "description": "sdust plot2d — plot y = f(x) from a formula string"
  },
  "3D surface plot": {
    "prefix": "plot3d",
    "body": [
      "#plot3d(",
      "    f: \"${1:x^2 + y^2}\",",
      "    x: (${2:-1}, ${3:1}),",
      "    y: (${4:-1}, ${5:1}),",
      ")",
      "$0"
    ],
    "description": "sdust plot3d — plot z = f(x, y) from a formula string"
  },
  "tex math": {
    "prefix": "tex",
    "body": [
      "#tex[${1:\\\\int_a^b f(x)\\\\,dx = F(b) - F(a)}]$0"
    ],
    "description": "raw LaTeX math via mitex"
  },
  "uml diagram": {
    "prefix": "uml",
    "body": [
      "#uml(",
      "  nodes: (\"${1:Client}\", \"${2:Server}\", \"${3:Database}\"),",
      "  edges: ((\"${1:Client}\", \"${2:Server}\", \"${4:request}\"), (\"${2:Server}\", \"${3:Database}\", \"${5:query}\")),",
      ")$0"
    ],
    "description": "simple list-format UML/flow diagram"
  }
}
